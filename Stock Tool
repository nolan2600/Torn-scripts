        content.appendChild(hdr);

        const sub = document.createElement('p');
        sub.className = 'sadv-sub';
        sub.textContent = 'Stocks ranked by recent price momentum. Best for overnight or short holds.';
        content.appendChild(sub);

        if (!hasEnoughHistory) {
            const warn = document.createElement('div');
            warn.className = 'sadv-warn';
            warn.innerHTML = `⚠️ <strong>Building price history…</strong> Come back after a few sessions for accurate 24h trends. Showing live prices for now.`;
            content.appendChild(warn);
        }

        // Top 3 recommendations
        if (top3.length) {
            const secTitle = document.createElement('p');
            secTitle.className = 'sadv-section-title';
            secTitle.textContent = '🔥 Top Momentum Picks';
            content.appendChild(secTitle);

            const medals = ['🥇','🥈','🥉'];
            top3.forEach((s, i) => {
                const p = perf(s.pct24);
                const p7 = perf(s.pct7d);
                const arrow = trendArrow(s.pct24);
                const stockId = Object.keys(STOCK_MAP).find(k => STOCK_MAP[k] === s.acronym);

                const card = document.createElement('div');
                card.className = 'sadv-card';
                card.style.borderLeftColor = p.border;
                card.style.background = p.bg.replace('0.3','0.15');

