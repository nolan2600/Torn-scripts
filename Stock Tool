    // ─── Original "Next Investment" button ────────────────────────────────────
    async function calculateRecommendation() {
        if (!apiKey) {
            const k = prompt('Enter your Torn API key (Limited or Full access):');
            if (!k) { showNotification('API key required.','error'); return; }
            saveApiKey(k);
        }

        showNotification('Loading…','info');
        const auth = await checkAuthorization(apiKey);
        if (!auth.authorized) { if (auth.error?.includes('Invalid')) clearApiKey(); showNotification(auth.error,'error'); return; }
        if (!INVESTMENT_TABLE?.length) { showNotification('Failed to load investment data.','error'); return; }

        const savedInv = localStorage.getItem(INVESTMENTS_KEY);
        if (savedInv) investmentPreferences = {...investmentPreferences, ...JSON.parse(savedInv)};

        showNotification('Calculating…','info');

        try {
            const moneyData    = await fetchAPI(`https://api.torn.com/v2/user/money?key=${apiKey}`);
            const networthData = await fetchAPI(`https://api.torn.com/v2/user?selections=networth&key=${apiKey}`);
            const money = moneyData.money; const nw = networthData.networth;

            let balance = 0;
            if (settings.wallet)       balance += money.wallet||0;
            if (settings.bank)         balance += money.city_bank?.amount||0;
            if (settings.cayman)       balance += money.cayman_bank||0;
            if (settings.vault)        balance += money.vault||0;
            if (settings.factionMoney) balance += money.faction?.money||0;
            if (settings.company)      balance += money.company||0;
            if (settings.pending)      balance += nw.pending||0;
            if (settings.points)       balance += nw.points||0;
            if (settings.piggybank)    balance += nw.piggybank||0;
            if (settings.items)        balance += nw.items||0;
            if (settings.displaycase)  balance += nw.displaycase||0;
            if (settings.bazaar)       balance += nw.bazaar||0;
            if (settings.trade)        balance += nw.trade||0;
            if (settings.itemmarket)   balance += nw.itemmarket||0;
            if (settings.properties)   balance += nw.properties||0;
            if (settings.auctionhouse) balance += nw.auctionhouse||0;
            if (settings.bookie)       balance += nw.bookie||0;
            if (settings.enlistedcars) balance += nw.enlistedcars||0;
            if (settings.loan)         balance += nw.loan||0;
            if (settings.unpaidfees)   balance += nw.unpaidfees||0;

            if (settings.companyEscrow) {
                try {
                    const cd = await fetchAPI(`https://api.torn.com/v2/company?selections=detailed,employees&key=${apiKey}`);
                    if (!cd.error && cd.company_detailed) {
                        const weeklyAd=(cd.company_detailed.advertising_budget||0)*7;
                        let wages=0; for(const[,e] of Object.entries(cd.company_employees||{})) wages+=e.wage||0;
                        if (companyEscrowPreferences.weeklyAdBudget)  balance-=weeklyAd;
                        if (companyEscrowPreferences.weeklyWageBudget) balance-=wages*7;
                    }
                } catch(_){}
            }

            const sd = await fetchAPI(`https://api.torn.com/v2/user/stocks?key=${apiKey}`);
            const { prices, history, tornData } = await fetchAndRecordPrices();

            // Refresh costs
            INVESTMENT_TABLE = INVESTMENT_TABLE.map(inv => {
                const id = Object.keys(STOCK_MAP).find(k => STOCK_MAP[k] === inv.acronym);
                const ts  = tornData.stocks?.find(s => s.id == id);
                const price = ts?.market?.price || inv.current_price || 0;
                return {...inv, cost: inv.shares_to_buy * price, current_price: price};
            });

            const userStocks = {}; let stockTotal = 0;
            for (const si of (sd.stocks||[])) {
                const acronym=STOCK_MAP[si.id]; if (!acronym) continue;
                const ts=tornData.stocks?.find(s=>s.id===si.id);
                const price=ts?.market?.price||0; const base=ts?.bonus?.requirement||0;
                if (si.bonus?.increment>0) {
                    let actual=0;
                    for(let i=1;i<=4;i++){const need=i===1?base:(base*Math.pow(2,i))-base;if(si.shares>=need) actual=i; else break;}
                    userStocks[acronym]=actual;
                    if (settings.extraStockShares) {
                        const needed=actual===1?base:(base*Math.pow(2,actual))-base;
                        const extra=si.shares-needed;
                        if (extra>0 && extraStockPreferences[acronym]!==false) stockTotal+=extra*price;
                    }
                } else {
                    userStocks[acronym]=0;
                    if (settings.extraStockShares && extraStockPreferences[acronym]!==false) stockTotal+=si.shares*price;
                }
            }
            if (settings.extraStockShares) balance+=stockTotal;

            let next=null;
            for (const inv of INVESTMENT_TABLE) {
                const k=getInvestmentKey(inv.acronym,inv.increment);
                if (investmentPreferences[k]===false) continue;
                if ((userStocks[inv.acronym]||0)<inv.increment){next=inv;break;}
            }

            if (!next){showNotification('🎉 All recommended investments complete!','success');return;}

            const canAfford = balance >= next.cost;
            const shortfall = canAfford ? 0 : next.cost - balance;
            const stockId   = Object.keys(STOCK_MAP).find(k => STOCK_MAP[k] === next.acronym);
            const pct24 = getPctChange(history, next.acronym, 24);
            const p24 = perf(pct24);

            showNotification(`
                <div style="font-weight:bold;font-size:16px;margin-bottom:10px;">📈 Next Investment</div>
                <div style="text-align:center;margin:10px 0;">
                    <img src="${STOCK_IMAGES[next.acronym]}" style="width:70px;height:70px;border-radius:10px;background:rgba(255,255,255,.1);padding:8px;">
                </div>
                <div style="margin-bottom:6px;"><strong>${next.acronym}</strong> – Increment ${next.increment}
                    ${pct24!==null?`<span style="margin-left:8px;padding:1px 7px;border-radius:10px;font-size:11px;background:${p24.bg};border:1px solid ${p24.border};color:${p24.textColor};">${trendArrow(pct24)} ${p24.label}</span>`:''}
                </div>
                <div style="margin-bottom:4px;font-size:13px;"><strong>Benefit:</strong> ${next.description}</div>
                <div style="margin-bottom:4px;font-size:13px;"><strong>Shares:</strong> ${next.shares_to_buy.toLocaleString()}</div>
                <div style="margin-bottom:4px;font-size:13px;"><strong>Cost:</strong> ${formatMoney(next.cost)}</div>
                <div style="margin-bottom:8px;font-size:13px;"><strong>Balance:</strong> ${formatMoney(balance)}</div>
                <div style="padding-top:10px;border-top:1px solid rgba(255,255,255,.2);">
                    ${canAfford
                        ? `✅ <strong>You can invest now!</strong><br><a href="https://www.torn.com/page.php?sid=stocks&stockID=${stockId}&tab=owned" style="color:white;text-decoration:underline;">Take me there →</a>`
                        : `❌ Need ${formatMoney(shortfall)} more.`}
                </div>`, canAfford ? 'success' : 'info');

            // Inject badges after every calculation
            injectPageBadges(prices, history);

        } catch(e) { showNotification(`Error: ${e.message}`,'error'); clearApiKey(); }
    }

