    // ─── Mini sparkline from history ──────────────────────────────────────────
    function sparklineHTML(history, acronym) {
        const data = history[acronym];
        if (!data || data.length < 3) return '';
        // Take last 14 points
        const points = data.slice(-14).map(d => d.p);
        const min = Math.min(...points);
        const max = Math.max(...points);
        const range = max - min || 1;
        const bars = points.map(p => {
            const h = Math.max(3, Math.round(((p - min) / range) * 20));
            const pct = ((p - min) / range) * 100;
            const col = pct > 60 ? '#4caf50' : pct > 35 ? '#ffc107' : '#f44336';
            return `<div class="sadv-bar" style="height:${h}px;background:${col};"></div>`;
        }).join('');
        return `<div class="sadv-bars">${bars}</div>`;
    }

    // ─── Short-Term Analysis ──────────────────────────────────────────────────
    async function showShortTermAnalysis() {
        ensureStyle();
        if (!apiKey) {
            const k = prompt('Enter your Torn API key:');
            if (!k) return;
            saveApiKey(k);
        }

        const auth = await checkAuthorization(apiKey);
        if (!auth.authorized) { showNotification(auth.error, 'error'); return; }

        showNotification('Fetching live market data…', 'info');

        let prices, history, tornData;
        try {
            ({ prices, history, tornData } = await fetchAndRecordPrices());
        } catch(e) { showNotification('Failed to fetch market data: ' + e.message, 'error'); return; }

        // Build performance table for all stocks
        const allStocks = (tornData.stocks || []).map(s => {
            const acronym = STOCK_MAP[s.id];
            if (!acronym) return null;
            const pct24  = getPctChange(history, acronym, 24);
            const pct7d  = getPctChange(history, acronym, 168);
            const ageH   = historyAgeHours(history, acronym);
            return { acronym, price: s.market?.price || 0, pct24, pct7d, ageH, stockData: s };
        }).filter(Boolean);

        // Short-term ranking: sort by 24h performance (stocks we actually have history for first)
        const withData    = allStocks.filter(s => s.pct24 !== null).sort((a,b) => b.pct24 - a.pct24);
        const withoutData = allStocks.filter(s => s.pct24 === null);
        const sorted = [...withData, ...withoutData];

        const top3 = withData.filter(s => s.pct24 > 0).slice(0, 3);
        const hasEnoughHistory = allStocks.filter(s => s.ageH >= 24).length >= 5;

        const content = document.createElement('div');

        // Header
        const hdr = document.createElement('div');
        hdr.style.cssText = 'display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;';
