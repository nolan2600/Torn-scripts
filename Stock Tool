    // ─── Price History System ─────────────────────────────────────────────────
    function loadPriceHistory() {
        try { return JSON.parse(localStorage.getItem(PRICE_HISTORY_KEY) || '{}'); }
        catch { return {}; }
    }

    function recordPrices(stockPriceMap) {
        const history = loadPriceHistory();
        const now = Date.now();
        for (const [acronym, price] of Object.entries(stockPriceMap)) {
            if (!history[acronym]) history[acronym] = [];
            // Don't spam — only record if >30 min since last entry
            const last = history[acronym][history[acronym].length - 1];
            if (!last || now - last.t > 30 * 60 * 1000) {
                history[acronym].push({ t: now, p: price });
            }
            if (history[acronym].length > 200) history[acronym] = history[acronym].slice(-200);
        }
        localStorage.setItem(PRICE_HISTORY_KEY, JSON.stringify(history));
        return history;
    }

    // Returns % change over the given number of hours (or null if no data)
    function getPctChange(history, acronym, hoursBack) {
        const data = history[acronym];
        if (!data || data.length < 2) return null;
        const now = Date.now();
        const cutoff = now - hoursBack * 3600000;
        const past = data.filter(d => d.t <= cutoff);
        if (!past.length) return null;
        const oldPrice = past[past.length - 1].p;
        const curPrice = data[data.length - 1].p;
        if (!oldPrice) return null;
        return ((curPrice - oldPrice) / oldPrice) * 100;
    }

    // Returns how many hours of history we have for a stock
    function historyAgeHours(history, acronym) {
        const data = history[acronym];
        if (!data || data.length < 2) return 0;
        return (Date.now() - data[0].t) / 3600000;
    }

    // Performance tier → color scheme
    function perf(pct) {
        if (pct === null)  return { bg:'#444',    border:'#666',    badge:'⚪', label:'No data', textColor:'#aaa' };
        if (pct >= 5)      return { bg:'#0a3d0a', border:'#00e676', badge:'🟢', label:`+${pct.toFixed(2)}%`, textColor:'#00e676' };
        if (pct >= 1)      return { bg:'#1b3a1b', border:'#4caf50', badge:'🟢', label:`+${pct.toFixed(2)}%`, textColor:'#4caf50' };
        if (pct >= -1)     return { bg:'#3a3200', border:'#ffc107', badge:'🟡', label:`${pct.toFixed(2)}%`,  textColor:'#ffc107' };
        if (pct >= -5)     return { bg:'#3a1500', border:'#ff5722', badge:'🔴', label:`${pct.toFixed(2)}%`,  textColor:'#ff5722' };
        return             { bg:'#3a0a0a', border:'#f44336', badge:'🔴', label:`${pct.toFixed(2)}%`,  textColor:'#f44336' };
    }

    function trendArrow(pct) {
        if (pct === null) return '–';
        if (pct >= 2)  return '↑↑';
        if (pct >= 0.5) return '↑';
        if (pct >= -0.5) return '→';
        if (pct >= -2) return '↓';
        return '↓↓';
    }

    // ─── Investment Table ─────────────────────────────────────────────────────
    async function buildInvestmentTable(key) {
        const cached = sessionStorage.getItem(INVESTMENT_TABLE_KEY);
        if (cached) { INVESTMENT_TABLE = JSON.parse(cached); return INVESTMENT_TABLE; }

        const tornData = await fetchAPI(`https://api.torn.com/v2/torn/stocks?key=${key}`);
        const lookup = {};
        for (const s of (tornData.stocks || [])) {
            const a = STOCK_MAP[s.id];
            if (a) lookup[a] = s;
        }

        const table = [];
        for (const key of ORIGINAL_ORDER) {
            const [acronym, incStr] = key.split('-');
            const increment = parseInt(incStr);
            const stock = lookup[acronym];
            if (!stock) continue;
            const baseReq = stock.bonus?.requirement || 0;
            const currentPrice = stock.market?.price || 0;
            if (!baseReq || !currentPrice) continue;
            const sharesToBuy = baseReq * Math.pow(2, increment - 1);
            table.push({
                acronym, increment,
                shares_to_buy: sharesToBuy,
                cost: sharesToBuy * currentPrice,
                current_price: currentPrice,
                description: stock.bonus?.description || '',
                monthlyMult: (stock.bonus?.frequency || 7) <= 7 ? 4 : 1
            });
        }

        sessionStorage.setItem(INVESTMENT_TABLE_KEY, JSON.stringify(table));
        INVESTMENT_TABLE = table;
        return table;
    }

    // ─── Auth ─────────────────────────────────────────────────────────────────
    async function checkAuthorization(key) {
        try {
            const data = await fetchAPI(`https://api.torn.com/v2/user?selections=&key=${key}`);
            if (data.error) return { authorized:false, error:`Invalid API key: ${data.error.error}` };
            await buildInvestmentTable(key);
            return { authorized:true };
        } catch(e) {
            return { authorized:false, error:'Failed to reach Torn API: ' + e.message };
        }
    }

    // ─── Fetch all stock prices + record history ───────────────────────────────
    async function fetchAndRecordPrices() {
        const tornData = await fetchAPI(`https://api.torn.com/v2/torn/stocks?key=${apiKey}`);
        const prices = {};
        for (const s of (tornData.stocks || [])) {
            const a = STOCK_MAP[s.id];
            if (a && s.market?.price) prices[a] = s.market.price;
        }
        const history = recordPrices(prices);
        return { prices, history, tornData };
    }

    // ─── DOM injection: color badges on Torn's stock page ────────────────────
    function injectPageBadges(prices, history) {
        // We look for elements containing just the ticker acronym text.
        // Torn's stock page often has spans/divs with the ticker symbol.
        // We inject a small colored pill after each match we find.
        const allText = document.querySelectorAll('span, div, td, th, li, a, button, h3, h4');
        const inserted = new Set();

        allText.forEach(el => {
            const txt = el.textContent.trim();
            const acronym = Object.values(STOCK_MAP).find(a => txt === a);
            if (!acronym || inserted.has(el)) return;
            if (el.querySelector('.sadv-badge')) return; // already injected
            if (el.children.length > 0 && !Array.from(el.children).every(c => c.childElementCount === 0)) return; // skip complex nodes

            const pct24 = getPctChange(history, acronym, 24);
            const { border, label, textColor } = perf(pct24);
            const badge = document.createElement('span');
            badge.className = 'sadv-badge';
            badge.textContent = pct24 !== null ? label : '';
            badge.title = `${acronym} 24h performance`;
            badge.style.cssText = `
                display:inline-block;margin-left:5px;padding:1px 5px;
                border-radius:4px;font-size:10px;font-weight:bold;
                border:1px solid ${border};color:${textColor};
                background:rgba(0,0,0,0.3);vertical-align:middle;
                font-family:monospace;
            `;
            el.appendChild(badge);
            inserted.add(el);
        });
    }

