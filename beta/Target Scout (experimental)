/* eslint-disable no-undef */

(function () {
    "use strict";

    const PDA_API_KEY   = "###PDA-APIKEY###";
    const PDA_PLACEHOLDER = "###" + "PDA-APIKEY" + "###";
    const VERSION = "1.0.0";
    const LS = { apiKey:"ts_apiKey", ffKey:"ts_ffKey", settings:"ts_settings" };

    const NPP_DAYS = 14;
    function isAttackableByAge(targetAge, myAge) {
        if (targetAge == null) return true;
        const meUnderNPP = (myAge != null) && (myAge < NPP_DAYS);
        if (meUnderNPP) return targetAge >= 1;
        return targetAge >= NPP_DAYS;
    }

    const API_BASE = "https://api.torn.com/v2";
    const FF_BASE  = "https://ffscouter.com/api/v1";
    const API_DELAY_MS = 750;
    const PROFILE_URL  = "https://www.torn.com/profiles.php?XID=";
    const STATUS_CONCURRENCY  = 1;
    const FACTION_CACHE_MS = 5 * 60 * 1000;
    const PROFILE_CACHE_MS = 60 * 1000;

    const DEFAULT_SETTINGS = {
        minLevel: 1, maxLevel: 100,
        minAge: 0,   maxAge: 9999,
        minFF: 1.0,  maxFF: 3.0,
        includeUnknownFF: false,
        status: "any",
        hospitalMaxMin: 30,
        excludeWar: true,
        excludeNPP: true,
        skipActiveHours: 0,
        maxResults: 50,
    };

    const IS_PDA      = typeof PDA_httpGet === "function";
    const HAS_PDA_KEY = PDA_API_KEY !== PDA_PLACEHOLDER && /^[A-Za-z0-9]{16}$/.test(PDA_API_KEY);
    const GM_XHR      = (typeof GM_xmlhttpRequest !== "undefined") ? GM_xmlhttpRequest : null;

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
    function escHtml(s) { return String(s == null ? "" : s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
    function parseBS(human) { if (!human) return null; const m = String(human).match(/^\s*([\d.]+)\s*([kKmMbB]?)\s*$/); if (!m) return null; const n = parseFloat(m[1]); if (!Number.isFinite(n)) return null; const s=(m[2]||"").toLowerCase(),mult=s==="k"?1e3:s==="m"?1e6:s==="b"?1e9:1; return n*mult; }
    function openTornUrl(url) { const a=document.createElement("a");a.href=url;a.target="_blank";a.rel="noopener noreferrer";document.body.appendChild(a);a.click();a.remove(); }

    const fmt = {
        hospLabel(untilSec) { const rem=Math.max(0,untilSec-Math.floor(Date.now()/1000));if(rem<=0)return"🏥 out";const h=Math.floor(rem/3600),m=Math.floor((rem%3600)/60),s=rem%60;if(h>0)return`🏥 ${h}h ${m}m`;return m===0?`🏥 ${s}s`:`🏥 ${m}m ${s}s`; },
        lastActive(ts) { if(!ts)return"?";const ago=Math.floor((Date.now()/1000-ts)/3600);if(ago<1)return"<1h";if(ago<24)return ago+"h ago";return Math.floor(ago/24)+"d ago"; },
    };

    function loadSettings() { try{const raw=localStorage.getItem(LS.settings);return{...DEFAULT_SETTINGS,...(raw?JSON.parse(raw):{})};} catch{return{...DEFAULT_SETTINGS};} }
    function saveSettings(s) { localStorage.setItem(LS.settings,JSON.stringify(s)); }

    // ── HTTP ───────────────────────────────────────────────────
    function _gmGet(url) {
        return new Promise((resolve,reject)=>{GM_XHR({method:"GET",url,onload:(r)=>resolve({status:r.status,text:r.responseText}),onerror:()=>reject(new Error("network_error")),ontimeout:()=>reject(new Error("timeout"))});});
    }
    async function _httpGetOnceRaw(url) {
        if(IS_PDA){const res=await PDA_httpGet(url);if(res.status<200||res.status>=300){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;}return JSON.parse(res.responseText);}
        if(GM_XHR){const res=await _gmGet(url);if(res.status<200||res.status>=300){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;}return JSON.parse(res.text);}
        const res=await fetch(url);if(!res.ok){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;}return res.json();
    }
    async function _httpGetOnce(url) { return _httpGetOnceRaw(url); }
    async function httpGetJson(url) {
        try{return await _httpGetOnce(url);}
        catch(err){if(err.status>=400&&err.status<500)throw err;await sleep(400);return _httpGetOnce(url);}
    }
    function isRateLimitError(err) { if(!err)return false;if(err.status===429)return true;if(err.tornCode===5)return true;return false; }

    // ── Torn API ───────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key=key; this._lastReq=0; }
        setKey(key) { this.key=key; }
        async _rateLimit() { const w=API_DELAY_MS-(Date.now()-this._lastReq);this._lastReq=Date.now()+Math.max(0,w);if(w>0)await sleep(w); }
        async _get(pathOrUrl,params=null) {
            await this._rateLimit();
            const url=new URL(/^https?:\/\//.test(pathOrUrl)?pathOrUrl:API_BASE+pathOrUrl);
            if(params)for(const[k,v]of Object.entries(params))url.searchParams.set(k,v);
            if(!url.searchParams.has("key"))url.searchParams.set("key",this.key);
            const data=await httpGetJson(url.toString());
            if(data&&data.error){const e=new Error(data.error.error||"Torn API error");e.tornCode=data.error.code;throw e;}
            return data;
        }
        async fetchUserProfile(id) { const data=await this._get(`/user/${id}/profile`);if(!data)return null;return data.profile||(data.id?data:null); }
        async validateKey() { const data=await this._get("/user/profile");return(data&&data.profile)||null; }
        async fetchRecentAttacks(limit=100) { return this._get("/user/attacks",{limit,sort:"DESC"}); }
        async fetchFactionMembers(factionId) { return this._get(`/faction/${factionId}`,{selections:"members"}); }
    }

    // ── FFScouter ──────────────────────────────────────────────
    async function validateFFScouterKey(key) {
        if(!/^[A-Za-z0-9]{16}$/.test(key))return{ok:false,message:"Must be 16 alphanumeric characters."};
        try{const data=await httpGetJson(`${FF_BASE}/check-key?key=${encodeURIComponent(key)}`);if(data&&data.code)return{ok:false,message:data.error||`FFScouter code ${data.code}`};if(!data||!data.is_registered)return{ok:false,message:"Key not registered — sign up at ffscouter.com first."};return{ok:true,message:data.is_premium?"Valid — premium.":"Valid."};}
        catch(e){return{ok:false,message:e?.message||"Could not reach FFScouter."};}
    }
    async function fetchFFScouterStats(key,userIds) {
        const result={map:new Map(),error:null,nullCount:0,totalReturned:0,networkFail:false};
        if(!key){result.error="no_key";return result;}
        if(userIds.length===0)return result;
        for(let i=0;i<userIds.length;i+=200){
            const chunk=userIds.slice(i,i+200),url=`${FF_BASE}/get-stats?key=${encodeURIComponent(key)}&targets=${chunk.join(",")}`;
            try{
                const data=await httpGetJson(url);
                if(!Array.isArray(data)){result.error=(data&&data.error)?data.error:"unexpected_response";continue;}
                result.totalReturned+=data.length;
                for(const p of data){if(p.fair_fight==null){result.nullCount++;continue;}result.map.set(Number(p.player_id),{ff:Number(p.fair_fight),bs:p.bs_estimate_human||null});}
            }catch(e){
                if(isRateLimitError(e))throw e;
                if(!result.error){result.error=e.message||"network_error";if(String(e.message).match(/fetch|network|Failed/i))result.networkFail=true;}
            }
        }
        return result;
    }

    // ── Key Resolver ───────────────────────────────────────────
    const KeyResolver = {
        resolveTornKey(){if(HAS_PDA_KEY)return PDA_API_KEY;return localStorage.getItem(LS.apiKey)||null;},
        saveTornKey(k){localStorage.setItem(LS.apiKey,k);},
        clearTornKey(){localStorage.removeItem(LS.apiKey);},
        getFFKey(){return localStorage.getItem(LS.ffKey)||"";},
        saveFFKey(k){localStorage.setItem(LS.ffKey,k);},
        clearFFKey(){localStorage.removeItem(LS.ffKey);},
        isPDAKey(){return HAS_PDA_KEY;},
    };

    // ── Target Scout ───────────────────────────────────────────
    class TargetScout {
        constructor(api) { this.api=api; this.myUserId=null; this.myUserAge=null; this._statusCache=new Map(); this._warCache=null; }

        async _getMyProfile() {
            if(this.myUserId!=null)return;
            try{const p=await this.api.validateKey();if(p){this.myUserId=p.id||null;this.myUserAge=typeof p.age==="number"?p.age:null;}}catch{}
        }

        async getIdsFromAttackLog() {
            const data=await this.api.fetchRecentAttacks(100);
            const ids=new Set();
            const attacks=Array.isArray(data.attacks)?data.attacks:Object.values(data.attacks||{});
            for(const a of attacks){
                if(a.attacker_id&&Number(a.attacker_id)!==this.myUserId)ids.add(Number(a.attacker_id));
                if(a.defender_id&&Number(a.defender_id)!==this.myUserId)ids.add(Number(a.defender_id));
            }
            return[...ids];
        }

        async getIdsFromFaction(factionId) {
            const data=await this.api.fetchFactionMembers(factionId);
            const members=data.members||data.faction?.members||{};
            if(Array.isArray(members))return members.map((m)=>Number(m.id)).filter(Boolean);
            return Object.keys(members).map(Number).filter(Boolean);
        }

        async _fetchWarFactions() {
            const now=Date.now();
            if(this._warCache&&(now-this._warCache.fetchedAt)<FACTION_CACHE_MS)return this._warCache.ids;
            const ids=new Set();
            try{
                const data=await this.api._get("/torn?selections=rankedwars,territorywars");
                for(const war of Object.values(data.rankedwars||{}))for(const fid of Object.keys(war.factions||{})){const n=Number(fid);if(!isNaN(n)&&n>0)ids.add(n);}
                for(const war of Object.values(data.territorywars||{}))for(const key of["assaulting_faction","defending_faction"]){const fid=war[key];if(fid){const n=Number(fid);if(!isNaN(n)&&n>0)ids.add(n);}}
            }catch{}
            this._warCache={ids,fetchedAt:now};
            return ids;
        }

        async _fetchProfiles(ids,onProgress,signal) {
            const out=new Map(),now=Date.now(),stale=[];
            for(const id of ids){const c=this._statusCache.get(id);if(c&&(now-c.fetchedAt)<PROFILE_CACHE_MS){out.set(id,c.data);}else{stale.push(id);}}
            let i=0,done=ids.length-stale.length,rateLimitErr=null;
            if(onProgress)onProgress(done,ids.length,"Fetching profiles…");
            const worker=async()=>{
                while(i<stale.length&&!rateLimitErr){
                    if(signal?.aborted)return;
                    const id=stale[i++];
                    try{
                        const profile=await this.api.fetchUserProfile(id);
                        if(profile&&typeof profile==="object"){
                            const data={status:profile.status??null,age:typeof profile.age==="number"?profile.age:null,level:typeof profile.level==="number"?profile.level:null,faction_id:profile.faction?.id??profile.faction?.faction_id??profile.faction_id??null,revivable:typeof profile.revivable==="boolean"?profile.revivable:null,name:profile.name||profile.player_name||null,last_action_ts:profile.last_action?.timestamp??null};
                            if(data.status!==null&&typeof data.status!=="object")data.status=null;
                            out.set(id,data);this._statusCache.set(id,{data,fetchedAt:Date.now()});
                        }
                    }catch(err){if(isRateLimitError(err)){rateLimitErr=err;return;}}
                    done++;
                    if(onProgress)onProgress(done,ids.length,"Fetching profiles…");
                }
            };
            await Promise.all(Array.from({length:STATUS_CONCURRENCY},worker));
            if(rateLimitErr)throw rateLimitErr;
            return out;
        }

        async scan(sourceType,sourceArg,settings,onProgress,signal) {
            await this._getMyProfile();
            if(signal?.aborted)return[];

            if(onProgress)onProgress(0,1,"Fetching player list…");
            let ids=[];
            if(sourceType==="attacks"){ids=await this.getIdsFromAttackLog();}
            else if(sourceType==="faction"){ids=await this.getIdsFromFaction(sourceArg);}
            else{ids=sourceArg;}

            ids=[...new Set(ids.map(Number))].filter((id)=>!isNaN(id)&&id>0&&id!==this.myUserId);
            if(ids.length===0)return[];
            if(signal?.aborted)return[];

            const profiles=await this._fetchProfiles(ids,onProgress,signal);
            if(signal?.aborted)return[];

            if(onProgress)onProgress(ids.length,ids.length,"Fetching FF scores…");
            const ff=await fetchFFScouterStats(KeyResolver.getFFKey(),ids);
            if(signal?.aborted)return[];

            const warFactions=settings.excludeWar?await this._fetchWarFactions():new Set();
            if(signal?.aborted)return[];

            const nowSec=Math.floor(Date.now()/1000),results=[];
            for(const id of ids){
                const p=profiles.get(id);
                if(!p||!p.status||typeof p.status!=="object")continue;
                if(p.level!=null&&(p.level<settings.minLevel||p.level>settings.maxLevel))continue;
                if(p.age!=null&&(p.age<settings.minAge||p.age>settings.maxAge))continue;
                if(settings.excludeNPP&&!isAttackableByAge(p.age,this.myUserAge))continue;
                const ffData=ff.map.get(id);
                const ffVal=ffData?ffData.ff:null,bsVal=ffData?ffData.bs:null;
                if(!ff.networkFail){
                    if(ffVal==null&&!settings.includeUnknownFF)continue;
                    if(ffVal!=null&&(ffVal<settings.minFF||ffVal>settings.maxFF))continue;
                }
                const state=p.status.state,until=p.status.until||0,remaining=Math.max(0,until-nowSec),hospWindowSec=settings.hospitalMaxMin*60;
                if(settings.status==="okay"){if(state!=="Okay")continue;}
                else if(settings.status==="hospital"){if(state!=="Hospital")continue;if(remaining>hospWindowSec)continue;}
                else{if(state==="Hospital"&&remaining>hospWindowSec)continue;if(state!=="Okay"&&state!=="Hospital")continue;}
                if(settings.excludeWar&&p.faction_id&&warFactions.has(Number(p.faction_id)))continue;
                if(settings.skipActiveHours>0&&p.last_action_ts){if((nowSec-p.last_action_ts)/3600<settings.skipActiveHours)continue;}
                results.push({id,name:p.name||`Player ${id}`,level:p.level||0,age:p.age,ff:ffVal,bs:bsVal,statusState:state,hospUntil:until,revivable:p.revivable,inFactionWar:!!(p.faction_id&&warFactions.has(Number(p.faction_id))),lastActionTs:p.last_action_ts});
            }
            results.sort((a,b)=>{if(a.ff==null&&b.ff==null)return 0;if(a.ff==null)return 1;if(b.ff==null)return -1;return b.ff-a.ff;});
            return results.slice(0,settings.maxResults);
        }
    }

