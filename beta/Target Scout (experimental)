    // ── UI ─────────────────────────────────────────────────────
    class UI {
        constructor(scout) {
            this.scout=scout; this.activeTab="search"; this._panel=null; this._overlay=null; this._authed=false;
            this._scanning=false; this._scanAbort=null; this._results=[]; this._sortCol="ff"; this._sortDir="desc";
            this._lastScanError=null; this._countdownTimer=null;
        }

        inject() {
            injectCSS();
