        function injectEntryCSS(e) { if(!e.color)return;const id=`eug-color-${e.id}`,dark=e.colorDark||"#222",hover=e.hoverColor||e.color,css=`[data-eug-id="${e.id}"]{background:linear-gradient(to bottom,${e.color},${dark})!important}[data-eug-id="${e.id}"]:hover{background:linear-gradient(to bottom,${hover},${e.color})!important}`;const ex=document.getElementById(id);if(ex){ex.textContent=css;return;}const el=document.createElement("style");el.id=id;el.textContent=css;document.head.appendChild(el); }
        const findRef = () => document.getElementById("notes_panel_button") || document.getElementById("people_panel_button");
        const getRow = () => document.getElementById(ROW_ID);
        const closeRow = () => { const r=getRow(); if(r) r.classList.remove("eug-open"); };
        const openRow = btn => { const row=getRow(); if(!row)return; const rect=btn.getBoundingClientRect(); row.classList.add("eug-open"); const rr=row.getBoundingClientRect(); row.style.left=Math.max(4,Math.min(rect.left+rect.width/2-rr.width/2,window.innerWidth-rr.width-4))+"px"; row.style.bottom=(window.innerHeight-rect.top+6)+"px"; };
        function makeScriptBtn(entry, refBtn, role) { const ic=refBtn.querySelector("svg")?.className?.baseVal||"",btn=document.createElement("button");btn.type="button";btn.className=refBtn.className;btn.title=entry.name;btn.setAttribute("data-eug",role);btn.setAttribute("data-eug-id",entry.id);btn.innerHTML=(entry.iconSVG||"").replace(/<svg\b([^>]*)>/,(m,a)=>/\sclass\s*=/.test(a)?m:`<svg${a} class="${ic}">`);btn.addEventListener("click",(e)=>{e.preventDefault();e.stopPropagation();closeRow();try{entry.onClick();}catch{}});injectEntryCSS(entry);return btn; }
        function makeMenuBtn(refBtn) { const ic=refBtn.querySelector("svg")?.className?.baseVal||"",btn=document.createElement("button");btn.type="button";btn.className=refBtn.className;btn.title="My userscripts";btn.setAttribute("data-eug","menu");btn.innerHTML=`<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" class="${ic}"><defs><linearGradient id="eug_mg" x1=".5" x2=".5" y2="1" gradientUnits="objectBoundingBox"><stop offset="0" stop-color="#ddd"/><stop offset="1" stop-color="#999"/></linearGradient></defs><g fill="url(#eug_mg)"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></g></svg>`;btn.addEventListener("click",(e)=>{e.preventDefault();e.stopPropagation();const row=getRow();if(row&&row.classList.contains("eug-open"))closeRow();else openRow(btn);});return btn; }
