    class UI {
        constructor(hunter, toaster, alertMgr, markedAlertMgr) {
            this.hunter = hunter; this.toaster = toaster; this.alertMgr = alertMgr; this.markedAlertMgr = markedAlertMgr;
            this.tab = "hunt"; this._panel = null; this._overlay = null; this._authed = false;
            this._sortCol = "reward"; this._sortDir = "desc"; this._refreshing = false; this._tick = null;
        }
        inject() {
            injectCSS();
            const overlay = document.createElement("div"); overlay.id = "bh4-overlay"; document.body.appendChild(overlay);
            const panel = document.createElement("div"); panel.id = "bh4-panel";
            panel.innerHTML = `
                <div id="bh4-hdr">
                    <span><span class="bh4-brand">BH4</span><span class="bh4-ver">v${VERSION}</span></span>
                    <button id="bh4-close">&times;</button>
                </div>
                <div id="bh4-tabs">
                    <div class="bh4-tab active" data-tab="hunt">Hunt</div>
                    <div class="bh4-tab" data-tab="targets">Targets</div>
                    <div class="bh4-tab" data-tab="settings">Settings</div>
                </div>
                <div id="bh4-body"></div>`;
            document.body.appendChild(panel); this._panel = panel; this._overlay = overlay;
            overlay.addEventListener("click", () => this.toggle(false));
            panel.querySelector("#bh4-close").addEventListener("click", () => this.toggle(false));
            panel.querySelector("#bh4-tabs").addEventListener("click", e => {
                const t = e.target.closest(".bh4-tab"); if (!t) return;
                this.tab = t.dataset.tab; this._syncTabs(); this._render();
            });
            this.hunter.onUpdate = () => { if (this._open()) this._render(); };
            this.hunter.onToast = b => this.toaster.showMany(b);
            this._tick = setInterval(() => {
                if (this._open() && this.tab === "hunt") {
                    const el = document.getElementById("bh4-cd"); if (el) el.textContent = this.hunter.secondsUntilRefresh();
                }
                document.querySelectorAll("[data-hu]").forEach(el => {
                    const u = parseInt(el.dataset.hu); if (Number.isFinite(u)) el.textContent = fmtHosp(u);
                });
            }, 1000);
        }
        _open() { return this._panel?.classList.contains("open"); }
        toggle(open) {
            const isOpen = open != null ? open : !this._open();
            this._panel.classList.toggle("open", isOpen);
            this._overlay.classList.toggle("open", isOpen);
            if (isOpen) this._render();
        }
        _syncTabs() { for (const t of this._panel.querySelectorAll(".bh4-tab")) t.classList.toggle("active", t.dataset.tab === this.tab); }
        _render() { if (!this._authed) { this._renderAuth(); return; } if (this.tab === "hunt") this._renderHunt(); else if (this.tab === "targets") this._renderTargets(); else this._renderSettings(); }
        setAuthed(b) { this._authed = b; if (this._open()) this._render(); }

        _renderAuth() {
            const body = this._panel.querySelector("#bh4-body");
            const spa = !IS_PDA && !!localStorage.getItem("spa_apiKey");
            body.innerHTML = `<div id="bh4-auth">
                <h3>Torn API Key Required</h3>
                <p>Bounty Hunter fetches live bounty data from <code>api.torn.com</code>. A <b>Public</b> access key is sufficient.</p>
                <p class="bh4-hint">Get one at <a href="https://www.torn.com/preferences.php#tab=api" target="_blank" rel="noopener">Torn → Preferences → API</a>.</p>
                <div class="bh4-field" style="margin-top:14px"><label>Torn API Key (16 chars)</label><input id="bh4-ak" class="bh4-inp bh4-inp-mask" type="text" maxlength="16" spellcheck="false" autocomplete="off" placeholder="••••••••••••••••"></div>
                <div class="bh4-field"><label>FFScouter Key (optional)</label><input id="bh4-fk" class="bh4-inp bh4-inp-mask" type="text" maxlength="16" spellcheck="false" autocomplete="off" placeholder="For FF / BS filtering" value="${esc(Keys.getFF())}"></div>
                <div class="bh4-ra">
                    <button id="bh4-as" class="bh4-btn bh4-btn-p">Connect →</button>
                    ${spa ? `<button id="bh4-spa" class="bh4-btn">Use SPA Key</button>` : ""}
                </div>
                <p class="bh4-ss err" id="bh4-ae"></p>
            </div>`;
            const err = body.querySelector("#bh4-ae");
            const connect = async () => {
                err.textContent = "";
                const k = body.querySelector("#bh4-ak").value.trim();
                if (!/^[A-Za-z0-9]{16}$/.test(k)) { err.className="bh4-ss err"; err.textContent="Enter a valid 16-character key."; return; }
                await this._adopt(k, body.querySelector("#bh4-fk").value.trim(), err);
            };
            body.querySelector("#bh4-as").addEventListener("click", connect);
            body.querySelector("#bh4-ak").addEventListener("keydown", e => { if (e.key === "Enter") connect(); });
            body.querySelector("#bh4-spa")?.addEventListener("click", async () => {
                const k = localStorage.getItem("spa_apiKey");
                if (!k) { err.className="bh4-ss err"; err.textContent="SPA key not found."; return; }
                body.querySelector("#bh4-ak").value = k;
                await this._adopt(k, body.querySelector("#bh4-fk").value.trim(), err);
            });
        }
        async _adopt(tornKey, ffKey, errEl) {
            errEl.className="bh4-ss info"; errEl.textContent="Validating…";
            this.hunter.api.setKey(tornKey);
            try { await this.hunter.api.validateKey(); }
            catch(e) { errEl.className="bh4-ss err"; errEl.textContent="Key rejected: " + (e.message||"invalid"); return; }
            Keys.saveTorn(tornKey);
            if (ffKey && /^[A-Za-z0-9]{16}$/.test(ffKey)) Keys.saveFF(ffKey);
            this.setAuthed(true); this.hunter.start();
        }

        _renderHunt() {
            const body = this._panel.querySelector("#bh4-body");
            const rows = this._sort(this.hunter.lastMatches), c = this.hunter.lastCounts;
            const rl = this.hunter.lastError?.tornCode === 5;
            const next = this.hunter.secondsUntilRefresh();
            const errLine = this.hunter.lastError && !rl ? `<span class="err">${esc(this.hunter.lastError.message||"error")}</span>` : "";
            const ffWarn = c?.ffNetworkFail ? `<span style="color:#f97316">FFScouter unreachable</span>` : c?.ffError ? `<span class="err">FF: ${esc(c.ffError)}</span>` : "";
            const th = col => `${this._sortCol===col?(this._sortDir==="asc"?"sa":"sd"):""}`;

            body.innerHTML = `
                <div id="bh4-sl">
                    <button id="bh4-rbtn"${this._refreshing?" disabled":""}>Refresh</button>
                    <span>Next in <span id="bh4-cd">${next}</span>s</span>
                    <span>${rows.length} match${rows.length===1?"":"es"}</span>
                    ${errLine}${ffWarn}
                </div>
                ${rl ? `<div class="bh4-rl"><div class="bh4-rl-t">Rate limit hit</div><div class="bh4-rl-b">${rows.length?"Showing last results.":"No results yet."} Raise min reward or refresh interval to stay under the limit.</div></div>` : ""}
                ${rows.length === 0 && !rl
                    ? `<div class="bh4-empty">No bounties match your filters.<br><span style="color:#2e3a2e">Adjust reward, FF, BS, hospital window, or revivable filter in Settings.</span></div>`
                    : `<table class="bh4-t"><thead><tr>
                        <th data-sort="target" class="${th("target")}">Target</th>
                        <th data-sort="reward" class="num ${th("reward")}">Reward</th>
                        <th data-sort="ff" class="num ${th("ff")}">FF</th>
                        <th data-sort="bs" class="num div ${th("bs")}">BS Est.</th>
                        <th class="div ${th("status")}" data-sort="status">Status</th>
                        <th></th>
                    </tr></thead><tbody>${rows.map(r => this._row(r)).join("")}</tbody></table>`}`;

            body.querySelector("#bh4-rbtn").addEventListener("click", async () => {
                if (this._refreshing) return;
                this._refreshing = true; body.querySelector("#bh4-rbtn").disabled = true;
                try { await this.hunter.refresh(); } catch {}
                this._refreshing = false;
                if (this._open() && this.tab === "hunt") this._renderHunt();
            });
            body.querySelectorAll(".bh4-att").forEach(el => el.addEventListener("click", e => { e.preventDefault(); openUrl(PROFILE_URL + el.dataset.id); }));
            body.querySelectorAll("th[data-sort]").forEach(el => el.addEventListener("click", () => {
                const col = el.dataset.sort;
                if (this._sortCol === col) this._sortDir = this._sortDir === "asc" ? "desc" : "asc";
                else { this._sortCol = col; this._sortDir = col === "target" ? "asc" : "desc"; }
                this._renderHunt();
            }));
            body.querySelectorAll(".bh4-bell").forEach(btn => btn.addEventListener("click", e => {
                e.stopPropagation(); const id = btn.dataset.id;
                this.alertMgr.toggle(id); this.alertMgr.sync(this.hunter.lastMatches);
                const on = this.alertMgr.isActive(id); btn.classList.toggle("on", on);
                btn.title = on ? "Cancel alert" : "Alert 1 min before exit";
            }));
        }

        _sort(list) {
            const col = this._sortCol, dir = this._sortDir === "asc" ? 1 : -1;
            const key = m => {
                if (col === "target") return String(m.target_name||"").toLowerCase();
                if (col === "reward") return m.reward || 0;
                if (col === "ff") return m.ff == null ? Infinity : m.ff;
                if (col === "bs") { const n = parseBS(m.bs); return n == null ? Infinity : n; }
                if (col === "status") { const rem = m.statusState==="Hospital" ? Math.max(0,(m.hospUntil||0)-Math.floor(Date.now()/1000)) : 0; return (m.statusState==="Okay"?0:1)*1e6+rem; }
                return m.reward || 0;
            };
            return [...list].sort((a, b) => {
                const ka = key(a), kb = key(b);
                if (ka === Infinity && kb !== Infinity) return 1;
                if (kb === Infinity && ka !== Infinity) return -1;
                if (ka < kb) return -1 * dir; if (ka > kb) return 1 * dir;
                return (b.reward||0) - (a.reward||0);
            });
        }

        _row(b) {
            const isH = b.statusState === "Hospital";
            const status = isH ? `<span class="bh4-badge bh4-bh" data-hu="${b.hospUntil}">${fmtHosp(b.hospUntil)}</span>${this.alertMgr.isActive(b.target_id)?`<button class="bh4-bell on" data-id="${b.target_id}" title="Cancel alert">🔔</button>`:`<button class="bh4-bell" data-id="${b.target_id}" title="Alert 1 min before exit">🔔</button>`}`
                            : `<span class="bh4-badge bh4-bo">OKAY</span>`;
            return `<tr>
                <td><a class="bh4-nl" href="${PROFILE_URL}${b.target_id}" target="_blank" rel="noopener">${esc(b.target_name)}</a><span style="color:#3a4a3a;font-size:10px"> L${b.target_level}</span>${b.bountyCount>1?`<span class="bh4-cnt">×${b.bountyCount}</span>`:""} ${b.inWar?`<span class="bh4-bw">WAR</span>`:""}</td>
                <td class="num">${esc(fmtMoneyFull(b.reward))}</td>
                <td class="num">${b.ff != null ? b.ff.toFixed(2) : "—"}</td>
                <td class="num div">${esc(b.bs||"—")}</td>
                <td class="div">${status}</td>
                <td><button class="bh4-att" data-id="${b.target_id}">Attack →</button></td>
            </tr>`;
        }

        _renderTargets() {
            const body = this._panel.querySelector("#bh4-body");
            const targets = Marks.load(), statuses = this.hunter.lastMarkedStatuses;
            if (!targets.length) {
                body.innerHTML = `<div id="bh4-sl"><button id="bh4-tref" class="bh4-btn">Refresh</button><span>0 marked targets</span></div><div class="bh4-empty">No marked targets.<br><span style="color:#2e3a2e">Visit a player profile and click the Mark button to track them here.</span></div>`;
                body.querySelector("#bh4-tref").addEventListener("click", () => this.hunter.refreshMarked().catch(() => {}));
                return;
            }
            const rows = targets.map(t => {
                const s = statuses.get(t.id);
                let badge = `<span class="bh4-badge" style="color:#3a4a3a;background:#0d100d;border:1px solid #1e2a1e">Loading…</span>`;
                if (s?.state === "Okay")     badge = `<span class="bh4-badge bh4-bo">OKAY</span>`;
                if (s?.state === "Hospital") badge = `<span class="bh4-badge bh4-bh" data-hu="${s.until}">${fmtHosp(s.until)}</span>`;
                if (s?.state === "Abroad" || s?.state === "Traveling") badge = `<span class="bh4-badge bh4-bt">TRAVEL</span>`;
                if (s?.state === "Jail")     badge = `<span class="bh4-badge" style="color:#5a7a5a;background:#0d100d;border:1px solid #1e2a1e">JAILED</span>`;
                const bell = (s?.state === "Hospital") ? `<button class="bh4-bell bh4-tbell${this.markedAlertMgr.isActive(t.id)?" on":""}" data-tid="${t.id}" title="${this.markedAlertMgr.isActive(t.id)?"Cancel alert":"Alert before exit"}">🔔</button>` : "";
                const war = s?.inWar ? `<span class="bh4-bw">WAR</span>` : "";
                return `<tr>
                    <td><a class="bh4-nl" href="${PROFILE_URL}${t.id}" target="_blank" rel="noopener">${esc(t.name)}</a> <span style="color:#3a4a3a;font-size:10px">L${t.level}</span> ${war}</td>
                    <td>${badge}${bell}</td>
                    <td><button class="bh4-att" data-id="${t.id}">Attack →</button></td>
                    <td><button class="bh4-trm" data-id="${t.id}" data-name="${esc(t.name)}">✕</button></td>
                </tr>`;
            }).join("");
            body.innerHTML = `
                <div id="bh4-sl"><button id="bh4-tref" class="bh4-btn">Refresh</button><span>${targets.length} marked target${targets.length===1?"":"s"}</span></div>
                <table class="bh4-t"><thead><tr><th>Target</th><th>Status</th><th></th><th></th></tr></thead><tbody>${rows}</tbody></table>`;
            body.querySelector("#bh4-tref").addEventListener("click", () => this.hunter.refreshMarked().catch(() => {}));
            body.querySelectorAll(".bh4-att").forEach(el => el.addEventListener("click", e => { e.preventDefault(); openUrl(PROFILE_URL + el.dataset.id); }));
            body.querySelectorAll(".bh4-trm").forEach(btn => btn.addEventListener("click", () => {
                const id = Number(btn.dataset.id);
                if (!confirm(`Remove ${btn.dataset.name} from marked targets?`)) return;
                Marks.remove(id); this.markedAlertMgr.cancelAll(); this._renderTargets();
                this.hunter.refreshMarked().catch(() => {});
            }));
            body.querySelectorAll(".bh4-tbell").forEach(btn => btn.addEventListener("click", e => {
                e.stopPropagation(); const id = btn.dataset.tid;
                this.markedAlertMgr.toggle(id); this.markedAlertMgr.sync(Marks.load(), this.hunter.lastMarkedStatuses);
                const on = this.markedAlertMgr.isActive(id); btn.classList.toggle("on", on);
                btn.title = on ? "Cancel alert" : "Alert before exit";
            }));
        }

        _renderSettings() {
            const body = this._panel.querySelector("#bh4-body"), s = this.hunter.settings;
            const bsBoxes = BS_RANGES.map(r => `<label><input type="checkbox" id="${r.id}" value="${r.id}"${(s.bsRanges||[]).includes(r.id)?" checked":""}> ${esc(r.label)}</label>`).join("");
            const pdaNote = Keys.isPDA() ? `<p class="bh4-hint">Torn key is provided by Torn PDA.</p>` : "";
            body.innerHTML = `
<div class="bh4-section"><h3>Filters</h3>
  <div class="bh4-g2">
    <div class="bh4-field"><label>Min reward ($)</label><input id="bhs-price" class="bh4-inp" type="number" min="0" step="10000" value="${s.minPrice}"></div>
    <div class="bh4-field"><label>Hospital window (min)</label><input id="bhs-hosp" class="bh4-inp" type="number" min="0" max="60" value="${s.hospitalMaxMin}"><p class="bh4-hint">0 = Okay only</p></div>
    <div class="bh4-field"><label>FF min</label><input id="bhs-ffmin" class="bh4-inp" type="number" min="1" max="10" step="0.1" value="${s.minFF}"></div>
    <div class="bh4-field"><label>FF max</label><input id="bhs-ffmax" class="bh4-inp" type="number" min="1" max="10" step="0.1" value="${s.maxFF}"></div>
  </div>
  <label class="bh4-check"><input type="checkbox" id="bhs-unkff"${s.includeUnknownFF?" checked":""}> Include targets with unknown FF score</label>
</div>

<div class="bh4-section"><h3>Battle Stats Bracket</h3>
  <p class="bh4-hint">Leave all unchecked for any stats. Requires FFScouter key.</p>
  <div class="bh4-bsb">${bsBoxes}</div>
</div>

<div class="bh4-section"><h3>Additional Filters</h3>
  <label class="bh4-check"><input type="checkbox" id="bhs-rev"${s.revivableOnly?" checked":""}> Hospital targets: revivable only</label><br><br>
  <label class="bh4-check"><input type="checkbox" id="bhs-war"${s.hideWarTargets?" checked":""}> Hide targets in active faction wars</label>
  <p class="bh4-hint">War status is fetched once per 5 minutes. Targets show ⚔ WAR badge when their faction is in a ranked or territory war.</p>
</div>

<div class="bh4-section"><h3>Alerts</h3>
  <p class="bh4-hint">Full-screen banner + vibration + beep when hospital timer hits ~60 seconds. Tap 🔔 on any hospital row for per-target alerts.</p>
  <label class="bh4-check"><input type="checkbox" id="bhs-ha"${s.hospAlerts?" checked":""}> Auto-alert all hospital targets (1 min before exit)</label><br><br>
  <label class="bh4-check"><input type="checkbox" id="bhs-ma"${s.markedAlerts?" checked":""}> Auto-alert all marked targets</label><br><br>
  <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:8px">
    <span class="bh4-hint">Web notifications:</span>
    <span id="bhs-npb" class="bh4-npb">…</span>
    <button id="bhs-nreq" class="bh4-btn" style="font-size:10px;padding:3px 10px">Request</button>
  </div>
</div>

<div class="bh4-section"><h3>Refresh</h3>
  <div class="bh4-g2">
    <div class="bh4-field"><label>Auto-refresh interval</label>
      <select id="bhs-ref" class="bh4-sel">
        <option value="30"${s.refreshSec===30?" selected":""}>30 seconds</option>
        <option value="60"${s.refreshSec===60?" selected":""}>60 seconds</option>
        <option value="120"${s.refreshSec===120?" selected":""}>2 minutes</option>
        <option value="300"${s.refreshSec===300?" selected":""}>5 minutes</option>
        <option value="0"${s.refreshSec===0?" selected":""}>Off</option>
      </select></div>
    <div class="bh4-field"><label>Options</label>
      <label class="bh4-check"><input type="checkbox" id="bhs-toast"${s.toastsEnabled?" checked":""}> Toast new matches</label>
    </div>
  </div>
</div>

<div class="bh4-section"><h3>Torn API Key</h3>
  ${pdaNote}
  <div class="bh4-field"><input id="bhs-tk" class="bh4-inp bh4-inp-mask" type="text" maxlength="16" spellcheck="false" autocomplete="off" value="${esc(Keys.getTorn())}"${Keys.isPDA()?" disabled":""}></div>
  ${!Keys.isPDA() ? `<div class="bh4-ra"><button id="bhs-tksave" class="bh4-btn bh4-btn-p">Save Key</button><button id="bhs-tkclear" class="bh4-btn bh4-btn-d">Clear & Logout</button></div><div id="bhs-tkst" class="bh4-ss"></div>` : ""}
</div>

<div class="bh4-section"><h3>FFScouter Key</h3>
  <p class="bh4-hint">Enables FF score and BS bracket filtering. One batch request per refresh.</p>
  <div class="bh4-field"><input id="bhs-fk" class="bh4-inp bh4-inp-mask" type="text" maxlength="16" spellcheck="false" autocomplete="off" value="${esc(Keys.getFF())}"></div>
  <div class="bh4-ra"><button id="bhs-fksave" class="bh4-btn bh4-btn-p">Save</button><button id="bhs-fkclear" class="bh4-btn">Clear</button></div>
  <div id="bhs-fkst" class="bh4-ss"></div>
</div>

<div class="bh4-section"><h3>Reset</h3>
  <button id="bhs-reset" class="bh4-btn">Reset all filters to defaults</button>
  <p class="bh4-hint">v${VERSION} · ${IS_PDA?"Torn PDA":"Desktop"}</p>
</div>`;

            const $ = id => body.querySelector("#" + id);
            const st = (elId, cls, msg) => { const el=$(elId); if(!el) return; el.className="bh4-ss "+cls; el.textContent=msg; };

            const persist = () => {
                const fmin = parseFloat($("bhs-ffmin").value), fmax = parseFloat($("bhs-ffmax").value);
                const cmin = Number.isFinite(fmin) ? Math.max(1,fmin) : 1;
                const cmax = Number.isFinite(fmax) ? Math.max(cmin,fmax) : cmin;
                const selBS = BS_RANGES.filter(r => { const el=document.getElementById(r.id); return el&&el.checked; }).map(r => r.id);
                this.hunter.updateSettings({
                    minPrice:Math.max(0,parseInt($("bhs-price").value)||0),
                    hospitalMaxMin:Math.max(0,Math.min(60,parseInt($("bhs-hosp").value)||0)),
                    minFF:cmin, maxFF:cmax,
                    refreshSec:parseInt($("bhs-ref").value)||60,
                    toastsEnabled:$("bhs-toast").checked,
                    includeUnknownFF:$("bhs-unkff").checked,
                    revivableOnly:$("bhs-rev").checked,
                    bsRanges:selBS,
                    hospAlerts:$("bhs-ha")?.checked ?? false,
                    hideWarTargets:$("bhs-war")?.checked ?? false,
                    markedAlerts:$("bhs-ma")?.checked ?? false,
                });
                this.alertMgr.enabled = this.hunter.settings.hospAlerts; this.alertMgr.sync(this.hunter.lastMatches);
                this.markedAlertMgr.enabled = this.hunter.settings.markedAlerts; this.markedAlertMgr.sync(Marks.load(), this.hunter.lastMarkedStatuses);
                if (this.hunter.settings.refreshSec > 0) { this.hunter.stop(); this.hunter.start(); } else this.hunter.stop();
            };
            ["bhs-price","bhs-hosp","bhs-ffmin","bhs-ffmax","bhs-ref","bhs-toast","bhs-unkff","bhs-rev","bhs-ha","bhs-war","bhs-ma"].forEach(id => $(id)?.addEventListener("change", persist));
            BS_RANGES.forEach(r => { const el=document.getElementById(r.id); if(el) el.addEventListener("change", persist); });

            const upNPB = () => {
                const badge=$("bhs-npb"), req=$("bhs-nreq"); if(!badge) return;
                if (typeof Notification === "undefined") { badge.className="bh4-npb bh4-nu"; badge.textContent="Not supported"; if(req) req.style.display="none"; return; }
                const p = Notification.permission;
                if (p === "granted")   { badge.className="bh4-npb bh4-ng"; badge.textContent="Granted ✓"; if(req) req.style.display="none"; }
                else if (p === "denied") { badge.className="bh4-npb bh4-nd"; badge.textContent="Denied"; if(req) req.style.display="none"; }
                else { badge.className="bh4-npb bh4-nn"; badge.textContent="Not asked"; }
            };
            upNPB();
            $("bhs-nreq")?.addEventListener("click", async () => { $("bhs-nreq").disabled=true; if(typeof Notification!=="undefined") await Notification.requestPermission(); upNPB(); $("bhs-nreq").disabled=false; });

            if (!Keys.isPDA()) {
                $("bhs-tksave")?.addEventListener("click", async () => {
                    const k=$("bhs-tk").value.trim();
                    if(!/^[A-Za-z0-9]{16}$/.test(k)){st("bhs-tkst","err","Must be 16 alphanumeric characters.");return;}
                    st("bhs-tkst","info","Validating…"); this.hunter.api.setKey(k);
                    try { await this.hunter.api.validateKey(); } catch(e) { st("bhs-tkst","err","Rejected: "+(e.message||"invalid")); return; }
                    Keys.saveTorn(k); st("bhs-tkst","ok","Saved ✓"); this.hunter.refresh().catch(()=>{});
                });
                $("bhs-tkclear")?.addEventListener("click", () => {
                    if(!confirm("Clear Torn API key and return to login?")) return;
                    Keys.clearTorn(); this.hunter.stop(); this.toaster.clearAll(); this.setAuthed(false);
                });
            }
            $("bhs-fksave").addEventListener("click", async () => {
                const k=$("bhs-fk").value.trim();
                if(!k){Keys.clearFF();st("bhs-fkst","info","Cleared.");this.hunter.refresh().catch(()=>{});return;}
                st("bhs-fkst","info","Validating…"); const r=await validateFFKey(k);
                if(!r.ok){st("bhs-fkst","err",r.msg);return;}
                Keys.saveFF(k); st("bhs-fkst","ok",r.msg+" — refreshing…"); this.hunter.refresh().catch(()=>{}); st("bhs-fkst","ok",r.msg+" ✓");
            });
            $("bhs-fkclear").addEventListener("click", () => { Keys.clearFF(); $("bhs-fk").value=""; st("bhs-fkst","info","Cleared."); this.hunter.refresh().catch(()=>{}); });
            $("bhs-reset").addEventListener("click", () => { if(!confirm("Reset filters?")) return; this.hunter.updateSettings({...DEFAULTS}); this._render(); });
        }
    }

    // ── Eugene footer menu ────────────────────────────────────────────────────
