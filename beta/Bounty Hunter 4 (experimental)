    // ── Filter bar ──────────────────────────────────────────────────────────────
    function injectFilterBar() {
        if (document.getElementById("bh4-bar")) return;

        const hasFF  = !!Keys.getFF();
        const hasTorn = Keys.getTorn() && Keys.getTorn() !== PDA_PH || IS_PDA;

        const bar = document.createElement("div");
        bar.id = "bh4-bar";
        bar.innerHTML = `
            <span class="bh4-brand">BH4</span>
            <span class="bh4-sep"></span>

            <div class="bh4-group">
                <span class="bh4-lbl">Window</span>
                <input type="number" id="bh4-window" class="w-win" min="0" max="120" step="1"
                       title="Hospital exit window (minutes). Set 0 to show Okay targets only.">
                <span class="bh4-lbl">m</span>
            </div>

            <div class="bh4-group">
                <span class="bh4-lbl">Status</span>
                <select id="bh4-status" title="Restrict by target status">
                    <option value="all">All</option>
                    <option value="okay">Okay</option>
                    <option value="hospital">Hospital</option>
                </select>
            </div>

            <div class="bh4-group">
                <span class="bh4-lbl">Min $</span>
                <input type="number" id="bh4-reward" class="w-re" min="0" step="50000"
                       title="Minimum bounty reward">
            </div>

            <div class="bh4-group">
                <span class="bh4-lbl">Lvl ≤</span>
                <input type="number" id="bh4-level" class="w-lvl" min="1" max="100" step="1"
                       title="Maximum target level">
            </div>

            <div class="bh4-group" id="bh4-ff-group" style="${hasFF ? "" : "display:none"}">
                <span class="bh4-lbl">FF</span>
                <input type="number" id="bh4-ffmin" class="w-ff" min="1" max="10" step="0.1" title="Min FF score">
                <span class="bh4-lbl">–</span>
                <input type="number" id="bh4-ffmax" class="w-ff" min="1" max="10" step="0.1" title="Max FF score">
            </div>

            <div class="bh4-actions">
                <button id="bh4-enrich-btn" style="${hasFF ? "" : "display:none"}"
                        title="Fetch FF scores for all listed targets">FF+</button>
                <button id="bh4-war-btn" class="${settings.hideWar ? "bh4-on" : ""}"
                        style="${hasTorn ? "" : "display:none"}"
                        title="Toggle faction war filter">WAR</button>
                <button id="bh4-settings-btn" title="Settings">⚙</button>
                <div class="bh4-count" id="bh4-stats">—</div>
            </div>
        `;

        const anchor = document.querySelector(".bounties-wrap .bounties-total, .bounties-wrap, .content-wrapper");
        if (anchor) anchor.parentNode.insertBefore(bar, anchor);
        else document.querySelector(".content-wrapper")?.prepend(bar);

        statsEl = bar.querySelector("#bh4-stats");

        // Sync saved values
        bar.querySelector("#bh4-window").value = settings.hospitalMaxMin;
        bar.querySelector("#bh4-status").value = settings.statusFilter;
        bar.querySelector("#bh4-reward").value = settings.minReward;
        bar.querySelector("#bh4-level").value  = settings.maxLevel;
        bar.querySelector("#bh4-ffmin").value  = settings.minFF;
        bar.querySelector("#bh4-ffmax").value  = settings.maxFF;

        const persist = () => {
            const ffn = parseFloat(bar.querySelector("#bh4-ffmin").value) || 1.0;
            const ffx = Math.max(ffn, parseFloat(bar.querySelector("#bh4-ffmax").value) || 3.0);
            settings = {
                ...settings,
                hospitalMaxMin : Math.max(0, parseInt(bar.querySelector("#bh4-window").value) || 0),
                statusFilter   : bar.querySelector("#bh4-status").value,
                minReward      : Math.max(0, parseInt(bar.querySelector("#bh4-reward").value) || 0),
                maxLevel       : Math.min(100, Math.max(1, parseInt(bar.querySelector("#bh4-level").value) || 100)),
                minFF          : ffn,
                maxFF          : ffx,
            };
            saveSettings(settings);
            scheduleFilter();
        };

        for (const sel of ["#bh4-window","#bh4-status","#bh4-reward","#bh4-level","#bh4-ffmin","#bh4-ffmax"]) {
            const el = bar.querySelector(sel);
            el?.addEventListener("input",  persist);
            el?.addEventListener("change", persist);
        }

        bar.querySelector("#bh4-enrich-btn")?.addEventListener("click", async () => {
            const btn = bar.querySelector("#bh4-enrich-btn");
            btn.textContent = "…"; btn.disabled = true;
            try { await runEnrichment(); } finally { btn.textContent = "FF+"; btn.disabled = false; }
        });

        bar.querySelector("#bh4-war-btn")?.addEventListener("click", () => {
            const btn = bar.querySelector("#bh4-war-btn");
            settings.hideWar = !settings.hideWar;
            btn.classList.toggle("bh4-on", settings.hideWar);
            saveSettings(settings);
            if (settings.hideWar) fetchWar().then(() => applyFilters()); else applyFilters();
        });

        bar.querySelector("#bh4-settings-btn").addEventListener("click", openSettings);
    }

    // ── Settings modal ──────────────────────────────────────────────────────────
    function esc(s) {
        return String(s ?? "")
            .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    function openSettings() {
        if (document.getElementById("bh4-overlay")) return;

        const overlay = document.createElement("div");
        overlay.id = "bh4-overlay";
        overlay.innerHTML = `
            <div id="bh4-modal">
                <button class="bh4-close" title="Close">✕</button>
                <h3>Bounty Hunter 4 — Settings</h3>

                <div class="bh4-section">
                    <label class="bh4-field-label">FFScouter API key</label>
                    <input type="text" id="bh4-ff-input" maxlength="64" spellcheck="false"
                           autocomplete="off" placeholder="16-character key"
                           value="${esc(Keys.getFF())}">
                    <div class="bh4-hint">Enables FF score display and filtering. One batch request per FF+ click.</div>
                    <div class="bh4-btn-row">
                        <button id="bh4-ff-save" class="bh4-btn-save">Save</button>
                        <button id="bh4-ff-clear" class="bh4-btn-clear">Clear</button>
                    </div>
                    <div id="bh4-ff-st" class="bh4-status"></div>
                </div>

                ${IS_PDA ? `<div class="bh4-hint" style="margin-bottom:14px">Torn key provided by Torn PDA.</div>` : `
                <div class="bh4-section">
                    <label class="bh4-field-label">
                        Torn API key
                        <span style="color:#2a2d24;text-transform:none;letter-spacing:0"> — optional, faction war detection</span>
                    </label>
                    <input type="text" id="bh4-torn-input" maxlength="16" spellcheck="false"
                           autocomplete="off" placeholder="Public access or higher"
                           value="${esc(Keys.getTorn())}">
                    <div class="bh4-hint">Single war-status call, cached 5 minutes. Enables the WAR toggle in the filter bar.</div>
                    <div class="bh4-btn-row">
                        <button id="bh4-torn-save" class="bh4-btn-save">Save</button>
                        <button id="bh4-torn-clear" class="bh4-btn-clear">Clear</button>
                    </div>
                    <div id="bh4-torn-st" class="bh4-status"></div>
                </div>`}

                <div class="bh4-section">
                    <label class="bh4-field-label">Fallback behavior</label>
                    <label class="bh4-check-row">
                        <input type="checkbox" id="bh4-unk-ff"    ${settings.includeUnknownFF    ? "checked" : ""}>
                        Include targets with unknown FF score
                    </label>
                    <label class="bh4-check-row">
                        <input type="checkbox" id="bh4-unk-timer" ${settings.includeUnknownTimer ? "checked" : ""}>
                        Include hospital targets with unreadable timer
                    </label>
                </div>

                <div class="bh4-ver">BH4 v${VERSION} · DOM-native filter</div>
            </div>
        `;
        document.body.appendChild(overlay);

        overlay.addEventListener("click", e => { if (e.target === overlay) overlay.remove(); });
        overlay.querySelector(".bh4-close").addEventListener("click", () => overlay.remove());

        overlay.querySelector("#bh4-unk-ff").addEventListener("change", e => {
            settings.includeUnknownFF = e.target.checked; saveSettings(settings); scheduleFilter();
        });
        overlay.querySelector("#bh4-unk-timer").addEventListener("change", e => {
            settings.includeUnknownTimer = e.target.checked; saveSettings(settings); scheduleFilter();
        });

        // FF key
        const ffSt = overlay.querySelector("#bh4-ff-st");
        const setFF = (cls, msg) => { ffSt.className = `bh4-status ${cls}`; ffSt.textContent = msg; };

        overlay.querySelector("#bh4-ff-save").addEventListener("click", async () => {
            const k = overlay.querySelector("#bh4-ff-input").value.trim();
            if (!k) { setFF("err", "Enter a key first."); return; }
            setFF("", "Validating…");
            const r = await validateFFKey(k);
            if (!r.ok) { setFF("err", r.msg); return; }
            Keys.saveFF(k);
            setFF("ok", r.msg);
            document.querySelector("#bh4-ff-group")?.style.removeProperty("display");
            document.querySelector("#bh4-enrich-btn")?.style.removeProperty("display");
        });

        overlay.querySelector("#bh4-ff-clear").addEventListener("click", () => {
            Keys.clearFF();
            overlay.querySelector("#bh4-ff-input").value = "";
            setFF("", "Cleared.");
            if (document.querySelector("#bh4-ff-group"))
                document.querySelector("#bh4-ff-group").style.display   = "none";
            if (document.querySelector("#bh4-enrich-btn"))
                document.querySelector("#bh4-enrich-btn").style.display = "none";
            scheduleFilter();
        });

        // Torn key (not PDA)
        if (!IS_PDA) {
            const tSt  = overlay.querySelector("#bh4-torn-st");
            const setT = (cls, msg) => { tSt.className = `bh4-status ${cls}`; tSt.textContent = msg; };

            overlay.querySelector("#bh4-torn-save").addEventListener("click", () => {
                const k = overlay.querySelector("#bh4-torn-input").value.trim();
                if (!/^[A-Za-z0-9]{16}$/.test(k)) { setT("err", "Must be 16 alphanumeric characters."); return; }
                Keys.saveTorn(k); _warFetchedAt = 0;
                setT("ok", "Saved.");
                document.querySelector("#bh4-war-btn")?.style.removeProperty("display");
            });

            overlay.querySelector("#bh4-torn-clear").addEventListener("click", () => {
                Keys.clearTorn();
                overlay.querySelector("#bh4-torn-input").value = "";
                _warFactions = new Set(); _warFetchedAt = 0;
                setT("", "Cleared.");
                if (document.querySelector("#bh4-war-btn"))
                    document.querySelector("#bh4-war-btn").style.display = "none";
                settings.hideWar = false; saveSettings(settings); applyFilters();
            });
        }
    }

    // ── Bounty page lifecycle ────────────────────────────────────────────────────
    let _ready   = false;
    let _listObs = null;

    function tryInit() {
        if (!document.querySelector(".bounties-list")) return false;

        injectCSS();
        injectFilterBar();
        applyFilters();

        if (Keys.getFF()) setTimeout(runEnrichment, 800);
        if (settings.hideWar && Keys.getTorn()) fetchWar().then(() => applyFilters());

        if (!_listObs) {
            _listObs = new MutationObserver(scheduleFilter);
            _listObs.observe(document.querySelector(".bounties-list"), { childList: true, subtree: true });
        }

        _ready = true;
        return true;
    }

    function setup() {
        if (tryInit()) return;

        const bodyObs = new MutationObserver(() => {
            if (!tryInit()) return;
            bodyObs.disconnect();

            // Handle SPA transitions that swap out the content wrapper
            const wrapper = document.querySelector(".content-wrapper");
            if (wrapper && !wrapper._bh4) {
                wrapper._bh4 = true;
                new MutationObserver(() => {
                    if (!document.querySelector(".bounties-list")) {
                        _ready = false; _listObs?.disconnect(); _listObs = null;
                        document.getElementById("bh4-bar")?.remove();
                        statsEl = null;
                    } else if (!_ready) {
                        setTimeout(tryInit, 150);
                    }
                }).observe(wrapper, { childList: true });
            }
        });
        bodyObs.observe(document.body, { childList: true, subtree: true });
    }

    // ── Profile mark button ──────────────────────────────────────────────────────
    function setupMarkButton() {
        injectCSS();
        let lastUrl = "", lastXid = "";

        const tryInject = () => {
            if (!location.href.includes("profiles.php")) {
                document.getElementById("bh4-mark-btn")?.remove(); lastXid = ""; return;
            }
            const xid = new URLSearchParams(location.search).get("XID") ?? "";
            if (!xid) { document.getElementById("bh4-mark-btn")?.remove(); lastXid = ""; return; }
            if (document.getElementById("bh4-mark-btn") && lastXid === xid) return;

            document.getElementById("bh4-mark-btn")?.remove();
            lastXid = xid;
            const id = Number(xid);
            if (!id) return;

            let name = `Player ${id}`;
            for (const sel of ["[class*='playerName']","[class*='player-name']","[class*='name___']",".profile-header h4","h4.bold"]) {
                const el = document.querySelector(sel);
                if (el?.textContent.trim() && el.textContent.trim().length < 40) { name = el.textContent.trim(); break; }
            }

            const isMarked = Marks.has(id);
            const btn = document.createElement("button");
            btn.id = "bh4-mark-btn";
            btn.className = "bh4-mark-btn" + (isMarked ? " active" : "");
            btn.textContent = isMarked ? "✓ MARKED" : "+ MARK";
            btn.addEventListener("click", () => {
                if (Marks.has(id)) { Marks.remove(id); btn.textContent = "+ MARK"; btn.classList.remove("active"); }
                else               { Marks.add({ id, name }); btn.textContent = "✓ MARKED"; btn.classList.add("active"); }
            });
            document.body.appendChild(btn);
        };

        setInterval(() => {
            if (location.href !== lastUrl) { lastUrl = location.href; setTimeout(tryInject, 500); setTimeout(tryInject, 1500); }
        }, 400);
        tryInject(); setTimeout(tryInject, 800); setTimeout(tryInject, 2000);
    }

    // ── Bootstrap ─────────────────────────────────────────────────────────────────
    if (ON_BOUNTIES) {
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", setup);
        else setup();
    }

    if (ON_PROFILE) {
        if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", setupMarkButton);
        else setupMarkButton();
    }

})();
