// ==UserScript==
// @name         Bounty Hunter 4
// @namespace    https://github.com/nolan2600/torn-scripts/bounty-hunter-4
// @version      4.2.0
// @description  Live Torn bounty board — reward, FF, BS bracket, hospital window, war filter, marked targets, alerts. Tactical UI.
// @author       nolan2600
// @match        https://www.torn.com/*
// @match        https://torn.com/*
// @grant        GM_xmlhttpRequest
// @grant        unsafeWindow
// @connect      api.torn.com
// @connect      ffscouter.com
// @run-at       document-end
// @license      GPL-3.0-or-later
// ==/UserScript==

(function () {
    "use strict";

    const VERSION = "4.2.1";
    const API_BASE = "https://api.torn.com/v2";
    const FF_BASE  = "https://ffscouter.com/api/v1";
    const ATTACK_URL  = "https://www.torn.com/page.php?sid=attack&user2ID=";
    const PROFILE_URL = "https://www.torn.com/profiles.php?XID=";

    const LS = { apiKey:"bh4_apiKey", ffKey:"bh4_ffKey", settings:"bh4_settings", marks:"bh4_marks", shared:"bh4_shared" };
    const API_DELAY_MS = 750, STATUS_CONCURRENCY = 3, STATUS_CACHE_MS = 20_000;
    const FACTION_CACHE_MS = 300_000, TOAST_MS = 15_000, SHARED_FRESH_RATIO = 0.8;

    const W      = (typeof unsafeWindow !== "undefined") ? unsafeWindow : window;
    const IS_PDA = typeof W.PDA_httpGet === "function";
    const PDA_PH = "###PDA-APIKEY###";
    const HAS_PDA_KEY = IS_PDA && PDA_PH !== "###" + "PDA-APIKEY" + "###" && /^[A-Za-z0-9]{16}$/.test(PDA_PH);

    const BS_RANGES = [
        { id:"bs-2k",   label:"2k–25k",    min:2_000,       max:25_000       },
        { id:"bs-20k",  label:"20k–250k",  min:20_000,      max:250_000      },
        { id:"bs-200k", label:"200k–2.5m", min:200_000,     max:2_500_000    },
        { id:"bs-2m",   label:"2m–25m",    min:2_000_000,   max:25_000_000   },
        { id:"bs-20m",  label:"20m–250m",  min:20_000_000,  max:250_000_000  },
        { id:"bs-200m", label:"200m+",     min:200_000_000, max:Infinity     },
    ];

    const DEFAULTS = {
        minPrice:500_000, minFF:1.0, maxFF:3.0, hospitalMaxMin:30,
        refreshSec:60, toastsEnabled:true, includeUnknownFF:true,
        revivableOnly:false, bsRanges:[], hospAlerts:false,
        hideWarTargets:false, markedAlerts:false,
    };

    // ── Utilities ─────────────────────────────────────────────────────────────
    const esc = s => String(s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    const sleep = ms => new Promise(r => setTimeout(r, ms));

    function fmtMoney(n) {
        if (n == null) return "$0";
        const a = Math.abs(n);
        const s = a >= 1e9 ? (a/1e9).toFixed(2)+"B" : a >= 1e6 ? (a/1e6).toFixed(2)+"M" : a >= 1e3 ? (a/1e3).toFixed(1)+"K" : a.toLocaleString();
        return (n < 0 ? "-$" : "$") + s;
    }
    function fmtMoneyFull(n) { return (n < 0 ? "-" : "") + "$" + Math.abs(n).toLocaleString(); }
    function fmtHosp(untilSec) {
        const rem = Math.max(0, untilSec - Math.floor(Date.now()/1000));
        if (rem <= 0) return "OUT";
        const h = Math.floor(rem/3600), m = Math.floor((rem%3600)/60), s = rem%60;
        if (h > 0) return `${h}h ${m}m`;
        return m === 0 ? `${s}s` : `${m}m ${s}s`;
    }
    function parseBS(human) {
        if (!human) return null;
        const m = String(human).match(/^\s*([\d.]+)\s*([kKmMbB]?)\s*$/);
        if (!m) return null;
        const n = parseFloat(m[1]);
        if (!Number.isFinite(n)) return null;
        const mult = ({k:1e3,m:1e6,b:1e9})[m[2].toLowerCase()] ?? 1;
        return n * mult;
    }
    function loadSettings() {
        try { const r = localStorage.getItem(LS.settings); return { ...DEFAULTS, ...(r ? JSON.parse(r) : {}) }; }
        catch { return { ...DEFAULTS }; }
    }
    function saveSettings(s) { try { localStorage.setItem(LS.settings, JSON.stringify(s)); } catch {} }
    function openUrl(url) { const a = document.createElement("a"); a.href=url; a.target="_blank"; a.rel="noopener noreferrer"; document.body.appendChild(a); a.click(); a.remove(); }

    // ── HTTP ──────────────────────────────────────────────────────────────────
    function gmGet(url) {
        if (typeof GM_xmlhttpRequest === "function") {
            return new Promise((resolve, reject) => {
                GM_xmlhttpRequest({
                    method:"GET", url, responseType:"json", timeout:25_000,
                    onload(r) {
                        const d = r.response ?? (() => { try { return JSON.parse(r.responseText); } catch { return null; } })();
                        if (d !== null) resolve(d); else reject(new Error("parse"));
                    },
                    onerror()   { reject(new Error("network")); },
                    ontimeout() { reject(new Error("timeout")); },
                });
            });
        }
        // Fallback for environments without GM_xmlhttpRequest (e.g. Torn PDA inline browser)
        return fetch(url).then(r => { if (!r.ok) throw new Error("HTTP " + r.status); return r.json(); });
    }
    async function httpGet(url) {
        if (IS_PDA && url.includes("api.torn.com")) {
            return new Promise((resolve, reject) => {
                W.PDA_httpGet(url, r => {
                    try { resolve(JSON.parse(r.responseText ?? r)); }
                    catch { reject(new Error("pda_parse")); }
                });
            });
        }
        try { return await gmGet(url); }
        catch (e) { await sleep(400); return gmGet(url); }
    }

    // ── Key store ─────────────────────────────────────────────────────────────
    const Keys = {
        getTorn()  { if (HAS_PDA_KEY) return PDA_PH; try { return localStorage.getItem(LS.apiKey) || ""; } catch { return ""; } },
        saveTorn(k){ try { localStorage.setItem(LS.apiKey, k); } catch {} },
        clearTorn(){ try { localStorage.removeItem(LS.apiKey); } catch {} },
        getFF()    { try { return localStorage.getItem(LS.ffKey) || ""; } catch { return ""; } },
        saveFF(k)  { try { localStorage.setItem(LS.ffKey, k); } catch {} },
        clearFF()  { try { localStorage.removeItem(LS.ffKey); } catch {} },
        isPDA()    { return HAS_PDA_KEY; },
    };

    // ── Marked targets ────────────────────────────────────────────────────────
    const Marks = {
        load()       { try { return JSON.parse(localStorage.getItem(LS.marks) || "[]"); } catch { return []; } },
        save(l)      { try { localStorage.setItem(LS.marks, JSON.stringify(l)); } catch {} },
        has(id)      { return this.load().some(t => t.id === Number(id)); },
        add(t)       { const l = this.load(); if (!l.some(x => x.id === Number(t.id))) { l.push({id:Number(t.id),name:String(t.name||`Player ${t.id}`),level:Number(t.level)||0}); this.save(l); } },
        remove(id)   { this.save(this.load().filter(t => t.id !== Number(id))); },
        updateInfo(id, name, level) { const l = this.load(), t = l.find(x => x.id === Number(id)); if (t && name) { t.name = name; if (level) t.level = level; this.save(l); } },
    };

    // ── Torn API ──────────────────────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key = key; this._last = 0; }
        setKey(k) { this.key = k; }
        async _rl() { const w = API_DELAY_MS - (Date.now() - this._last); this._last = Date.now() + Math.max(0, w); if (w > 0) await sleep(w); }
        async _get(path, params = {}) {
            await this._rl();
            const url = new URL(/^https?:\/\//.test(path) ? path : API_BASE + path);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            if (!url.searchParams.has("key")) url.searchParams.set("key", this.key);
            const data = await httpGet(url.toString());
            if (data?.error) { const e = new Error(data.error.error || "Torn API error"); e.tornCode = data.error.code; throw e; }
            return data;
        }
        async fetchBounties() {
            const all = []; let url = `${API_BASE}/torn/bounties?limit=100&offset=0`, delay = 0, safety = 10;
            while (url && safety-- > 0) {
                const data = await this._get(url);
                if (Array.isArray(data.bounties)) all.push(...data.bounties);
                if (typeof data.bounties_delay === "number") delay = data.bounties_delay;
                const next = data._metadata?.links?.next;
                if (!next || !data.bounties?.length) break;
                url = next;
            }
            return { bounties: all, delaySec: delay };
        }
        async fetchProfile(id) {
            const d = await this._get(`/user/${id}/profile`);
            return d?.profile ?? (d?.id ? d : null);
        }
        async validateKey() { const d = await this._get("/user/profile"); return d?.profile ?? null; }
        async fetchWars() { return this._get("https://api.torn.com/torn/?selections=rankedwars,territorywars"); }
    }

    // ── FFScouter ─────────────────────────────────────────────────────────────
    async function validateFFKey(key) {
        if (!/^[A-Za-z0-9]{16}$/.test(key)) return { ok:false, msg:"Must be 16 alphanumeric characters." };
        try {
            const d = await gmGet(`${FF_BASE}/check-key?key=${encodeURIComponent(key)}`);
            if (d?.code) return { ok:false, msg:d.error || `FFScouter error ${d.code}` };
            if (!d?.is_registered) return { ok:false, msg:"Key not registered." };
            return { ok:true, msg:d.is_premium ? "Valid (premium)" : "Valid" };
        } catch(e) { return { ok:false, msg:e?.message || "Could not reach FFScouter." }; }
    }
    async function fetchFF(key, ids) {
        const map = new Map(); let networkFail = false, error = null;
        if (!key || !ids.length) return { map, networkFail, error };
        for (let i = 0; i < ids.length; i += 200) {
            const chunk = ids.slice(i, i + 200);
            try {
                const data = await gmGet(`${FF_BASE}/get-stats?key=${encodeURIComponent(key)}&targets=${chunk.join(",")}`);
                if (Array.isArray(data)) {
                    for (const p of data) {
                        if (p.fair_fight != null) map.set(Number(p.player_id), { ff:Number(p.fair_fight), bs:p.bs_estimate_human ?? null });
                    }
                } else { error = data?.error || "unexpected"; }
            } catch(e) { error = e.message; networkFail = true; }
        }
        return { map, networkFail, error };
    }

    // ── Hunter ────────────────────────────────────────────────────────────────
    class Hunter {
        constructor(api) {
            this.api = api; this.settings = loadSettings();
            this.myId = null; this.myLevel = null; this.myAge = null;
            this.lastMatches = []; this.lastMatchKeys = new Set(); this.lastCounts = null;
            this._statusCache = new Map(); this._warCache = null; this._timer = null;
            this._running = false; this._nextAt = 0; this.lastError = null;
            this.onUpdate = null; this.onToast = null; this.onHospAlert = null;
            this.onClaimed = null; this.onMarkedUpdate = null; this.onMarkedAlert = null;
            this.lastMarkedStatuses = new Map();
        }
        updateSettings(next) {
            this.settings = { ...this.settings, ...next };
            saveSettings(this.settings);
            this.lastMatchKeys = new Set();
            this._warCache = null;
            try { localStorage.removeItem(LS.shared); } catch {}
        }
        _readShared() {
            try { const r = localStorage.getItem(LS.shared); if (!r) return null; const s = JSON.parse(r); return s?.writtenAt ? s : null; }
            catch { return null; }
        }
        _writeShared() {
            try { localStorage.setItem(LS.shared, JSON.stringify({ writtenAt:Date.now(), refreshSec:this.settings.refreshSec, matches:this.lastMatches, lastCounts:this.lastCounts, myId:this.myId, myLevel:this.myLevel, myAge:this.myAge, lastError:this.lastError?.message ?? null })); } catch {}
        }
        _applyMatches(matches) {
            const key = m => `${m.target_id}|${m.reward}`;
            const cur = new Set(matches.map(key));
            const newOnes = matches.filter(m => !this.lastMatchKeys.has(key(m)));
            if (this.settings.toastsEnabled && this.onToast && newOnes.length) this.onToast(newOnes);
            this.lastMatches = matches; this.lastMatchKeys = cur;
            if (this.onHospAlert) this.onHospAlert(matches);
        }
        adoptShared(s) {
            if (!s) return;
            if (s.myId != null && this.myId == null) this.myId = s.myId;
            if (s.myLevel != null && this.myLevel == null) this.myLevel = s.myLevel;
            if (s.myAge != null && this.myAge == null) this.myAge = s.myAge;
            if (Array.isArray(s.matches)) { this.lastCounts = s.lastCounts ?? null; this._applyMatches(s.matches); }
            if (this.onUpdate) this.onUpdate();
        }
        stop() { if (this._timer) { clearTimeout(this._timer); this._timer = null; } this._running = false; }
        start() { if (this._running) return; this._running = true; this._nextAt = Date.now() + this.settings.refreshSec * 1000; this._tick(); }
        async _tick() {
            if (!this._running) return;
            let waitSec = this.settings.refreshSec;
            try {
                const shared = this._readShared();
                const fresh = shared && (Date.now() - shared.writtenAt) < (this.settings.refreshSec * 1000 * SHARED_FRESH_RATIO);
                if (fresh) { this.adoptShared(shared); }
                else { const d = await this.refresh(); waitSec = Math.max(this.settings.refreshSec, d || 0); }
            } catch(e) {
                this.lastError = e;
                if (this.onUpdate) this.onUpdate();
                waitSec = Math.max(this.settings.refreshSec, 30);
            }
            await this.refreshMarked().catch(() => {});
            if (!this.settings.refreshSec) return;
            this._nextAt = Date.now() + waitSec * 1000;
            this._timer = setTimeout(() => this._tick(), waitSec * 1000);
        }
        async refresh() {
            this.lastError = null;
            if (this.onUpdate) this.onUpdate({ loading:true });
            try {
                const p = await this.api.validateKey();
                if (p) { this.myId = p.id ?? this.myId; this.myLevel = p.level ?? this.myLevel; this.myAge = p.age ?? this.myAge; }
            } catch {}

            const { bounties, delaySec } = await this.api.fetchBounties();

            // Deduplicate by target — keep highest reward
            const grouped = new Map();
            for (const b of bounties) {
                const id = String(b.target_id), qty = (typeof b.quantity === "number" && b.quantity > 0) ? b.quantity : 1;
                if (!grouped.has(id)) { grouped.set(id, { ...b, bountyCount:qty }); }
                else {
                    const ex = grouped.get(id);
                    const nc = ex.bountyCount + qty;
                    if (b.reward > ex.reward) grouped.set(id, { ...b, bountyCount:nc });
                    else ex.bountyCount = nc;
                }
            }
            const deduped = [...grouped.values()];

            // Detect claimed (hospital targets that vanished)
            if (this.lastMatches.length) {
                const board = new Set(deduped.map(b => String(b.target_id)));
                const claimed = this.lastMatches.filter(m => m.statusState === "Hospital" && !board.has(String(m.target_id)));
                if (claimed.length && this.onClaimed) this.onClaimed(claimed);
            }

            const counts = { total:bounties.length, afterBasic:0, withFF:0, ffError:null, ffNetworkFail:false, afterFF:0, afterBS:0, matches:0, inWar:0 };
            const byBasic = deduped.filter(b => b.reward >= this.settings.minPrice && (this.myId == null || b.target_id !== this.myId));
            counts.afterBasic = byBasic.length;

            const ffKey = Keys.getFF();
            const ids = [...new Set(byBasic.map(b => Number(b.target_id)))];
            const ff = await fetchFF(ffKey, ids);
            counts.withFF = ff.map.size; counts.ffError = ff.error; counts.ffNetworkFail = ff.networkFail;

            const includeUnknown = !!this.settings.includeUnknownFF || ff.networkFail;
            const byFF = byBasic.map(b => {
                const e = ff.map.get(Number(b.target_id));
                if (e) return { ...b, ff:e.ff, bs:e.bs };
                return includeUnknown ? { ...b, ff:null, bs:null } : null;
            }).filter(b => {
                if (!b) return false;
                if (b.ff == null) return true;
                return b.ff >= this.settings.minFF && b.ff <= this.settings.maxFF;
            });
            counts.afterFF = byFF.length;

            const sel = this.settings.bsRanges || [];
            const byBS = sel.length === 0 ? byFF : byFF.filter(b => {
                if (b.bs == null) return true;
                const n = parseBS(b.bs); if (n == null) return true;
                return sel.some(rid => { const r = BS_RANGES.find(x => x.id === rid); return r && n >= r.min && n <= r.max; });
            });
            counts.afterBS = byBS.length;

            const profiles = await this._fetchProfiles(byBS.map(b => Number(b.target_id)));
            const warSet = await this._fetchWarFactions();

            const nowSec = Math.floor(Date.now()/1000);
            const hospWindowSec = this.settings.hospitalMaxMin * 60;
            const matches = [];

            for (const b of byBS) {
                const p = profiles.get(Number(b.target_id));
                if (!p?.status || typeof p.status !== "object") continue;
                const state = p.status.state;
                const until = p.status.until || 0;
                const remaining = Math.max(0, until - nowSec);
                const inWar = !!(p.faction_id && warSet.has(Number(p.faction_id)));
                if (this.settings.hideWarTargets && inWar) { counts.inWar++; continue; }
                if (state === "Okay") {
                    matches.push({ ...b, statusState:"Okay", hospUntil:0, revivable:null, inWar });
                } else if (state === "Hospital" && remaining <= hospWindowSec) {
                    if (this.settings.revivableOnly && p.revivable !== true) continue;
                    matches.push({ ...b, statusState:"Hospital", hospUntil:until, revivable:p.revivable ?? null, inWar });
                }
            }
            matches.sort((a, b) => b.reward - a.reward);
            counts.matches = matches.length;
            this.lastCounts = counts;
            this._applyMatches(matches);
            this._writeShared();
            if (this.onUpdate) this.onUpdate({ loading:false });
            return delaySec;
        }
        async _fetchProfiles(ids) {
            const out = new Map(), now = Date.now(), stale = [], unique = [...new Set(ids)];
            for (const id of unique) {
                const c = this._statusCache.get(id);
                if (c) {
                    const hospLocked = c.data?.status?.state === "Hospital" && c.data.status.until && (c.data.status.until * 1000) > now;
                    if (hospLocked || (now - c.fetchedAt < STATUS_CACHE_MS)) { out.set(id, c.data); continue; }
                }
                stale.push(id);
            }
            let i = 0, rlErr = null;
            const workers = Array.from({ length:STATUS_CONCURRENCY }, async () => {
                while (i < stale.length && !rlErr) {
                    const id = stale[i++];
                    try {
                        const p = await this.api.fetchProfile(id);
                        if (p && typeof p === "object") {
                            const data = {
                                status:p.status ?? null, age:typeof p.age === "number" ? p.age : null,
                                faction_id:p.faction?.id ?? p.faction?.faction_id ?? p.faction_id ?? null,
                                revivable:typeof p.revivable === "boolean" ? p.revivable : null,
                                name:p.name ?? p.player_name ?? null, level:typeof p.level === "number" ? p.level : null,
                            };
                            out.set(id, data); this._statusCache.set(id, { data, fetchedAt:Date.now() });
                        }
                    } catch(e) { if (e.tornCode === 5 || e.status === 429) { rlErr = e; return; } }
                }
            });
            await Promise.all(workers);
            if (rlErr) throw rlErr;
            return out;
        }
        async _fetchWarFactions() {
            const now = Date.now();
            if (this._warCache && (now - this._warCache.fetchedAt) < FACTION_CACHE_MS) return this._warCache.ids;
            const ids = new Set();
            try {
                const data = await this.api.fetchWars();
                for (const w of Object.values(data.rankedwars || {}))
                    for (const fid of Object.keys(w.factions || {})) { const n = Number(fid); if (n > 0) ids.add(n); }
                for (const w of Object.values(data.territorywars || {})) {
                    for (const k of ["assaulting_faction","defending_faction"]) { const n = Number(w[k]); if (n > 0) ids.add(n); }
                }
            } catch { return this._warCache?.ids ?? ids; }
            this._warCache = { ids, fetchedAt:now };
            return ids;
        }
        async refreshMarked() {
            const targets = Marks.load();
            if (!targets.length) { this.lastMarkedStatuses = new Map(); if (this.onMarkedUpdate) this.onMarkedUpdate(); return; }
            const profiles = await this._fetchProfiles(targets.map(t => Number(t.id)));
            const warSet = await this._fetchWarFactions();
            let changed = false;
            const updated = targets.map(t => {
                const p = profiles.get(Number(t.id));
                if (p?.name && (p.name !== t.name || (p.level && p.level !== t.level))) { changed = true; return { ...t, name:p.name, level:p.level || t.level }; }
                return t;
            });
            if (changed) Marks.save(updated);
            const nowSec = Math.floor(Date.now()/1000);
            const statuses = new Map();
            for (const t of updated) {
                const p = profiles.get(Number(t.id));
                if (!p?.status) { statuses.set(t.id, { state:null, until:0, remaining:0, revivable:null, inWar:false }); continue; }
                statuses.set(t.id, {
                    state:p.status.state, until:p.status.until || 0,
                    remaining:Math.max(0, (p.status.until || 0) - nowSec),
                    revivable:p.revivable ?? null,
                    inWar:!!(p.faction_id && warSet.has(Number(p.faction_id))),
                    description:p.status.description || "",
                });
            }
            this.lastMarkedStatuses = statuses;
            if (this.onMarkedUpdate) this.onMarkedUpdate();
            if (this.onMarkedAlert) this.onMarkedAlert(updated, statuses);
        }
        secondsUntilRefresh() { return this._nextAt ? Math.max(0, Math.round((this._nextAt - Date.now()) / 1000)) : 0; }
    }

    // ── Toaster ───────────────────────────────────────────────────────────────
    class Toaster {
        constructor() { this._el = null; this._cards = []; }
        _ensure() {
            if (this._el && document.body.contains(this._el)) return;
            const c = document.createElement("div"); c.id = "bh4-toasts"; document.body.appendChild(c); this._el = c;
        }
        showMany(bounties) {
            this._ensure();
            const MAX = window.matchMedia("(max-width:768px)").matches ? 1 : 3;
            const slots = Math.max(0, MAX - this._cards.length);
            bounties.slice(0, slots).forEach(b => this._show(b));
        }
        _show(b) {
            const el = document.createElement("div"); el.className = "bh4-toast";
            const isH = b.statusState === "Hospital";
            el.innerHTML = `
                <button class="bh4-tc">&times;</button>
                <div class="bh4-th">
                    <span class="bh4-tn">${esc(b.target_name)} <span class="bh4-tlv">L${b.target_level}</span>${b.bountyCount>1?`<span class="bh4-tct">×${b.bountyCount}</span>`:""}</span>
                    <span class="bh4-tr">${esc(fmtMoney(b.reward))}</span>
                </div>
                <div class="bh4-tm">
                    <span class="bh4-chip">${b.ff != null ? `FF ${b.ff.toFixed(2)}` : "FF ?"}</span>
                    ${b.bs ? `<span class="bh4-chip">BS ${esc(b.bs)}</span>` : ""}
                    <span class="bh4-chip ${isH ? "bh4-ch" : "bh4-co"}"${isH ? ` data-hu="${b.hospUntil}"` : ""}>${isH ? fmtHosp(b.hospUntil) : "OKAY"}</span>
                </div>
                <button class="bh4-ta">ATTACK →</button>`;
            const card = { id:Number(b.target_id), el, rem:TOAST_MS, at:0, timer:null };
            const dismiss = () => this._rm(card);
            el.querySelector(".bh4-tc").addEventListener("click", e => { e.stopPropagation(); dismiss(); });
            el.querySelector(".bh4-ta").addEventListener("click", () => { openUrl(PROFILE_URL + b.target_id); dismiss(); });
            el.addEventListener("click", () => { openUrl(PROFILE_URL + b.target_id); dismiss(); });
            el.addEventListener("pointerenter", () => this._pause(card));
            el.addEventListener("pointerleave", () => this._resume(card));
            this._resume(card); this._el.appendChild(el); this._cards.push(card);
        }
        _pause(card) { if (!card.timer) return; clearTimeout(card.timer); card.timer = null; card.rem = Math.max(0, card.rem - (Date.now() - card.at)); }
        _resume(card) { card.at = Date.now(); if (card.timer) clearTimeout(card.timer); card.timer = setTimeout(() => this._rm(card), card.rem); }
        _rm(card) { clearTimeout(card.timer); card.el?.parentNode?.removeChild(card.el); this._cards = this._cards.filter(c => c !== card); }
        clearAll() { [...this._cards].forEach(c => this._rm(c)); }
    }

    // ── Hospital Alert Manager ────────────────────────────────────────────────
    class AlertMgr {
        constructor() { this._sched = new Map(); this._fired = new Map(); this._manual = new Set(); this._cancel = new Set(); this.enabled = false; }
        toggle(id) {
            id = String(id);
            if (this.enabled) { if (this._cancel.has(id)) this._cancel.delete(id); else this._cancel.add(id); }
            else { if (this._manual.has(id)) this._manual.delete(id); else this._manual.add(id); }
        }
        isActive(id) { id = String(id); return this.enabled ? !this._cancel.has(id) : this._manual.has(id); }
        sync(matches) {
            const nowSec = Math.floor(Date.now()/1000), live = new Set();
            for (const m of matches) {
                if (m.statusState !== "Hospital" || m.hospUntil <= nowSec) continue;
                const id = String(m.target_id); live.add(id);
                if (!this.isActive(id)) continue;
                const firedUntil = this._fired.get(id);
                if (firedUntil != null && Math.abs(m.hospUntil - firedUntil) < 300) continue;
                const ex = this._sched.get(id);
                if (ex && Math.abs(ex.hospUntil - m.hospUntil) <= 5) continue;
                if (ex) { clearTimeout(ex.timer); this._sched.delete(id); }
                const alertAt = m.hospUntil - 60;
                if (alertAt < nowSec - 10) continue;
                const delay = Math.max(0, (alertAt - nowSec) * 1000);
                const snap = m.hospUntil;
                const timer = setTimeout(() => { this._fired.set(id, snap); this._sched.delete(id); this._fire(m); }, delay);
                this._sched.set(id, { timer, hospUntil:m.hospUntil });
            }
            for (const [id, e] of this._sched) { if (!live.has(id)) { clearTimeout(e.timer); this._sched.delete(id); } }
            for (const [id, u] of this._fired) { if (u + 120 < nowSec) this._fired.delete(id); }
        }
        _fire(m) {
            const rem = Math.max(0, m.hospUntil - Math.floor(Date.now()/1000));
            const label = rem <= 0 ? "OUT NOW" : `~${rem}s`;
            try { if (navigator.vibrate) navigator.vibrate([400,150,400,150,600]); } catch {}
            try {
                const ACtx = window.AudioContext || window.webkitAudioContext;
                if (ACtx) { const ctx = new ACtx(), beep = (f,t,d) => { const o=ctx.createOscillator(),g=ctx.createGain(); o.connect(g); g.connect(ctx.destination); o.type="sine"; o.frequency.value=f; g.gain.setValueAtTime(0.4,t); g.gain.exponentialRampToValueAtTime(0.001,t+d); o.start(t); o.stop(t+d); }; beep(880,ctx.currentTime,0.18); beep(880,ctx.currentTime+0.22,0.18); beep(1100,ctx.currentTime+0.44,0.30); }
            } catch {}
            this._banner(m, label);
            if (typeof Notification !== "undefined" && Notification.permission === "granted") {
                try { new Notification(`${m.target_name} exits hospital ${label}`, { body:`Reward: ${fmtMoney(m.reward)}${m.ff!=null?" · FF "+m.ff.toFixed(2):""}`, tag:`bh4-h-${m.target_id}`, requireInteraction:false }); } catch {}
            }
        }
        _banner(m, label) {
            document.getElementById(`bh4-ab-${m.target_id}`)?.remove();
            const el = document.createElement("div"); el.id = `bh4-ab-${m.target_id}`; el.className = "bh4-alert";
            el.innerHTML = `<div class="bh4-al"><span class="bh4-ai">!</span><span class="bh4-an">${esc(m.target_name)} <span class="bh4-alv">L${m.target_level}</span></span><span class="bh4-at2">${label}</span><button class="bh4-ax">&times;</button></div><div class="bh4-as"><span class="bh4-chip">${esc(fmtMoney(m.reward))}</span>${m.ff!=null?`<span class="bh4-chip">FF ${m.ff.toFixed(2)}</span>`:""}</div><button class="bh4-aa">ATTACK → ${esc(m.target_name)}</button>`;
            document.body.appendChild(el);
            const dismiss = () => { el.style.animation="bh4-aout .25s forwards"; setTimeout(() => el.remove(), 260); };
            const auto = setTimeout(dismiss, 30_000);
            el.querySelector(".bh4-ax").addEventListener("click", e => { e.stopPropagation(); clearTimeout(auto); dismiss(); });
            el.querySelector(".bh4-aa").addEventListener("click", () => { clearTimeout(auto); openUrl(ATTACK_URL + m.target_id); dismiss(); });
        }
        cancelAll() { for (const { timer } of this._sched.values()) clearTimeout(timer); this._sched.clear(); }
    }

    // ── Marked Alert Manager ──────────────────────────────────────────────────
    class MarkedAlertMgr {
        constructor() { this._sched = new Map(); this._fired = new Map(); this._manual = new Set(); this._cancel = new Set(); this.enabled = false; }
        toggle(id) { id = String(id); if (this.enabled) { if (this._cancel.has(id)) this._cancel.delete(id); else this._cancel.add(id); } else { if (this._manual.has(id)) this._manual.delete(id); else this._manual.add(id); } }
        isActive(id) { id = String(id); return this.enabled ? !this._cancel.has(id) : this._manual.has(id); }
        sync(targets, statuses) {
            const nowSec = Math.floor(Date.now()/1000), live = new Set();
            for (const t of targets) {
                const s = statuses.get(t.id); if (!s?.state) continue;
                const alertUntil = s.state === "Hospital" ? s.until : 0;
                if (!alertUntil || alertUntil <= nowSec) continue;
                const id = String(t.id); live.add(id);
                if (!this.isActive(id)) continue;
                const firedU = this._fired.get(id);
                if (firedU != null && Math.abs(alertUntil - firedU) < 300) continue;
                const ex = this._sched.get(id);
                if (ex && Math.abs(ex.until - alertUntil) <= 5) continue;
                if (ex) { clearTimeout(ex.timer); this._sched.delete(id); }
                const alertAt = alertUntil - 60;
                if (alertAt < nowSec - 10) continue;
                const timer = setTimeout(() => { this._fired.set(id, alertUntil); this._sched.delete(id); this._fire(t, s); }, Math.max(0, (alertAt - nowSec) * 1000));
                this._sched.set(id, { timer, until:alertUntil });
            }
            for (const [id, e] of this._sched) { if (!live.has(id)) { clearTimeout(e.timer); this._sched.delete(id); } }
        }
        _fire(t, s) {
            const rem = Math.max(0, s.until - Math.floor(Date.now()/1000));
            this._banner(t, rem <= 0 ? "OUT NOW" : `~${rem}s`);
        }
        _banner(t, label) {
            document.getElementById(`bh4-tab-${t.id}`)?.remove();
            const el = document.createElement("div"); el.id = `bh4-tab-${t.id}`; el.className = "bh4-alert bh4-alert-top";
            el.innerHTML = `<div class="bh4-al"><span class="bh4-ai">T</span><span class="bh4-an">${esc(t.name)} <span class="bh4-alv">L${t.level}</span></span><span class="bh4-at2">${label}</span><button class="bh4-ax">&times;</button></div><div class="bh4-as"><span class="bh4-chip">Marked target</span></div><button class="bh4-aa">ATTACK → ${esc(t.name)}</button>`;
            document.body.appendChild(el);
            const dismiss = () => { el.remove(); };
            const auto = setTimeout(dismiss, 30_000);
            el.querySelector(".bh4-ax").addEventListener("click", e => { e.stopPropagation(); clearTimeout(auto); dismiss(); });
            el.querySelector(".bh4-aa").addEventListener("click", () => { clearTimeout(auto); openUrl(ATTACK_URL + t.id); dismiss(); });
        }
        cancelAll() { for (const { timer } of this._sched.values()) clearTimeout(timer); this._sched.clear(); }
    }

