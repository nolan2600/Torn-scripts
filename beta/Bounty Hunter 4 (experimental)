// ==UserScript==
// @name         Bounty Hunter 4
// @namespace    https://github.com/nolan2600/torn-scripts/bounty-hunter-4
// @version      4.1.0
// @description  DOM-native bounty board filter — 30-min attack window, FF enrichment, marked-target highlights. Desktop + Torn PDA.
// @author       nolan2600
// @match        https://www.torn.com/bounties.php*
// @match        https://torn.com/bounties.php*
// @match        https://www.torn.com/profiles.php*
// @match        https://torn.com/profiles.php*
// @grant        GM_xmlhttpRequest
// @grant        unsafeWindow
// @connect      ffscouter.com
// @connect      api.torn.com
// @run-at       document-end
// @license      GPL-3.0-or-later
// ==/UserScript==

(function () {
    "use strict";

    const ON_BOUNTIES = /bounties\.php/.test(location.href);
    const ON_PROFILE  = /profiles\.php/.test(location.href);

    // ── Constants ────────────────────────────────────────────────────────────
    const VERSION   = "4.1.0";
    const FF_BASE   = "https://ffscouter.com/api/v1";
    const TORN_BASE = "https://api.torn.com";

    const LS = {
        settings : "bh4_settings",
        marks    : "bh4_marks",
        ffKey    : "bh4_ffkey",
        tornKey  : "bh4_tornkey",
    };

    const W      = (typeof unsafeWindow !== "undefined") ? unsafeWindow : window;
    const IS_PDA = typeof W.PDA_httpGet === "function";
    const PDA_PH = "###PDA-APIKEY###";

    // ── Settings ──────────────────────────────────────────────────────────────
    const DEFAULTS = {
        hospitalMaxMin     : 30,
        statusFilter       : "all",   // "all" | "okay" | "hospital"
        minReward          : 0,
        maxLevel           : 100,
        minFF              : 1.0,
        maxFF              : 3.0,
        hideWar            : false,
        includeUnknownFF   : true,
        includeUnknownTimer: true,
    };

    function loadSettings() {
        try {
            const raw = localStorage.getItem(LS.settings);
            return raw ? { ...DEFAULTS, ...JSON.parse(raw) } : { ...DEFAULTS };
        } catch { return { ...DEFAULTS }; }
    }

    function saveSettings(s) {
        try { localStorage.setItem(LS.settings, JSON.stringify(s)); } catch {}
    }

    // ── Keys ──────────────────────────────────────────────────────────────────
    const Keys = {
        getFF()    { try { return localStorage.getItem(LS.ffKey)   || ""; } catch { return ""; } },
        saveFF(k)  { try { localStorage.setItem(LS.ffKey, k);          } catch {} },
        clearFF()  { try { localStorage.removeItem(LS.ffKey);          } catch {} },

        getTorn()  {
            if (IS_PDA) return PDA_PH;
            try { return localStorage.getItem(LS.tornKey) || ""; } catch { return ""; }
        },
        saveTorn(k)  { try { localStorage.setItem(LS.tornKey, k);  } catch {} },
        clearTorn()  { try { localStorage.removeItem(LS.tornKey);  } catch {} },
    };

    // ── Marked targets ────────────────────────────────────────────────────────
    const Marks = {
        load()     { try { return JSON.parse(localStorage.getItem(LS.marks) || "[]"); } catch { return []; } },
        save(list) { try { localStorage.setItem(LS.marks, JSON.stringify(list)); } catch {} },
        ids()      { return new Set(this.load().map(m => m.id)); },
        has(id)    { return this.load().some(m => m.id === id); },
        add(m)     { const l = this.load(); if (!l.some(x => x.id === m.id)) { l.push(m); this.save(l); } },
        remove(id) { this.save(this.load().filter(m => m.id !== id)); },
    };

    // ── HTTP ──────────────────────────────────────────────────────────────────
    function gmGet(url) {
        return new Promise((resolve, reject) => {
            if (IS_PDA && url.includes("api.torn.com")) {
                const resolved = url.replace(PDA_PH, W.PDA_API_KEY || "");
                W.PDA_httpGet(resolved, r => {
                    try { resolve(JSON.parse(r)); } catch { reject(new Error("parse")); }
                });
                return;
            }
            GM_xmlhttpRequest({
                method      : "GET",
                url,
                responseType: "json",
                timeout     : 20_000,
                onload(r) {
                    const d = r.response ?? (() => { try { return JSON.parse(r.responseText); } catch { return null; } })();
                    if (d !== null) resolve(d); else reject(new Error("parse"));
                },
                onerror()   { reject(new Error("network")); },
                ontimeout() { reject(new Error("timeout")); },
            });
        });
    }

    // ── FFScouter ─────────────────────────────────────────────────────────────
    const _ffData = {};   // playerId → { ff: number|null, bs: string|null }

    async function validateFFKey(key) {
        if (!/^[A-Za-z0-9]{16}$/.test(key)) return { ok: false, msg: "Must be 16 alphanumeric characters." };
        try {
            const data = await gmGet(`${FF_BASE}/check-key?key=${encodeURIComponent(key)}`);
            if (data?.code)          return { ok: false, msg: data.error || `FFScouter error ${data.code}` };
            if (!data?.is_registered) return { ok: false, msg: "Key not registered — sign up at ffscouter.com first." };
            return { ok: true, msg: data.is_premium ? "Valid (premium)." : "Valid." };
        } catch (e) { return { ok: false, msg: e?.message || "Could not reach FFScouter." }; }
    }

    async function enrichFF(ids) {
        const key = Keys.getFF();
        if (!key || ids.length === 0) return;

        const fresh = ids.filter(id => !(id in _ffData));
        if (fresh.length === 0) return;

        for (let i = 0; i < fresh.length; i += 200) {
            const chunk = fresh.slice(i, i + 200);
            try {
                const data = await gmGet(`${FF_BASE}/get-stats?key=${encodeURIComponent(key)}&targets=${chunk.join(",")}`);
                if (Array.isArray(data)) {
                    for (const p of data) {
                        _ffData[Number(p.player_id)] = {
                            ff : p.fair_fight != null ? Number(p.fair_fight) : null,
                            bs : p.bs_estimate_human ?? null,
                        };
                    }
                }
            } catch {}
            // Mark any remaining IDs in chunk as null so we don't re-fetch
            for (const id of chunk) if (!(id in _ffData)) _ffData[id] = { ff: null, bs: null };
        }
    }

    // ── War detection ──────────────────────────────────────────────────────────
    let _warFactions  = new Set();
    let _warFetchedAt = 0;
    const WAR_TTL = 300_000;

    async function fetchWar() {
        const key = Keys.getTorn();
        if (!key) return;
        if (Date.now() - _warFetchedAt < WAR_TTL) return;
        try {
            const data = await gmGet(`${TORN_BASE}/torn/?selections=rankedwars,territorywars&key=${key}`);
            const ids = new Set();
            for (const w of Object.values(data?.rankedwars    || {}))
                for (const f of Object.values(w?.factions || {})) ids.add(f.faction_id ?? f.id);
            for (const w of Object.values(data?.territorywars || {})) {
                if (w.assaulting_faction) ids.add(w.assaulting_faction);
                if (w.defending_faction)  ids.add(w.defending_faction);
            }
            _warFactions  = ids;
            _warFetchedAt = Date.now();
        } catch {}
    }

    // ── DOM parsers ────────────────────────────────────────────────────────────
    function parsePlayerId(li) {
        const id = parseInt(li.dataset.id ?? li.dataset.userId ?? "");
        if (!isNaN(id) && id > 0) return id;
        const link = li.querySelector("a[href*='profiles.php']");
        if (link) { const m = link.href.match(/XID=(\d+)/); if (m) return parseInt(m[1]); }
        return null;
    }

    function parsePlayerName(li) {
        const link = li.querySelector("a[href*='profiles.php']");
        if (link) return link.textContent.trim().replace(/\s*\[.*?\]$/, "");
        const el = li.querySelector(".name, [class*='playerName'], [class*='player-name']");
        return el ? el.textContent.trim().replace(/\s*\[.*?\]$/, "") : null;
    }

    function parseLevel(li) {
        const el = li.querySelector(".level");
        if (!el) return null;
        const m = el.textContent.match(/\d+/);
        return m ? parseInt(m[0]) : null;
    }

    function parseReward(li) {
        const el = li.querySelector(".reward, [class*='reward']");
        if (!el) return null;
        const num = el.textContent.replace(/[^0-9]/g, "");
        return num.length ? parseInt(num) : null;
    }

    function parseStatus(li) {
        if (li.querySelector(".user-red-status"))  return "hospital";
        if (li.querySelector(".user-blue-status")) return "traveling";
        const txt = li.querySelector("[class*='status']")?.textContent.toLowerCase() ?? "";
        if (txt.includes("hospital")) return "hospital";
        if (txt.includes("travel"))   return "traveling";
        return "okay";
    }

    function parseTimeText(text) {
        if (!text) return null;
        const s = text.toLowerCase();
        if (/\d+\s*d/.test(s)) return 99_999;
        const hms = s.match(/(\d+)\s*h\s*(\d+)\s*m(?:\s*(\d+)\s*s)?/);
        if (hms) return +hms[1] * 3600 + +hms[2] * 60 + +(hms[3] ?? 0);
        const ms = s.match(/(\d+)\s*m(?:in)?(?:\s*(\d+)\s*s)?/);
        if (ms)  return +ms[1] * 60 + +(ms[2] ?? 0);
        const sec = s.match(/^(\d+)\s*s/);
        if (sec) return +sec[1];
        const hmss = s.match(/(\d+):(\d{2}):(\d{2})/);
        if (hmss) return +hmss[1] * 3600 + +hmss[2] * 60 + +hmss[3];
        const mss = s.match(/(\d{1,3}):(\d{2})/);
        if (mss)  return +mss[1] * 60 + +mss[2];
        return null;
    }

    function parseHospSeconds(li) {
        for (const attr of ["data-time", "data-end", "data-timestamp", "data-timer"]) {
            const el = li.querySelector(`[${attr}]`);
            if (!el) continue;
            const t = parseInt(el.getAttribute(attr));
            if (isNaN(t)) continue;
            if (t > 10_000_000_000) return Math.max(0, Math.round((t - Date.now()) / 1000));
            if (t >  1_000_000_000) return Math.max(0, t - Math.floor(Date.now() / 1000));
            return Math.max(0, t);
        }
        const statusEl = li.querySelector(".user-red-status, [class*='hospital']");
        if (statusEl) { const t = parseTimeText(statusEl.textContent); if (t !== null) return t; }
        return parseTimeText(li.textContent);
    }

    function parseFactionId(li) {
        const link = li.querySelector("a[href*='factions.php']");
        if (!link) return null;
        const m = link.href.match(/(?:ID|factionID)=(\d+)/i);
        return m ? parseInt(m[1]) : null;
    }

    // ── Runtime state ──────────────────────────────────────────────────────────
    let settings = loadSettings();
    let statsEl  = null;

    // ── Filter logic ───────────────────────────────────────────────────────────
    function rowPasses(li) {
        const status = parseStatus(li);
        if (status === "traveling") return false;

        const level   = parseLevel(li);
        const reward  = parseReward(li);
        if (level  !== null && level  > settings.maxLevel)  return false;
        if (reward !== null && reward < settings.minReward) return false;

        const windowSec = settings.hospitalMaxMin * 60;

        if (status === "hospital") {
            if (settings.statusFilter === "okay") return false;
            const secs = parseHospSeconds(li);
            if (secs === null && !settings.includeUnknownTimer) return false;
            if (secs !== null && secs > windowSec)               return false;
        } else {
            if (settings.statusFilter === "hospital") return false;
        }

        if (Keys.getFF()) {
            const id = parsePlayerId(li);
            const ff = id !== null ? (_ffData[id]?.ff ?? null) : null;
            if (ff === null && !settings.includeUnknownFF)                   return false;
            if (ff !== null && (ff < settings.minFF || ff > settings.maxFF)) return false;
        }

        if (settings.hideWar && _warFetchedAt > 0) {
            const fid = parseFactionId(li);
            if (fid && _warFactions.has(fid)) return false;
        }

        return true;
    }

    let _filterTimer = null;
    function scheduleFilter() {
        clearTimeout(_filterTimer);
        _filterTimer = setTimeout(applyFilters, 60);
    }

    function fmtSecs(secs) {
        if (secs < 60)   return `${secs}s`;
        if (secs < 3600) return `${Math.ceil(secs / 60)}m`;
        return `${Math.floor(secs / 3600)}h ${Math.round((secs % 3600) / 60)}m`;
    }

    function applyFilters() {
        const list = document.querySelector(".bounties-list");
        if (!list) return;

        const rows      = list.querySelectorAll(":scope > li[data-id]");
        const markedIds = Marks.ids();
        let visible = 0;

        for (const li of rows) {
            const passes = rowPasses(li);
            li.classList.toggle("bh4-hidden", !passes);

            if (!passes) {
                li.querySelectorAll(".bh4-badge").forEach(b => b.remove());
                continue;
            }

            visible++;
            const id = parsePlayerId(li);
            li.classList.toggle("bh4-marked-row", id !== null && markedIds.has(id));
            injectBadges(li, id);
        }

        if (statsEl) statsEl.innerHTML = `<strong>${visible}</strong> / ${rows.length}`;
    }

    function injectBadges(li, id) {
        li.querySelectorAll(".bh4-badge").forEach(b => b.remove());

        const anchor = li.querySelector(".level, .reward, li:first-child") ?? li;

        // Hospital timer badge
        if (parseStatus(li) === "hospital") {
            const secs = parseHospSeconds(li);
            if (secs !== null) {
                const b = document.createElement("span");
                b.className   = "bh4-badge bh4-hosp-badge";
                b.textContent = `→ ${fmtSecs(secs)}`;
                anchor.insertAdjacentElement("afterend", b);
            }
        }

        // FF badge
        if (id !== null && id in _ffData && _ffData[id].ff !== null) {
            const b = document.createElement("span");
            b.className   = "bh4-badge bh4-ff-badge";
            b.textContent = `FF ${_ffData[id].ff.toFixed(2)}`;
            anchor.insertAdjacentElement("afterend", b);
        }
    }

    // ── Enrichment runner ──────────────────────────────────────────────────────
    async function runEnrichment() {
        const list = document.querySelector(".bounties-list");
        if (!list) return;

        // Collect all IDs (not just visible) so FF data drives filtering
        const ids = [];
        for (const li of list.querySelectorAll(":scope > li[data-id]")) {
            const id = parsePlayerId(li);
            if (id !== null) ids.push(id);
        }

        await Promise.allSettled([enrichFF(ids), fetchWar()]);
        applyFilters();
    }

