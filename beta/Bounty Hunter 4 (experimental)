    })();

    // ── Profile mark button ───────────────────────────────────────────────────
    function setupMarkButton() {
        injectCSS();
        let lastUrl = "", lastXid = "";
        const tryInject = () => {
            if (!location.href.includes("profiles.php")) { document.getElementById("bh4-mb")?.remove(); lastXid=""; return; }
            const xid = new URLSearchParams(location.search).get("XID") || "";
            if (!xid) { document.getElementById("bh4-mb")?.remove(); lastXid=""; return; }
            if (document.getElementById("bh4-mb") && lastXid === xid) return;
            document.getElementById("bh4-mb")?.remove(); lastXid = xid;
            const id = Number(xid); if (!id) return;
            let name = `Player ${id}`, level = 0;
            for (const sel of ["[class*='playerName']","[class*='player-name']","[class*='name___']",".profile-header h4","h4.bold"]) {
                const el = document.querySelector(sel);
                if (el?.textContent.trim()?.length < 40) { name = el.textContent.trim(); break; }
            }
            const isMarked = Marks.has(id);
            const btn = document.createElement("button");
            btn.id = "bh4-mb"; btn.className = "bh4-mark-btn" + (isMarked ? " active" : "");
            btn.textContent = isMarked ? "✓ MARKED" : "+ MARK";
            btn.addEventListener("click", () => {
                if (Marks.has(id)) { Marks.remove(id); btn.textContent="+ MARK"; btn.classList.remove("active"); }
                else { Marks.add({ id, name, level }); btn.textContent="✓ MARKED"; btn.classList.add("active"); }
            });
            document.body.appendChild(btn);
        };
        setInterval(() => { if (location.href !== lastUrl) { lastUrl=location.href; setTimeout(tryInject,500); setTimeout(tryInject,1500); } }, 400);
        tryInject(); setTimeout(tryInject, 800); setTimeout(tryInject, 2000);
    }

    // ── Main ──────────────────────────────────────────────────────────────────
    const BH4_ICON = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><defs><linearGradient id="bh4g" x1=".5" x2=".5" y2="1" gradientUnits="objectBoundingBox"><stop offset="0" stop-color="#ddd"/><stop offset="1" stop-color="#999"/></linearGradient></defs><g fill="url(#bh4g)"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8Z"/><path d="M12 6a6 6 0 1 0 6 6 6 6 0 0 0-6-6Zm0 10a4 4 0 1 1 4-4 4 4 0 0 1-4 4Z"/><circle cx="12" cy="12" r="1.5"/><path d="M11 0h2v5h-2zM11 19h2v5h-2zM0 11h5v2H0zM19 11h5v2h-5z"/></g></svg>`;

    function main() {
        const key = Keys.getTorn();
        const api = new TornAPI(key || "");
        const hunter = new Hunter(api);
        const toaster = new Toaster();
        const alertMgr = new AlertMgr();
        const markedAlertMgr = new MarkedAlertMgr();
        const ui = new UI(hunter, toaster, alertMgr, markedAlertMgr);

        window.__bh4UI = ui; ui.inject(); ui.setAuthed(!!key);

        hunter.onHospAlert = matches => { alertMgr.enabled = hunter.settings.hospAlerts; alertMgr.sync(matches); };
        hunter.onClaimed = claimed => { if (hunter.settings.toastsEnabled) toaster.showMany(claimed); };
        hunter.onMarkedUpdate = () => { if (ui._open() && ui.tab === "targets") ui._renderTargets(); };
        hunter.onMarkedAlert = (targets, statuses) => { markedAlertMgr.enabled = hunter.settings.markedAlerts; markedAlertMgr.sync(targets, statuses); };

        setupMarkButton();

        window.addEventListener("storage", e => {
            if (e.key !== LS.shared || !e.newValue) return;
            try { hunter.adoptShared(JSON.parse(e.newValue)); } catch {}
        });

        W.registerEugeneScript({ id:"bh4", name:"Bounty Hunter 4", color:"#7a6020", colorDark:"#4a3a10", hoverColor:"#c8a84b", iconSVG:BH4_ICON, onClick:() => ui.toggle(true) });
        W.mountEugeneFooterMenu();
        if (key) hunter.start();
