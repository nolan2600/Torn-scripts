                const msg   = c.querySelector("#mkt-msg");
                if (!name) { msg.className = "cfa-msg-error"; msg.textContent = "Item name required."; return; }
                const type  = c.querySelector("#mkt-type").value;
                const qty   = parseFloat(c.querySelector("#mkt-qty").value) || 1;
                const price = parseFloat(c.querySelector("#mkt-price").value) || 0;
                const dateV = c.querySelector("#mkt-date").value;
                const ts    = dateV ? Math.floor(new Date(dateV + "T12:00:00").getTime() / 1000) : Math.floor(Date.now() / 1000);
                Store.addMarket({ id: fmt.uid(), itemId: null, itemName: name, type, qty, pricePerUnit: price, timestamp: ts });
                msg.className = "cfa-msg-success"; msg.textContent = "Trade added!";
                setTimeout(() => this._renderMarket(), 300);
            });

            c.querySelectorAll(".cfa-del-mkt").forEach(btn => {
                btn.addEventListener("click", () => {
                    const all = Store.getMarket().filter(e => e.id !== btn.dataset.id);
                    Store.saveMarket(all);
                    this._renderMarket();
                });
            });

            c.querySelector("#mkt-export").addEventListener("click", () => {
                const headers = ["Item","Type","Qty","Price/Unit","Total","Date"];
                const rws = Store.getMarket().map(e => [
                    e.itemName, e.type, e.qty, e.pricePerUnit,
                    (e.pricePerUnit * e.qty).toFixed(2), fmt.date(e.timestamp),
                ]);
                exportCSV("cfa_market_trades.csv", headers, rws);
            });
        }

        // ── Mugging ───────────────────────────────────────────────────────────

        _renderMugging() {
            const range     = this._dateRange;
            const raw       = Analytics.filterByRange(Store.getMugging(), range);
            const stats     = Analytics.muggingStats(raw);
            const lastSync  = Store.getLastMugSync();
            const lastSyncStr = lastSync ? fmt.dateTime(lastSync) : "Never";

            const { col, dir } = this._muggingSort;
            const sorted = [...raw].sort((a, b) => {
                let av = a[col], bv = b[col];
                if (av == null) av = 0; if (bv == null) bv = 0;
                return dir === "asc" ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
            });

            const th = (key, label) => {
                const icon = this._muggingSort.col === key ? (this._muggingSort.dir === "asc" ? " ▲" : " ▼") : "";
                return `<th data-sort="${key}">${label}${icon}</th>`;
            };

            const netColor  = stats.netMugging >= 0 ? "#4caf50" : "#ef5350";

            const tableRows = sorted.map(e => {
                const cls = e.type === "gained" ? "cfa-row-gained" : "cfa-row-lost";
                return `
<tr class="${cls}">
  <td><span class="${e.type === "gained" ? "cfa-badge-profit" : "cfa-badge-loss"}">${escHtml(e.type.toUpperCase())}</span></td>
  <td>${escHtml(e.attackerName || "—")}</td>
  <td>${escHtml(e.defenderName || "—")}</td>
  <td class="${e.type === "gained" ? "cfa-badge-profit" : "cfa-badge-loss"}">${fmt.money(e.amount)}</td>
  <td>${fmt.date(e.timestamp)}</td>
  <td><button class="cfa-btn-sm cfa-del-mug" data-id="${escHtml(e.id)}" style="color:#ef9a9a">Del</button></td>
</tr>`;
            }).join("") || `<tr><td colspan="6" class="cfa-muted" style="padding:12px">No mugging data. Sync from API or add manually.</td></tr>`;

            this._content(`
<div class="cfa-sync-bar">
  <button id="mug-sync" class="cfa-btn">&#x21bb; Sync from API</button>
  <span id="mug-spinner" style="display:none"><span class="cfa-spinner"></span></span>
  <span id="mug-sync-msg" class="cfa-muted"></span>
  <span class="cfa-sync-note">Last sync: ${escHtml(lastSyncStr)}</span>
</div>
<p class="cfa-muted" style="margin:0 0 14px">Syncs attack log and detects mugging results automatically.</p>

<div class="cfa-stats-grid">
  <div class="cfa-stat">
    <div class="cfa-stat-label">Total Gained</div>
    <div class="cfa-stat-value" style="color:#4caf50">${fmt.money(stats.totalGained)}</div>
  </div>
  <div class="cfa-stat">
    <div class="cfa-stat-label">Total Lost</div>
    <div class="cfa-stat-value" style="color:#ef5350">${fmt.money(stats.totalLost)}</div>
  </div>
  <div class="cfa-stat">
    <div class="cfa-stat-label">Net Mugging</div>
    <div class="cfa-stat-value" style="color:${netColor}">${fmt.money(stats.netMugging)}</div>
  </div>
  <div class="cfa-stat">
    <div class="cfa-stat-label">Biggest Single Loss</div>
    <div class="cfa-stat-value" style="color:#ef5350">${stats.biggestLoss ? fmt.money(stats.biggestLoss.amount) : "—"}</div>
    ${stats.biggestLoss ? `<div class="cfa-muted" style="font-size:11px;margin-top:2px">by ${escHtml(stats.biggestLoss.attackerName || "?")}</div>` : ""}
  </div>
  <div class="cfa-stat">
    <div class="cfa-stat-label">Daily Avg Gained</div>
    <div class="cfa-stat-value" style="color:#4caf50">${fmt.money(stats.dailyGained)}</div>
  </div>
  <div class="cfa-stat">
    <div class="cfa-stat-label">Daily Avg Lost</div>
    <div class="cfa-stat-value" style="color:#ef5350">${fmt.money(stats.dailyLost)}</div>
  </div>
</div>

<table class="cfa-table">
  <thead><tr>
    ${th("type","Type")}
    ${th("attackerName","Attacker")}
    ${th("defenderName","Victim")}
    ${th("amount","Amount")}
    ${th("timestamp","Date")}
    <th>Del</th>
  </tr></thead>
  <tbody>${tableRows}</tbody>
</table>
<br>
<button id="mug-export" class="cfa-btn-muted">Export CSV</button>
            `);

            const c = document.getElementById("cfa-content");

            c.querySelectorAll(".cfa-table th[data-sort]").forEach(th2 => {
                th2.addEventListener("click", () => {
                    const key = th2.dataset.sort;
                    if (this._muggingSort.col === key) {
                        this._muggingSort.dir = this._muggingSort.dir === "asc" ? "desc" : "asc";
                    } else {
                        this._muggingSort = { col: key, dir: "desc" };
                    }
                    this._renderMugging();
                });
            });

            c.querySelector("#mug-sync").addEventListener("click", () => this._syncMuggingData());

            c.querySelectorAll(".cfa-del-mug").forEach(btn => {
                btn.addEventListener("click", () => {
                    const all = Store.getMugging().filter(e => e.id !== btn.dataset.id);
                    Store.saveMugging(all);
                    this._renderMugging();
                });
            });

            c.querySelector("#mug-export").addEventListener("click", () => {
                const headers = ["Type","Attacker","Victim","Amount","Date"];
                const rws = Store.getMugging().map(e => [
                    e.type, e.attackerName || "", e.defenderName || "", e.amount, fmt.date(e.timestamp),
                ]);
                exportCSV("cfa_mugging.csv", headers, rws);
            });
        }

        // ── Charts ────────────────────────────────────────────────────────────

        _renderCharts() {
            // Destroy existing charts
            for (const [id, chart] of Object.entries(this._charts)) {
                try { chart.destroy(); } catch {}
            }
            this._charts = {};

            if (typeof Chart === "undefined") {
                this._content(`<div class="cfa-card" style="text-align:center;padding:40px;color:#ef5350">
                    Chart.js not loaded. Check your internet connection or the @require URL.
                </div>`);
                return;
            }

            this._content(`
<div class="cfa-chart-wrap">
  <div class="cfa-chart-title">Daily Cash Flow — Last 30 Days</div>
  <canvas id="cfa-chart-daily" height="120"></canvas>
</div>
<div class="cfa-chart-wrap">
  <div class="cfa-chart-title">Top Items by ROI%</div>
  <canvas id="cfa-chart-roi" height="120"></canvas>
</div>
<div class="cfa-chart-wrap" style="max-width:400px">
  <div class="cfa-chart-title">Spending Breakdown</div>
  <canvas id="cfa-chart-donut" height="200"></canvas>
</div>
            `);

            const range    = this._dateRange;
            const shopAll  = Store.getShop();
            const mktAll   = Store.getMarket();
            const mugAll   = Store.getMugging();

            // Chart defaults
            const chartDefaults = {
                color: "#ddd",
                plugins: { legend: { labels: { color: "#ddd" } } },
            };

            // Chart 1 — Daily Cash Flow
            const daily = Analytics.dailyCashFlow(shopAll, mktAll, mugAll);
            {
                const ctx  = document.getElementById("cfa-chart-daily").getContext("2d");
                const inst = new Chart(ctx, {
                    type: "line",
                    data: {
                        labels:   daily.map(d => d.date.slice(5)),
                        datasets: [
                            { label: "Income",       data: daily.map(d => d.income),      borderColor: "#4caf50", backgroundColor: "rgba(76,175,80,.1)",  tension: .3, fill: true  },
                            { label: "Spending",     data: daily.map(d => d.spending),    borderColor: "#ef5350", backgroundColor: "rgba(239,83,80,.1)",   tension: .3, fill: true  },
                            { label: "Mugging Loss", data: daily.map(d => d.muggingLoss), borderColor: "#f59e0b", backgroundColor: "rgba(245,158,11,.08)", tension: .3, fill: false },
                        ],
                    },
                    options: {
                        ...chartDefaults,
                        plugins: {
                            ...chartDefaults.plugins,
                            legend: { labels: { color: "#ddd" } },
                        },
                        scales: {
                            x: { ticks: { color: "#888", maxTicksLimit: 10 }, grid: { color: "rgba(255,255,255,.07)" } },
                            y: { ticks: { color: "#888", callback: v => "$" + (v / 1e6 > 1 ? (v / 1e6).toFixed(1) + "M" : (v / 1e3).toFixed(0) + "k") }, grid: { color: "rgba(255,255,255,.07)" } },
                        },
                    },
                });
                this._charts["daily"] = inst;
            }

            // Chart 2 — ROI bar
            {
                const shopItems = Analytics.shopROI(Analytics.filterByRange(shopAll, range))
                    .filter(i => i.roi != null)
                    .sort((a, b) => b.roi - a.roi)
                    .slice(0, 10);
                const mktStats  = Analytics.marketStats(Analytics.filterByRange(mktAll, range));
                const mktItems  = mktStats.topItems.filter(i => i.roi != null);
                const combined  = [...shopItems.map(i => ({ itemName: i.itemName, roi: i.roi })), ...mktItems]
                    .sort((a, b) => b.roi - a.roi)
                    .slice(0, 10);
                const ctx  = document.getElementById("cfa-chart-roi").getContext("2d");
                const inst = new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels:   combined.map(i => i.itemName),
                        datasets: [{
                            label: "ROI%",
                            data:  combined.map(i => i.roi),
                            backgroundColor: combined.map(i => i.roi >= 0 ? "rgba(76,175,80,.7)" : "rgba(239,83,80,.7)"),
                            borderRadius: 4,
                        }],
                    },
                    options: {
                        ...chartDefaults,
                        plugins: { legend: { labels: { color: "#ddd" } } },
                        scales: {
                            x: { ticks: { color: "#888" }, grid: { color: "rgba(255,255,255,.07)" } },
                            y: { ticks: { color: "#888", callback: v => v.toFixed(1) + "%" }, grid: { color: "rgba(255,255,255,.07)" } },
                        },
                    },
                });
                this._charts["roi"] = inst;
            }

            // Chart 3 — Spending Doughnut
            {
                const shopF   = Analytics.filterByRange(shopAll, range);
                const mktF    = Analytics.filterByRange(mktAll,  range);
                const shopSpend = shopF.reduce((s, e) => s + (e.buyPriceTotal || 0), 0);
                const mktBuy    = mktF.filter(e => e.type === "buy").reduce((s, e) => s + e.pricePerUnit * e.qty, 0);
                const ctx  = document.getElementById("cfa-chart-donut").getContext("2d");
                const inst = new Chart(ctx, {
                    type: "doughnut",
                    data: {
                        labels:   ["Shop Purchases", "Market Buys"],
                        datasets: [{
                            data:            [shopSpend, mktBuy],
                            backgroundColor: ["#b45309", "#d97706"],
                            borderColor:     "#1a1a1a",
                            borderWidth:     3,
                        }],
                    },
                    options: {
                        ...chartDefaults,
                        plugins: { legend: { labels: { color: "#ddd" } } },
                    },
                });
                this._charts["donut"] = inst;
            }
        }

        // ── Settings ──────────────────────────────────────────────────────────

        _renderSettings() {
            const currentKey  = Store.getApiKey();
            const maskedKey   = currentKey ? currentKey.slice(0, 6) + "••••••••••••••••••••" + currentKey.slice(-4) : "Not set";
            const lastSync    = Store.getLastMugSync();
            const shopCount   = Store.getShop().length;
            const mktCount    = Store.getMarket().length;
            const mugCount    = Store.getMugging().length;

            this._content(`
<div class="cfa-section-title">API Key</div>
<div class="cfa-card" style="margin-bottom:16px">
  <p class="cfa-muted" style="margin:0 0 8px">Current key: <span style="color:#aaa;font-family:monospace">${escHtml(maskedKey)}</span></p>
  <div class="cfa-form-row" style="margin:0 0 8px">
    <div class="cfa-field" style="flex:1">
      <label>New API Key</label>
      <input id="set-key" class="cfa-input" type="password" placeholder="Paste key here" style="width:100%">
