  <td class="${r.totalPL != null && r.totalPL >= 0 ? "cfa-badge-profit" : r.totalPL != null ? "cfa-badge-loss" : "cfa-badge-neutral"}">${r.totalPL != null ? fmt.money(r.totalPL) : "—"}</td>
  <td>
