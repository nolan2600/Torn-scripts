        // ── Shop ROI ──────────────────────────────────────────────────────────

        _renderShop() {
            const range  = this._dateRange;
            const raw    = Analytics.filterByRange(Store.getShop(), range);
            const rows   = Analytics.shopROI(raw);

            // Sort rows
            const { col, dir } = this._shopSort;
            rows.sort((a, b) => {
                let av = a[col], bv = b[col];
                if (av == null) av = dir === "asc" ? Infinity : -Infinity;
                if (bv == null) bv = dir === "asc" ? Infinity : -Infinity;
                return dir === "asc" ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
            });

            const th = (key, label) => {
                const icon = this._shopSort.col === key ? (this._shopSort.dir === "asc" ? " ▲" : " ▼") : "";
                return `<th data-sort="${key}">${label}${icon}</th>`;
            };

            const tableRows = rows.map(r => {
