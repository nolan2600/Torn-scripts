  </div>
  <div id="set-key-msg"></div>
  <p class="cfa-muted" style="margin:8px 0 0">
    Key stored via GM_setValue (Tampermonkey secure storage).<br>
    Used for: mugging sync, market price lookup.
  </p>
</div>

<div class="cfa-section-title">Data Management</div>
<div class="cfa-card" style="margin-bottom:16px">
  <div style="display:flex;flex-wrap:wrap;gap:10px">
    <button id="rst-shop" class="cfa-btn-danger">Reset Shop Data</button>
    <button id="rst-mkt" class="cfa-btn-danger">Reset Market Data</button>
    <button id="rst-mug" class="cfa-btn-danger">Reset Mugging Data</button>
    <button id="rst-all" class="cfa-btn-danger" style="background:#7f1d1d">Reset ALL Data</button>
  </div>
  <div id="set-data-msg" style="margin-top:8px"></div>
</div>

<div class="cfa-section-title">Sync Status</div>
<div class="cfa-card">
  <div class="cfa-stats-bar" style="flex-direction:column;gap:6px">
    <span>Last mugging sync: <b>${escHtml(lastSync ? fmt.dateTime(lastSync) : "Never")}</b></span>
    <span>Shop records: <b>${shopCount}</b></span>
    <span>Market records: <b>${mktCount}</b></span>
    <span>Mugging records: <b>${mugCount}</b></span>
  </div>
</div>
            `);

            const c = document.getElementById("cfa-content");

            // Save key
            c.querySelector("#set-key-save").addEventListener("click", async () => {
                const key = c.querySelector("#set-key").value.trim();
                const msg = c.querySelector("#set-key-msg");
                if (!key) { msg.className = "cfa-msg-error"; msg.textContent = "Enter a key first."; return; }
                msg.textContent = "Validating..."; msg.className = "";
                try {
                    this.api.setKey(key);
                    const profile = await this.api.fetchProfile();
                    const userId  = profile?.player_id || profile?.id || profile?.ID || "";
                    Store.saveApiKey(key);
                    if (userId) { Store.saveMyUserId(userId); this.api.myUserId = String(userId); }
                    this._authed = true;
                    msg.className = "cfa-msg-success"; msg.textContent = "API key saved and validated!";
                    c.querySelector("#set-key").value = "";
                    setTimeout(() => this._renderSettings(), 800);
                } catch (err) {
                    msg.className = "cfa-msg-error"; msg.textContent = "Failed: " + (err.message || "Invalid key");
                }
            });

            // Clear key
            c.querySelector("#set-key-clear").addEventListener("click", () => {
                if (!confirm("Clear stored API key?")) return;
                Store.saveApiKey("");
                this.api.setKey("");
                const msg = c.querySelector("#set-key-msg");
                msg.className = "cfa-msg-success"; msg.textContent = "API key cleared.";
                setTimeout(() => this._renderSettings(), 500);
            });

            // Reset buttons
            const dataMsg = c.querySelector("#set-data-msg");
            const resetBtn = (id, label, fn) => {
                c.querySelector(id).addEventListener("click", () => {
                    if (!confirm(`Are you sure you want to reset ${label}? This cannot be undone.`)) return;
                    fn();
                    dataMsg.className = "cfa-msg-success";
                    dataMsg.textContent = label + " reset successfully.";
                    setTimeout(() => this._renderSettings(), 500);
                });
            };
            resetBtn("#rst-shop", "Shop Data",    () => Store.resetShop());
            resetBtn("#rst-mkt",  "Market Data",  () => Store.resetMarket());
            resetBtn("#rst-mug",  "Mugging Data", () => Store.resetMugging());
            c.querySelector("#rst-all").addEventListener("click", () => {
                if (!confirm("RESET ALL DATA? This will permanently delete all shop, market, and mugging records.")) return;
                Store.resetShop(); Store.resetMarket(); Store.resetMugging();
                dataMsg.className = "cfa-msg-success"; dataMsg.textContent = "All data reset.";
                setTimeout(() => this._renderSettings(), 500);
            });
        }

        // ── Mugging Sync ──────────────────────────────────────────────────────

        async _syncMuggingData() {
            if (this._syncing) return;
            const key = Store.getApiKey();
            const msgEl = document.getElementById("mug-sync-msg");
            const spinner = document.getElementById("mug-spinner");
            const syncBtn = document.getElementById("mug-sync");

            if (!key) {
                if (msgEl) { msgEl.style.color = "#ef5350"; msgEl.textContent = "API key required. Set it in Settings."; }
                return;
            }

            this._syncing = true;
            if (syncBtn) syncBtn.disabled = true;
            if (spinner) spinner.style.display = "inline-block";
            if (msgEl)   { msgEl.style.color = "#888"; msgEl.textContent = "Fetching attacks..."; }

            try {
                // Ensure we have userId
                if (!this.api.myUserId) {
                    const profile = await this.api.fetchProfile();
                    const uid = profile?.player_id || profile?.id || profile?.ID || "";
                    if (uid) { Store.saveMyUserId(uid); this.api.myUserId = String(uid); }
                }

                const myId       = String(this.api.myUserId || "");
                const lastSync   = Store.getLastMugSync() || null;
                const data       = await this.api.fetchAttacks(100, lastSync || null);

                // The v2 API returns attacks in various shapes
                const attackList = data?.attacks || data?.items || Object.values(data?.attacks || {}) || [];

                const newEntries = [];
                for (const atk of attackList) {
                    const result = atk.result || atk.result_name || atk.outcome || "";
                    const isMug  = /mug/i.test(result);
                    if (!isMug) continue;

                    const amount       = atk.money_mugged || atk.cash_mugged || atk.stealthy_attack || 0;
                    const ts           = atk.timestamp_ended || atk.ended || atk.timestamp || 0;
                    const attackerId   = String(atk.attacker_id || atk.attackerId || "");
                    const attackerName = atk.attacker_name || atk.attackerName || attackerId || "Unknown";
                    const defenderId   = String(atk.defender_id || atk.defenderId || "");
                    const defenderName = atk.defender_name || atk.defenderName || defenderId || "Unknown";
                    const atkId        = String(atk.id || atk.attack_id || `${attackerId}_${ts}`);

                    // Determine if we gained or lost
                    let type;
                    if (myId && attackerId === myId) type = "gained";
                    else if (myId && defenderId === myId) type = "lost";
                    else type = amount > 0 ? "gained" : "lost";

                    newEntries.push({
                        id: atkId,
                        type,
                        attackerName,
                        defenderName,
                        amount: Math.abs(amount),
                        timestamp: ts,
                    });
                }

                Store.mergeMugging(newEntries);
                Store.setLastMugSync(Math.floor(Date.now() / 1000));

                if (msgEl) { msgEl.style.color = "#4caf50"; msgEl.textContent = `Synced ${newEntries.length} new mugging event(s).`; }
            } catch (err) {
                if (msgEl) { msgEl.style.color = "#ef5350"; msgEl.textContent = "Sync failed: " + (err.message || "unknown error"); }
            } finally {
                this._syncing = false;
                if (syncBtn) syncBtn.disabled = false;
                if (spinner) spinner.style.display = "none";
                // Re-render after a short delay to reflect new data
                setTimeout(() => { if (this.activeTab === "mugging") this._renderMugging(); }, 600);
            }
        }
    }

    // =========================================================================
    // SECTION 8 — Main
    // =========================================================================

    async function main() {
        const storedKey = Store.getApiKey();
        const api = new TornAPI(storedKey || "");
        const ui  = new UI(api);
        ui.inject();

        if (storedKey) {
            ui._authed = true;
            // Restore cached userId if available
            const cachedId = Store.getMyUserId();
            if (cachedId) api.myUserId = cachedId;
        }
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", main);
    } else {
        main();
    }

})();
