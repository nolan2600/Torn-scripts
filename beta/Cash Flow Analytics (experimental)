                        this._shopSort.dir = this._shopSort.dir === "asc" ? "desc" : "asc";
                    } else {
                        this._shopSort = { col: key, dir: "desc" };
                    }
                    this._renderShop();
                });
            });

            // Fetch market price
            c.querySelector("#sh-fetch-mkt").addEventListener("click", async () => {
                const itemId = parseInt(c.querySelector("#sh-id").value);
                const valEl  = c.querySelector("#sh-mkt-val");
                const key    = Store.getApiKey();
                if (!key) { valEl.style.color = "#ef5350"; valEl.textContent = "API key required."; return; }
                if (!itemId) { valEl.style.color = "#ef5350"; valEl.textContent = "Enter Item ID first."; return; }
                valEl.style.color = "#888"; valEl.textContent = "Fetching...";
                const price = await this.api.fetchMarketItem(itemId);
                if (price != null) {
                    c.querySelector("#sh-sell").value = price;
                    valEl.style.color = ACCENT;
