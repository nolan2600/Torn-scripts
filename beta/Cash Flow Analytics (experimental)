    // =========================================================================
    // SECTION 1 — Constants & Config
    // =========================================================================

    const VERSION       = "1.0.0";
    const API_BASE      = "https://api.torn.com/v2";
    const API_DELAY_MS  = 750;
    const ACCENT        = "#f59e0b";

    const LS = {
        shop:        "cfa_shop",
        market:      "cfa_market",
        mugging:     "cfa_mugging",
        settings:    "cfa_settings",
        lastMugSync: "cfa_lastMugSync",
    };

    const GM_KEY_APIKEY = "cfa_api_key";
    const GM_KEY_MYID   = "cfa_my_user_id";

    // =========================================================================
    // SECTION 2 — Storage Layer
    // =========================================================================

    const Store = {
        // --- Shop ---
        getShop() {
            try { return JSON.parse(localStorage.getItem(LS.shop) || "[]"); } catch { return []; }
        },
        saveShop(arr) { localStorage.setItem(LS.shop, JSON.stringify(arr)); },
        addShop(entry) { const a = this.getShop(); a.push(entry); this.saveShop(a); },
        resetShop() { localStorage.removeItem(LS.shop); },

        // --- Market ---
        getMarket() {
            try { return JSON.parse(localStorage.getItem(LS.market) || "[]"); } catch { return []; }
        },
        saveMarket(arr) { localStorage.setItem(LS.market, JSON.stringify(arr)); },
        addMarket(entry) { const a = this.getMarket(); a.push(entry); this.saveMarket(a); },
        resetMarket() { localStorage.removeItem(LS.market); },

        // --- Mugging ---
        getMugging() {
            try { return JSON.parse(localStorage.getItem(LS.mugging) || "[]"); } catch { return []; }
        },
        saveMugging(arr) { localStorage.setItem(LS.mugging, JSON.stringify(arr)); },
        mergeMugging(newEntries) {
            const existing = this.getMugging();
            const ids = new Set(existing.map(e => e.id));
            const merged = [...existing];
            for (const e of newEntries) {
                if (!ids.has(e.id)) { merged.push(e); ids.add(e.id); }
            }
            this.saveMugging(merged);
        },
        resetMugging() { localStorage.removeItem(LS.mugging); },

        // --- Settings ---
        getSettings() {
            try { return JSON.parse(localStorage.getItem(LS.settings) || "{}"); } catch { return {}; }
        },
        saveSettings(s) { localStorage.setItem(LS.settings, JSON.stringify(s)); },

        // --- API Key (GM secure storage) ---
        getApiKey()      { return GM_getValue(GM_KEY_APIKEY, ""); },
        saveApiKey(k)    { GM_setValue(GM_KEY_APIKEY, k); },

        // --- My User ID (GM secure storage) ---
        getMyUserId()    { return GM_getValue(GM_KEY_MYID, ""); },
        saveMyUserId(id) { GM_setValue(GM_KEY_MYID, String(id)); },

        // --- Last Mugging Sync ---
        getLastMugSync() { return parseFloat(localStorage.getItem(LS.lastMugSync) || "0") || 0; },
        setLastMugSync(ts) { localStorage.setItem(LS.lastMugSync, String(ts)); },
    };

    // =========================================================================
    // SECTION 3 — Torn API Class
    // =========================================================================

    class TornAPI {
        constructor(key) {
            this.key      = key;
            this._lastReq = 0;
            this.myUserId = Store.getMyUserId() || null;
        }

        setKey(key) { this.key = key; }

        async _rateLimit() {
            const now  = Date.now();
            const wait = API_DELAY_MS - (now - this._lastReq);
            if (wait > 0) await new Promise(r => setTimeout(r, wait));
            this._lastReq = Date.now();
        }

        async _gmGet(url) {
            return new Promise((resolve, reject) => {
                GM_xmlhttpRequest({
                    method:  "GET",
                    url,
                    onload:  r => resolve({ status: r.status, text: r.responseText }),
                    onerror: e => reject(new Error("Network error: " + JSON.stringify(e))),
                    ontimeout: () => reject(new Error("Request timed out")),
                    timeout: 15000,
                });
            });
        }

        async _get(path, params = {}) {
            await this._rateLimit();
            const url = new URL(API_BASE + path);
            for (const [k, v] of Object.entries(params)) {
                if (v != null) url.searchParams.set(k, String(v));
            }
            url.searchParams.set("key", this.key);
            const { status, text } = await this._gmGet(url.toString());
            if (status < 200 || status >= 300) throw new Error("HTTP " + status);
            let data;
            try { data = JSON.parse(text); } catch { throw new Error("Invalid JSON response"); }
            if (data && data.error) throw new Error(data.error.error || data.error.code || "API error");
            return data;
        }

        async fetchProfile() {
            return this._get("/user/profile");
        }

        async fetchAttacks(limit = 100, fromTimestamp = null) {
            const params = { limit, sort: "DESC" };
            if (fromTimestamp) params.from = fromTimestamp;
            return this._get("/user/attacks", params);
        }

        async fetchMarketItem(itemId) {
            try {
                const data = await this._get(`/market/${itemId}/listings`, { type: "bazaar" });
                const listings = data?.listings || data?.bazaar || [];
                if (!listings.length) return null;
                const prices = listings
                    .map(l => l.price || l.cost || 0)
                    .filter(p => p > 0)
                    .sort((a, b) => a - b);
                if (!prices.length) return null;
                // Return median price
                const mid = Math.floor(prices.length / 2);
                return prices.length % 2 === 0
                    ? Math.round((prices[mid - 1] + prices[mid]) / 2)
                    : prices[mid];
            } catch {
                return null;
            }
        }
    }

    // =========================================================================
    // SECTION 4 — Analytics (pure functions)
    // =========================================================================

    const Analytics = {};

    Analytics.filterByRange = function (items, range) {
        if (!range || range === "all") return items;
        const now = Date.now() / 1000;
        let cutoff;
        if (range === "today") {
            const d = new Date(); d.setHours(0, 0, 0, 0);
            cutoff = d.getTime() / 1000;
        } else if (range === "7d") {
            cutoff = now - 7 * 86400;
        } else if (range === "30d") {
            cutoff = now - 30 * 86400;
        } else {
            return items;
        }
        return items.filter(i => (i.timestamp || 0) >= cutoff);
    };

    Analytics.shopROI = function (shopData) {
        const groups = {};
        for (const e of shopData) {
            const key = e.itemName || "Unknown";
            if (!groups[key]) groups[key] = { itemName: key, itemId: e.itemId ?? null, entries: [] };
            groups[key].entries.push(e);
        }
        return Object.values(groups).map(g => {
            const totalQty     = g.entries.reduce((s, e) => s + (e.qty || 0), 0);
            const totalSpent   = g.entries.reduce((s, e) => s + (e.buyPriceTotal || 0), 0);
            const avgBuyPrice  = totalQty > 0 ? totalSpent / totalQty : 0;
            // Use the most recently set sellPrice
            const withSell     = g.entries.filter(e => e.sellPricePerUnit != null);
            const sellPrice    = withSell.length > 0
                ? withSell[withSell.length - 1].sellPricePerUnit
                : null;
            const roi          = (sellPrice != null && avgBuyPrice > 0)
                ? ((sellPrice - avgBuyPrice) / avgBuyPrice * 100)
                : null;
            const totalPL      = (sellPrice != null)
                ? (sellPrice - avgBuyPrice) * totalQty
                : null;
            return { itemName: g.itemName, itemId: g.itemId, totalQty, avgBuyPrice, sellPrice, roi, totalSpent, totalPL };
        });
    };

    Analytics.marketStats = function (marketData) {
        const byItem = {};
        let buyCount = 0, sellCount = 0;
        for (const e of marketData) {
            const key = e.itemName || "Unknown";
            if (!byItem[key]) byItem[key] = { buys: [], sells: [] };
            if (e.type === "buy") { byItem[key].buys.push(e); buyCount++; }
            else                  { byItem[key].sells.push(e); sellCount++; }
        }
        let totalProfit = 0, totalVolume = 0;
        const itemProfits = [];
        for (const [name, { buys, sells }] of Object.entries(byItem)) {
            const sellTotal = sells.reduce((s, e) => s + e.pricePerUnit * e.qty, 0);
            const buyTotal  = buys.reduce((s, e) => s + e.pricePerUnit * e.qty, 0);
            const sellQty   = sells.reduce((s, e) => s + e.qty, 0);
            const buyQty    = buys.reduce((s, e) => s + e.qty, 0);
            const profit    = sells.length > 0 && buys.length > 0
                ? sellTotal - buyTotal
                : 0;
            totalVolume += sellTotal + buyTotal;
            totalProfit += (sellTotal - buyTotal);
            const avgSell  = sellQty > 0 ? sellTotal / sellQty : 0;
            const avgBuy   = buyQty  > 0 ? buyTotal  / buyQty  : 0;
            const roi      = (avgBuy > 0 && avgSell > 0)
                ? ((avgSell - avgBuy) / avgBuy * 100)
                : null;
            itemProfits.push({ itemName: name, profit, roi });
        }
        const topItems = itemProfits.sort((a, b) => b.profit - a.profit).slice(0, 5);
        return { totalProfit, totalVolume, topItems, buyCount, sellCount };
    };

    Analytics.muggingStats = function (muggingData) {
        if (!muggingData.length) {
            return { totalGained: 0, totalLost: 0, netMugging: 0, biggestLoss: null, biggestGain: null, dailyGained: 0, dailyLost: 0 };
        }
        const gained = muggingData.filter(e => e.type === "gained");
        const lost   = muggingData.filter(e => e.type === "lost");
        const totalGained = gained.reduce((s, e) => s + (e.amount || 0), 0);
        const totalLost   = lost.reduce((s, e) => s + (e.amount || 0), 0);
        const netMugging  = totalGained - totalLost;
        const biggestLoss = lost.length  ? lost.reduce((a, b)  => b.amount > a.amount ? b : a)  : null;
        const biggestGain = gained.length ? gained.reduce((a, b) => b.amount > a.amount ? b : a) : null;
        const timestamps  = muggingData.map(e => e.timestamp || 0).filter(t => t > 0);
        const minTs       = timestamps.length ? Math.min(...timestamps) : 0;
        const maxTs       = timestamps.length ? Math.max(...timestamps) : 0;
        const daySpan     = Math.max(1, (maxTs - minTs) / 86400);
        return {
            totalGained, totalLost, netMugging, biggestLoss, biggestGain,
            dailyGained: totalGained / daySpan,
            dailyLost:   totalLost   / daySpan,
        };
    };

    Analytics.overview = function (shopData, marketData, muggingData) {
        const allTs = [
            ...shopData.map(e => e.timestamp),
            ...marketData.map(e => e.timestamp),
            ...muggingData.map(e => e.timestamp),
        ].filter(t => t > 0);
        const minTs    = allTs.length ? Math.min(...allTs) : 0;
        const maxTs    = allTs.length ? Math.max(...allTs) : 0;
        const daySpan  = Math.max(1, (maxTs - minTs) / 86400);

        const totalShopSpend     = shopData.reduce((s, e) => s + (e.buyPriceTotal || 0), 0);
        const buys               = marketData.filter(e => e.type === "buy");
        const sells              = marketData.filter(e => e.type === "sell");
        const totalMarketBuy     = buys.reduce((s, e)  => s + e.pricePerUnit * e.qty, 0);
        const totalMarketSell    = sells.reduce((s, e) => s + e.pricePerUnit * e.qty, 0);
        const totalMarketProfit  = totalMarketSell - totalMarketBuy;
        const mugStats           = Analytics.muggingStats(muggingData);
        const totalMuggingGained = mugStats.totalGained;
        const totalMuggingLost   = mugStats.totalLost;
        const netCashFlow        = totalMarketProfit + totalMuggingGained - totalMuggingLost - totalShopSpend;
        const totalMovement      = totalShopSpend + totalMarketBuy + totalMarketSell + totalMuggingGained + totalMuggingLost;
        const cashEfficiency     = (netCashFlow / Math.max(1, totalMovement)) * 100;
        const dailyAvgIncome     = (totalMarketSell + totalMuggingGained) / daySpan;
        const dailyAvgSpending   = (totalShopSpend  + totalMarketBuy)     / daySpan;

        // Top 5 profitable items (shop + market combined)
        const shopItems = Analytics.shopROI(shopData).map(i => ({
            itemName: i.itemName, totalPL: i.totalPL ?? 0, roi: i.roi ?? 0,
        }));
        const mktStats  = Analytics.marketStats(marketData);
        const mktItems  = mktStats.topItems.map(i => ({
            itemName: i.itemName, totalPL: i.profit, roi: i.roi ?? 0,
        }));
        const combined  = [...shopItems, ...mktItems]
            .sort((a, b) => b.totalPL - a.totalPL)
            .slice(0, 5);

        return {
            totalShopSpend, totalMarketBuy, totalMarketSell, totalMarketProfit,
            totalMuggingGained, totalMuggingLost, netCashFlow, cashEfficiency,
            dailyAvgIncome, dailyAvgSpending, topProfitableItems: combined,
        };
    };

    Analytics.dailyCashFlow = function (shopData, marketData, muggingData) {
        const days = [];
        const now  = new Date();
        for (let i = 29; i >= 0; i--) {
            const d = new Date(now);
            d.setDate(d.getDate() - i);
            d.setHours(0, 0, 0, 0);
            days.push(d);
        }
        return days.map(day => {
            const dayStart = day.getTime() / 1000;
            const dayEnd   = dayStart + 86400;
            const inRange  = e => (e.timestamp || 0) >= dayStart && (e.timestamp || 0) < dayEnd;
            const income = marketData.filter(e => e.type === "sell" && inRange(e))
                .reduce((s, e) => s + e.pricePerUnit * e.qty, 0)
                + muggingData.filter(e => e.type === "gained" && inRange(e))
                    .reduce((s, e) => s + (e.amount || 0), 0);
            const spending = shopData.filter(inRange)
                .reduce((s, e) => s + (e.buyPriceTotal || 0), 0)
                + marketData.filter(e => e.type === "buy" && inRange(e))
                    .reduce((s, e) => s + e.pricePerUnit * e.qty, 0);
            const muggingLoss = muggingData.filter(e => e.type === "lost" && inRange(e))
                .reduce((s, e) => s + (e.amount || 0), 0);
            const dateStr = day.toISOString().slice(0, 10);
            return { date: dateStr, income, spending, muggingLoss };
        });
    };

    // =========================================================================
    // SECTION 5 — CSV Export
    // =========================================================================

    function exportCSV(filename, headers, rows) {
        const csv = [headers, ...rows]
            .map(r => r.map(v => `"${String(v ?? "").replace(/"/g, '""')}"`).join(","))
            .join("\n");
        const blob = new Blob([csv], { type: "text/csv" });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement("a");
        a.href     = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
    }

