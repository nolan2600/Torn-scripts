            this._dateRange   = "all";
            this._shopSort    = { col: "roi",       dir: "desc" };
            this._marketSort  = { col: "timestamp", dir: "desc" };
            this._muggingSort = { col: "timestamp", dir: "desc" };
            this._syncing     = false;
            this._charts      = {};
        }

        inject() {
            injectCSS();

            // Overlay
            this._overlay = document.createElement("div");
            this._overlay.id = "cfa-overlay";
            document.body.appendChild(this._overlay);

            // Panel
            this._panel = document.createElement("div");
            this._panel.id = "cfa-panel";
            this._panel.innerHTML = `
