                Attacks access (wins/respect): <b style="color:${this.access.attacks?"#66bb6a":"#ef5350"}">${this.access.attacks?"OK":"unavailable"}</b><br>
                A <b>Full Access</b> key unlocks everything; Limited adds attacks; Public gives stat snapshots only.
            </div>`;

            return `
                <div class="ta-settings-hd">🔑 API Key</div>
                ${pdaNote}
                ${!KeyResolver.isPDAKey() ? `
                <div class="ta-field">
                    <label>Torn API Key</label>
                    <div class="ta-key-row">
                        <input type="text" class="ta-input" id="ta-s-key" value="${escHtml(key)}" maxlength="16" autocomplete="off" data-lpignore="true" />
                        <button class="ta-btn ta-btn-primary ta-btn-sm" id="ta-s-key-save">Save</button>
                    </div>
                    <div id="ta-s-key-msg" class="ta-save-status"></div>
                </div>` : ""}
                ${accessNote}

                <div class="ta-settings-hd">📊 Track Sources</div>
                <div class="ta-check-row">
                    <input type="checkbox" id="ta-s-mug"  ${s.includeMuggings?"checked":""} />
                    <label for="ta-s-mug">💰 <strong>Muggings</strong> — money stolen from attacks (from activity log)</label>
                </div>
                <div class="ta-check-row">
                    <input type="checkbox" id="ta-s-bty"  ${s.includeBounties?"checked":""} />
                    <label for="ta-s-bty">🎯 <strong>Bounties</strong> — payouts collected for killing bounty targets</label>
                </div>
                <div class="ta-check-row">
                    <input type="checkbox" id="ta-s-atk"  ${s.includeAttacks?"checked":""} />
                    <label for="ta-s-atk">⚔️ <strong>Attack Wins</strong> — wins &amp; respect (no cash value)</label>
                </div>

                <div class="ta-settings-hd">⚙️ Sync & Data</div>
                <div class="ta-field">
                    <label>Auto-sync every (seconds, min 60)</label>
                    <input type="number" class="ta-input" id="ta-s-refresh" value="${s.refreshSec}" min="60" max="3600" style="width:120px" />
                </div>
                <div class="ta-field">
                    <label>Keep data for (days, max 365)</label>
                    <input type="number" class="ta-input" id="ta-s-retain" value="${s.retentionDays}" min="7" max="365" style="width:120px" />
                </div>

                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px">
                    <button class="ta-btn ta-btn-primary" id="ta-s-save">Save Settings</button>
                    <button class="ta-btn ta-btn-muted ta-btn-sm" id="ta-s-refetch">🔄 Re-fetch History</button>
                    <button class="ta-btn ta-btn-muted ta-btn-sm" id="ta-s-export">⬇ Export CSV</button>
                    <button class="ta-btn ta-btn-danger ta-btn-sm" id="ta-s-clear">🗑 Clear All Data</button>
                </div>
                <div id="ta-s-msg" class="ta-save-status"></div>
                <div style="font-size:10px;color:#555;margin-top:10px">
                    Version ${VERSION} · Platform: ${IS_PDA ? "Torn PDA" : "Desktop"} · ${loadEvents().length} events stored · ${loadSnapshots().length} snapshots
                </div>`;
        }

        _wireSettings(body) {
            const msg = body.querySelector("#ta-s-msg");

            const keySave = body.querySelector("#ta-s-key-save");
            if (keySave) {
                keySave.addEventListener("click", async () => {
                    const k    = body.querySelector("#ta-s-key").value.trim();
                    const kMsg = body.querySelector("#ta-s-key-msg");
                    if (!/^[A-Za-z0-9]{16}$/.test(k)) { kMsg.className = "ta-save-status ta-save-err"; kMsg.textContent = "Must be 16 alphanumeric characters."; return; }
                    keySave.disabled = true;
                    kMsg.className = "ta-save-status ta-save-info"; kMsg.textContent = "Validating…";
                    try {
                        const api  = new TornAPI(k);
                        const prof = await api.validateKey();
                        if (!prof) throw new Error("Key rejected.");
                        KeyResolver.saveKey(k);
                        this.myId = prof.id || prof.player_id;
                        try { localStorage.setItem(LS.myId, String(this.myId)); } catch {}
                        // New key — re-probe what it can read on next sync
                        this.access = { attacks:true, log:true };
                        saveAccess(this.access);
                        kMsg.className = "ta-save-status ta-save-ok";
                        kMsg.textContent = `✓ Valid — ${prof.name || "Player"} [${this.myId}] — syncing…`;
                        this.syncData();
                    } catch (e) {
                        kMsg.className = "ta-save-status ta-save-err"; kMsg.textContent = e.message || "Validation failed.";
                    } finally { keySave.disabled = false; }
                });
            }

            body.querySelector("#ta-s-save").addEventListener("click", () => {
                this.settings = {
                    ...this.settings,
                    includeMuggings: body.querySelector("#ta-s-mug").checked,
                    includeBounties: body.querySelector("#ta-s-bty").checked,
                    includeAttacks:  body.querySelector("#ta-s-atk").checked,
                    refreshSec:      Math.max(60, parseInt(body.querySelector("#ta-s-refresh").value, 10) || 300),
                    retentionDays:   Math.min(365, Math.max(7, parseInt(body.querySelector("#ta-s-retain").value, 10) || 90)),
                };
                saveSettings(this.settings);
                msg.className = "ta-save-status ta-save-ok";
                msg.textContent = "✓ Settings saved.";
                setTimeout(() => { msg.textContent = ""; }, 2000);
            });

            // Re-fetch history (reset cursors so next sync pulls 90 days)
            body.querySelector("#ta-s-refetch").addEventListener("click", () => {
                [LS.lastAttackTs, LS.lastLogTs].forEach(k => { try { localStorage.removeItem(k); } catch {} });
                // Re-probe access too, in case the key was upgraded
                this.access = { attacks:true, log:true };
                saveAccess(this.access);
                msg.className = "ta-save-status ta-save-ok";
                msg.textContent = "✓ Cursors reset — click ⟳ Sync to re-fetch 90 days of history.";
                setTimeout(() => { msg.textContent = ""; }, 4000);
            });

            body.querySelector("#ta-s-export").addEventListener("click", () => {
                const events = loadEvents();
                const csv    = ["type,amount,label,timestamp,date"].concat(
                    events.map(e => `${e.type},${e.amount||0},"${(e.label||"").replace(/"/g,'""')}",${new Date(e.ts*1000).toISOString()},${fmt.date(e.ts)}`)
                ).join("\n");
                const blob = new Blob([csv], {type:"text/csv"});
                const url  = URL.createObjectURL(blob);
                const a    = document.createElement("a");
                a.href = url; a.download = `torn-analytics-${Date.now()}.csv`; a.click();
                URL.revokeObjectURL(url);
            });

            body.querySelector("#ta-s-clear").addEventListener("click", () => {
                if (!confirm("Clear ALL tracked profit data? This cannot be undone.")) return;
                [LS.events, LS.snapshots, LS.lastAttackTs, LS.lastLogTs, LS.lastSnapTs, LS.myId, LS.statsCache, LS.access, LS.names].forEach(k => {
                    try { localStorage.removeItem(k); } catch {}
                });
                this.myId = null;
                this.cachedStats = null;
                this.syncReport = null;
                this.lastSync = 0;
                this.access = { attacks:true, log:true };
                msg.className = "ta-save-status ta-save-err";
                msg.textContent = "All data cleared.";
                this._tickFooter();
                setTimeout(() => this._renderBody(), 1500);
            });
        }

        // ── Sync ──────────────────────────────────────────────
        _friendlyErr(e) {
            if (e.tornCode === 2)  return "Invalid API key — check it in Settings.";
            if (e.tornCode === 5)  return "Rate limited by Torn — will retry later.";
            if (e.tornCode === 16) return "API key access level too low.";
            return e.message || "Sync failed";
        }

        async syncData() {
            if (this.syncing) return;
            const key = KeyResolver.resolveTornKey();
            if (!key) return;
            const api = new TornAPI(key);

            this.syncing = true; this.lastErr = null;
            this._tickFooter();

            try {
                if (!this.myId) {
                    const prof = await api.validateKey();
                    if (!prof) throw new Error("API key invalid or expired.");
                    this.myId = prof.id || prof.player_id;
                    try { localStorage.setItem(LS.myId, String(this.myId)); } catch {}
                }

                const report = { attacks: 0, mugs: 0, bounties: 0 };
                const newEvents = [];
                let nameMap = new Map();

                // ── Attacks (needs Limited key) — wins, respect, target names
                const lastAtkTs = getTs(LS.lastAttackTs);
                try {
                    const attacks = await api.fetchAttacks(lastAtkTs > 0 ? lastAtkTs + 1 : 0);
                    report.attacks = attacks.length;
                    const r = processAttacks(attacks, this.myId);
                    newEvents.push(...r.events);
                    nameMap = r.nameMap;
                    const maxTs = Math.max(0, ...attacks.map(a => a.timestamp_ended || 0));
                    if (maxTs > lastAtkTs) setTs(LS.lastAttackTs, maxTs);
                    if (!this.access.attacks) { this.access.attacks = true; saveAccess(this.access); }
                } catch (e) {
                    if (e.tornCode === 16 || e.tornCode === 7) { this.access.attacks = false; saveAccess(this.access); }
                    else throw e;
                }

                // ── Activity log (needs Full Access key) — THE money source
                const lastLogTs = getTs(LS.lastLogTs);
                try {
                    const entries = await api.fetchLog(lastLogTs > 0 ? lastLogTs + 1 : 0);
                    const logEvents = processLog(entries, nameMap);
                    report.mugs     = logEvents.filter(e => e.type === EVENT_TYPES.MUGGING).length;
                    report.bounties = logEvents.filter(e => e.type === EVENT_TYPES.BOUNTY).length;
                    newEvents.push(...logEvents);
                    const maxTs = Math.max(0, ...entries.map(e => e.timestamp || 0));
                    if (maxTs > lastLogTs) setTs(LS.lastLogTs, maxTs);
                    if (!this.access.log) { this.access.log = true; saveAccess(this.access); }
                } catch (e) {
                    if (e.tornCode === 16 || e.tornCode === 7) { this.access.log = false; saveAccess(this.access); }
                    else throw e;
                }

                this.syncReport = report;

                // ── Merge, resolve names, save ─────────────────
                const merged = mergeEvents(loadEvents(), newEvents);

                // Fold names from attack history into the persistent cache
                const names = loadNames();
                for (const [id, nm] of nameMap) names[String(id)] = nm;

                // Log entries only carry IDs — look up unknown names via the
                // API (basic selection, any key level), a batch per sync.
                const unresolved = [...new Set(
                    merged.filter(ev => {
                        const tid = ev.meta && ev.meta.targetId;
                        return tid && !names[String(tid)];
                    }).map(ev => String(ev.meta.targetId))
                )].slice(0, 20);
                for (const id of unresolved) {
                    try {
                        const b = await api.fetchBasic(id);
                        if (b && b.name) names[id] = b.name;
                    } catch (e) {
                        if (e.tornCode === 5) break; // rate limited — finish next sync
                    }
                }
                saveNames(names);

                // Apply every known name to events and labels
                for (const ev of merged) {
                    const tid = ev.meta && ev.meta.targetId;
                    if (!tid) continue;
                    const nm = names[String(tid)];
                    if (nm && ev.meta.targetName !== nm) {
