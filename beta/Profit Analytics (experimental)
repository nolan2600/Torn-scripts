`;
        document.head.appendChild(s);
    }

    // ── UI ─────────────────────────────────────────────────────
    class AnalyticsUI {
        constructor() {
            this._panel      = null;
            this._overlay    = null;
            this.tab         = "overview";
            this.period      = "week";
            this.settings    = loadSettings();
            this.syncing     = false;
            this.lastSync    = 0;
            this.lastErr     = null;
            this.myId        = parseInt(localStorage.getItem(LS.myId) || "0", 10) || null;
            this._ticker     = null;
            this._syncTmr    = null;
            this.syncReport  = null;
            this.cachedStats = loadStatsCache(); // survives page reloads
            this.access      = loadAccess();     // which API selections this key can read
        }

        init() { injectCSS(); }

        toggle(open) {
            const isOpen = open != null ? open : !(this._panel && this._panel.classList.contains("ta-open"));
            if (isOpen) this._open(); else this._close();
        }

        _open() {
            injectCSS();
            if (!this._panel) this._build();
            this._panel.classList.add("ta-open");
            this._overlay.classList.add("ta-open");
            this._renderBody();
            this._startTicker();
            // Auto-sync on open if stale
            const key = KeyResolver.resolveTornKey();
            if (key && (Date.now() - this.lastSync) > this.settings.refreshSec * 1000) {
                this.syncData();
            }
        }

        _close() {
            if (this._panel)   this._panel.classList.remove("ta-open");
            if (this._overlay) this._overlay.classList.remove("ta-open");
            this._stopTicker();
        }

        _build() {
            const overlay = document.createElement("div");
            overlay.id = "ta-overlay";
            overlay.addEventListener("click", () => this._close());
            document.body.appendChild(overlay);
            this._overlay = overlay;

            const panel = document.createElement("div");
            panel.id = "ta-panel";
            panel.innerHTML = `
                <div id="ta-header">
                    <h2>📊 Profit Analytics <span class="ta-ver">v${VERSION}</span></h2>
                    <button id="ta-close" title="Close">✕</button>
                </div>
                <div id="ta-tabs">
                    <button class="ta-tab active" data-tab="overview">Overview</button>
                    <button class="ta-tab" data-tab="sources">By Source</button>
                    <button class="ta-tab" data-tab="top">Top Events</button>
                    <button class="ta-tab" data-tab="trends">Trends</button>
                    <button class="ta-tab" data-tab="settings">Settings</button>
                </div>
                <div id="ta-body"></div>
                <div id="ta-footer">
                    <span id="ta-status-txt">—</span>
                    <button class="ta-btn ta-btn-primary ta-btn-sm" id="ta-sync-btn">⟳ Sync</button>
                </div>`;
            document.body.appendChild(panel);
            this._panel = panel;

            panel.querySelector("#ta-close").addEventListener("click", () => this._close());
            panel.querySelectorAll(".ta-tab").forEach(t =>
                t.addEventListener("click", () => { this.tab = t.dataset.tab; this._syncTabs(); this._renderBody(); })
            );
            panel.querySelector("#ta-sync-btn").addEventListener("click", () => this.syncData());
        }

        _syncTabs() {
            this._panel.querySelectorAll(".ta-tab").forEach(t =>
                t.classList.toggle("active", t.dataset.tab === this.tab)
            );
        }

        _startTicker() {
            if (this._ticker) return;
            this._ticker = setInterval(() => this._tickFooter(), 5000);
        }
        _stopTicker() { if (this._ticker) { clearInterval(this._ticker); this._ticker = null; } }

        _tickFooter() {
            const el = this._panel && this._panel.querySelector("#ta-status-txt");
            if (!el) return;
            if (this.syncing) { el.textContent = "⟳ Syncing…"; return; }
            if (this.lastErr) { el.textContent = `❌ ${this.lastErr}`; return; }
            if (this.lastSync > 0) {
                const events = loadEvents();
                const r = this.syncReport;
                const detail = r ? ` · +${r.mugs} mug${r.mugs===1?"":"s"}, +${r.bounties} bount${r.bounties===1?"y":"ies"}` : "";
                el.textContent = `${events.length} events · synced ${fmt.relTime(Math.floor(this.lastSync/1000))}${detail}`;
            } else {
                el.textContent = "No data yet — click ⟳ Sync";
            }
        }

        _renderBody() {
            const body = this._panel && this._panel.querySelector("#ta-body");
            if (!body) return;
            const key = KeyResolver.resolveTornKey();
            if (!key) { body.innerHTML = this._authHTML(); this._wireAuth(body); this._tickFooter(); return; }
            switch (this.tab) {
                case "overview": body.innerHTML = this._overviewHTML(); this._wirePeriod(body); break;
                case "sources":  body.innerHTML = this._sourcesHTML(); this._wirePeriod(body); break;
                case "top":      body.innerHTML = this._topHTML();     this._wirePeriod(body); break;
                case "trends":   body.innerHTML = this._trendsHTML();  break;
                case "settings": body.innerHTML = this._settingsHTML(); this._wireSettings(body); break;
            }
            this._tickFooter();
        }

        // ── Auth ──────────────────────────────────────────────
        _authHTML() {
            return `<div style="padding:8px 0">
                <div style="font-size:14px;font-weight:700;margin-bottom:10px">API Key Required</div>
                <div class="ta-field">
                    <label>Torn API Key (16 characters)</label>
                    <div class="ta-key-row">
                        <input type="text" class="ta-input" id="ta-auth-inp" maxlength="16" placeholder="Paste your key here" autocomplete="off" data-lpignore="true" />
                        <button class="ta-btn ta-btn-primary" id="ta-auth-save">Save</button>
                    </div>
                    <div id="ta-auth-msg" class="ta-save-status"></div>
                </div>
                <p style="font-size:11px;color:#666;margin-top:6px">
                    Get your key at <a class="ta-link" href="https://www.torn.com/preferences.php#tab=api" target="_blank">Torn → Preferences → API Key</a>.
                </p>
                <p style="font-size:11px;color:#888;margin-top:8px;line-height:1.5">
                    <b>Key access levels:</b> a <b>Full Access</b> key is recommended — it unlocks exact per-mug money
                    from your activity log. A Limited key tracks attack wins only; a Public key falls back to
                    approximate money from hourly stat snapshots.
                </p>
            </div>`;
        }

        _wireAuth(body) {
            const inp = body.querySelector("#ta-auth-inp");
            const btn = body.querySelector("#ta-auth-save");
            const msg = body.querySelector("#ta-auth-msg");
            const save = async () => {
                const k = inp.value.trim();
                if (!/^[A-Za-z0-9]{16}$/.test(k)) { msg.className = "ta-save-status ta-save-err"; msg.textContent = "Must be exactly 16 alphanumeric characters."; return; }
                btn.disabled = true;
                msg.className = "ta-save-status ta-save-info"; msg.textContent = "Validating…";
                try {
                    const api  = new TornAPI(k);
                    const prof = await api.validateKey();
                    if (!prof) throw new Error("Key rejected or insufficient access.");
                    KeyResolver.saveKey(k);
                    this.myId = prof.id || prof.player_id;
                    try { localStorage.setItem(LS.myId, String(this.myId)); } catch {}
                    // New key — reset access flags so sync re-probes what it can read
                    this.access = { attacks:true, log:true };
                    saveAccess(this.access);
                    msg.className = "ta-save-status ta-save-ok";
                    msg.textContent = `✓ Valid — ${prof.name || "Player"} [${this.myId}]`;
                    setTimeout(() => { this._renderBody(); this.syncData(); }, 1200);
                } catch (e) {
                    msg.className = "ta-save-status ta-save-err"; msg.textContent = e.message || "Validation failed.";
                } finally { btn.disabled = false; }
            };
            btn.addEventListener("click", save);
            inp.addEventListener("keydown", e => { if (e.key === "Enter") save(); });
        }

        // ── Period selector ───────────────────────────────────
        _periodRow() {
            const periods = [
                {id:"today",label:"Today"},{id:"week",label:"7 Days"},
                {id:"month",label:"30 Days"},{id:"3month",label:"90 Days"},{id:"all",label:"All Time"},
            ];
            return `<div class="ta-period-row">${periods.map(p =>
                `<button class="ta-period-btn${p.id===this.period?" active":""}" data-period="${p.id}">${p.label}</button>`
            ).join("")}</div>`;
        }

        _wirePeriod(container) {
            container.querySelectorAll(".ta-period-btn").forEach(btn =>
                btn.addEventListener("click", () => { this.period = btn.dataset.period; this._renderBody(); })
            );
        }

        _events() { return filterByPeriod(loadEvents(), this.period, this.settings); }

        // Delta of a personalstats field since a timestamp, using the snapshot
        // taken closest before that time. Fallback when the log isn't readable.
        _snapDeltaSince(fromTs, field) {
            const s = this.cachedStats;
            if (!s || s[field] == null || !fromTs) return null;
            const snaps = loadSnapshots();
            const base = [...snaps].reverse().find(x => x.ts <= fromTs && x[field] != null);
            if (!base) return null;
            return s[field] - base[field];
        }

        // ── Overview ──────────────────────────────────────────
        _overviewHTML() {
            const range  = getRange(this.period);
            const events = this._events();
            const s      = this.cachedStats;

            if (!s && loadEvents().length === 0) {
                return `${this._periodRow()}<div class="ta-empty"><div class="ta-empty-icon">📊</div>No data yet.<br>Click ⟳ Sync to load your stats.</div>`;
            }

            const mugs    = events.filter(e => e.type === EVENT_TYPES.MUGGING);
            const bnts    = events.filter(e => e.type === EVENT_TYPES.BOUNTY);
            const atks    = events.filter(e => e.type === EVENT_TYPES.ATTACK);
            const mugTot  = mugs.reduce((t,e) => t + e.amount, 0);
            const bntTot  = bnts.reduce((t,e) => t + e.amount, 0);
            const respect = atks.reduce((t,e) => t + (e.meta?.respect || 0), 0);
            const best    = Math.max(0, ...mugs.map(e => e.amount), ...bnts.map(e => e.amount));

            let notice = "";
            if (!this.access.log) {
                notice = `<div class="ta-notice">⚠️ Your API key can't read the activity log (needs a <b>Full Access</b> key), so exact per-mug money isn't available. Money below is estimated from hourly stat snapshots — paste a Full Access key in Settings for precise per-event tracking.</div>`;
            } else if (!this.access.attacks) {
                notice = `<div class="ta-notice">⚠️ Your API key can't read attack history (needs a <b>Limited</b> key or higher) — attack wins and respect are unavailable.</div>`;
            }

            // Money cards: exact from log events, or snapshot-delta estimate
            let mugVal = fmt.money(mugTot), mugSub = `${mugs.length} mug${mugs.length===1?"":"s"}`;
            let bntVal = fmt.money(bntTot), bntSub = `${bnts.length} bount${bnts.length===1?"y":"ies"} collected`;
            if (!this.access.log) {
                if (this.period === "all") {
                    mugVal = s && s.moneymugged != null ? fmt.money(s.moneymugged) : "—";
                    mugSub = "lifetime (personal stats)";
                } else {
                    const d = this._snapDeltaSince(range.from, "moneymugged");
                    mugVal = d == null ? "—" : "≈ " + fmt.money(d);
                    mugSub = d == null ? "need snapshots spanning this period" : "estimated from stat snapshots";
                }
                bntVal = "—"; bntSub = "needs Full Access key";
            }

            const cardsHTML = `<div class="ta-cards">
                <div class="ta-card">
                    <div class="ta-card-lbl">💰 Mugged — ${escHtml(range.label)}</div>
                    <div class="ta-card-val">${escHtml(mugVal)}</div>
                    <div class="ta-card-sub">${escHtml(mugSub)}</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">🎯 Bounties — ${escHtml(range.label)}</div>
                    <div class="ta-card-val">${escHtml(bntVal)}</div>
                    <div class="ta-card-sub">${escHtml(bntSub)}</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">⚔️ Attack Wins — ${escHtml(range.label)}</div>
                    <div class="ta-card-val">${atks.length.toLocaleString()}</div>
                    <div class="ta-card-sub">${respect.toFixed(2)} respect</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">🏆 Best Single Hit</div>
                    <div class="ta-card-val">${escHtml(best > 0 ? fmt.money(best) : "—")}</div>
                    <div class="ta-card-sub">${escHtml(range.label)}</div>
                </div>
            </div>`;

            // Lifetime tiles from personalstats
            let lifeHTML = "";
            if (s) {
                const xtra = [
                    ["Mugged (lifetime)", s.moneymugged  != null ? fmt.money(s.moneymugged)      : null],
                    ["Networth",          s.networth     != null ? fmt.money(s.networth)         : null],
                    ["Attacks Won",       s.attackswon   != null ? s.attackswon.toLocaleString() : null],
                    ["Bazaar Profit",     s.bazaarprofit != null ? fmt.money(s.bazaarprofit)     : null],
                ].filter(([, v]) => v != null);
                if (xtra.length) {
                    lifeHTML = `<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
                        ${xtra.map(([k, v]) => `<div style="flex:1;min-width:90px;background:#1f1f1f;border-radius:5px;padding:6px 10px;border:1px solid #2a2a2a">
                            <div style="font-size:10px;color:#666;text-transform:uppercase;letter-spacing:.5px">${escHtml(k)}</div>
                            <div style="font-size:14px;font-weight:700;color:#bbb;margin-top:2px">${escHtml(v)}</div>
                        </div>`).join("")}
                    </div>`;
                }
            }

            const { days } = range;
            const chartDays   = days <= 1 ? 7 : Math.min(days, 30);
            const chartPeriod = chartDays <= 7 ? "week" : "month";
            const chart  = this._barChart(filterByPeriod(loadEvents(), chartPeriod, this.settings), chartDays);
            const recent = loadEvents().filter(e => (e.amount||0) > 0).slice(0, 12);

            const topMugged = groupByTarget(loadEvents().filter(e => e.type === EVENT_TYPES.MUGGING)).slice(0, 10);
            const mugRankHTML = topMugged.length > 0
                ? `<div class="ta-section-hd">Top Mugged Targets</div>
                    <div class="ta-event-list">${topMugged.map((t, i) => `<div class="ta-event-row">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-lbl"><a class="ta-link" href="https://www.torn.com/profiles.php?XID=${t.id}" target="_blank" rel="noopener">${escHtml(t.name)}</a></div>
                        <div class="ta-event-amt pos">${escHtml(fmt.money(t.total))}</div>
                        <div class="ta-event-time">${t.count}×</div>
                    </div>`).join("")}</div>`
                : "";

            return `${this._periodRow()}${notice}${cardsHTML}${lifeHTML}
                <div class="ta-section-hd">Money per Day</div>
                ${chart}
                ${mugRankHTML}
                <div class="ta-section-hd">Recent Money Events</div>
                ${this._eventListHTML(recent)}`;
        }

        _barChart(events, days) {
            const buckets  = groupByDay(events, days);
            const isCounts = buckets.some(b => b.isCounts);
            const maxVal   = Math.max(...buckets.map(b => b.displayVal), 1);
            const bars     = buckets.map(b => {
                const h   = Math.max(2, Math.round((b.displayVal / maxVal) * 100));
                const tip = isCounts
                    ? `${b.label}: ${b.count} event${b.count===1?"":"s"}`
                    : `${b.label}: ${fmt.money(b.total)} (${b.count} events)`;
                return `<div class="ta-bar-col" title="${escHtml(tip)}">
                    <div class="ta-bar-fill${b.displayVal===0?" ta-bar-zero":""}" style="height:${h}%"></div>
                </div>`;
            }).join("");
            const lbl = isCounts ? `<div class="ta-chart-lbl">Activity per day (events — no money recorded yet)</div>` : "";
            return `<div class="ta-chart">
                ${lbl}
                <div class="ta-bars">${bars}</div>
                <div class="ta-chart-axis">
                    <span>${escHtml(buckets[0]?.label||"")}</span>
                    <span>Today</span>
                </div>
            </div>`;
        }

        _eventListHTML(events) {
            if (events.length === 0) return `<div class="ta-empty"><div class="ta-empty-icon">📭</div>No money events recorded yet.<br>${this.access.log ? "Click ⟳ Sync to fetch data." : "A Full Access API key is required for per-event money tracking."}</div>`;
            return `<div class="ta-event-list">${events.map(e => {
                const tc   = TYPE_CONFIG[e.type] || {icon:"•"};
                const pos  = (e.amount||0) > 0;
                const amtS = pos ? "+" + fmt.money(e.amount)
                           : e.type === EVENT_TYPES.ATTACK ? (+(e.meta?.respect||0)).toFixed(2) + " resp"
                           : fmt.money(0);
                return `<div class="ta-event-row">
                    <div class="ta-event-icon">${tc.icon}</div>
                    <div class="ta-event-lbl" title="${escHtml(e.label)}">${escHtml(e.label)}</div>
                    <div class="ta-event-amt ${pos?"pos":"zero"}">${escHtml(amtS)}</div>
                    <div class="ta-event-time">${fmt.relTime(e.ts)}</div>
                </div>`;
            }).join("")}</div>`;
        }

        // ── Sources ───────────────────────────────────────────
        _sourcesHTML() {
            const events   = this._events().filter(e => (e.amount||0) > 0);
            const groups   = groupByType(events);
            const grandTot = events.reduce((t,e) => t + e.amount, 0);

            if (Object.keys(groups).length === 0) {
                const s = this.cachedStats;
                if (s) {
                    const rows = [
                        { icon:"💰", label:"Muggings",      val: fmt.money(s.moneymugged ?? 0),                  sub: "lifetime total" },
                        { icon:"⚔️",  label:"Attacks",       val: `${(s.attackswon ?? 0).toLocaleString()} wins`, sub: `${(s.attackslost ?? 0).toLocaleString()} losses` },
                        { icon:"🛒", label:"Bazaar Profit",  val: fmt.money(s.bazaarprofit ?? 0),                 sub: `${(s.bazaarsales ?? 0).toLocaleString()} items sold` },
                    ];
                    return `${this._periodRow()}
                        <div style="font-size:11px;color:#555;margin-bottom:12px">No per-event money in this period — showing lifetime totals from your personal stats.${this.access.log ? "" : " (A Full Access key unlocks per-event tracking.)"}</div>
                        <div style="display:flex;flex-direction:column;gap:8px">
                            ${rows.map(r => `<div style="display:flex;align-items:center;gap:12px;background:#1f1f1f;border-radius:6px;padding:10px 14px;border:1px solid #2a2a2a">
                                <div style="font-size:22px;flex-shrink:0">${r.icon}</div>
                                <div style="flex:1">
                                    <div style="font-size:13px;font-weight:700;color:#ccc">${escHtml(r.label)}</div>
                                    <div style="font-size:10px;color:#555;margin-top:2px">${escHtml(r.sub)}</div>
                                </div>
                                <div style="font-size:16px;font-weight:700;color:#4fc3f7">${escHtml(r.val)}</div>
                            </div>`).join("")}
                        </div>`;
                }
                return `${this._periodRow()}<div class="ta-empty"><div class="ta-empty-icon">📊</div>No data yet. Click ⟳ Sync to load your stats.</div>`;
            }

            const rows = Object.entries(groups)
                .sort((a,b) => b[1].total - a[1].total)
                .map(([type, g]) => {
                    const tc  = TYPE_CONFIG[type] || {icon:"•", label:type, color:"#888"};
                    const pct = grandTot > 0 ? g.total/grandTot*100 : 0;
                    const avg = g.count > 0 ? g.total/g.count : 0;
                    return `<tr>
                        <td><span class="ta-badge" style="background:${tc.color}1a;color:${tc.color}">${tc.icon} ${tc.label}</span></td>
                        <td class="num" style="color:#aaa">${g.count}</td>
                        <td class="num" style="color:#66bb6a;font-weight:700">${escHtml(fmt.money(g.total))}</td>
                        <td>
                            <span class="ta-pbar-bg"><span class="ta-pbar-fill" style="width:${pct.toFixed(1)}%;background:${tc.color};display:block;height:100%;border-radius:3px"></span></span>
                            <span style="font-size:10px;color:#777;margin-left:5px">${fmt.pct(pct)}</span>
                        </td>
                        <td class="num" style="color:#888">${escHtml(fmt.money(avg))}</td>
                    </tr>`;
                }).join("");

            return `${this._periodRow()}
                <table class="ta-tbl">
                    <thead><tr>
                        <th>Source</th><th class="num">Events</th>
                        <th class="num">Total Profit</th><th>Share</th>
                        <th class="num">Avg / Event</th>
                    </tr></thead>
                    <tbody>${rows}</tbody>
                    <tfoot>
                        <tr style="border-top:1px solid #333">
                            <td style="color:#777;font-weight:700;font-size:11px">TOTAL</td>
                            <td class="num" style="color:#777">${events.length}</td>
                            <td class="num" style="color:#4fc3f7;font-weight:700">${escHtml(fmt.money(grandTot))}</td>
                            <td></td>
                            <td class="num" style="color:#777">${escHtml(fmt.money(grandTot/(events.length||1)))}</td>
                        </tr>
                    </tfoot>
                </table>`;
        }

        // ── Top Events ────────────────────────────────────────
        _topHTML() {
            const events      = this._events().filter(e => (e.amount||0) > 0);
            const topEvents   = [...events].sort((a,b) => b.amount - a.amount).slice(0, 15);
            const topTargets  = groupByTarget(this._events()).slice(0, 10);

            const evtHTML = topEvents.length === 0
                ? `<div class="ta-empty"><div class="ta-empty-icon">🏆</div>No money events yet for this period.</div>`
                : topEvents.map((e, i) => {
                    const tc = TYPE_CONFIG[e.type] || {icon:"•"};
                    return `<div class="ta-top-item">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-icon">${tc.icon}</div>
                        <div class="ta-top-lbl" title="${escHtml(e.label)}">${escHtml(e.label)}</div>
                        <div class="ta-top-amt">${escHtml(fmt.money(e.amount))}</div>
                        <div class="ta-top-meta">${fmt.relTime(e.ts)}</div>
                    </div>`;
                }).join("");

            const tgtHTML = topTargets.length > 0
                ? topTargets.map((t, i) =>
                    `<div class="ta-top-item">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-icon">💰</div>
                        <div class="ta-top-lbl"><a class="ta-link" href="https://www.torn.com/profiles.php?XID=${t.id}" target="_blank" rel="noopener">${escHtml(t.name)}</a></div>
                        <div class="ta-top-amt">${escHtml(fmt.money(t.total))}</div>
                        <div class="ta-top-meta">${t.count} hit${t.count===1?"":"s"}</div>
                    </div>`).join("")
                : "";

            const atkEvents = this._events().filter(e => e.type === EVENT_TYPES.ATTACK);
            const topAtkTargets = rankByCount(atkEvents).slice(0, 10);
            const atkTgtHTML = topAtkTargets.length > 0
                ? topAtkTargets.map((t, i) =>
                    `<div class="ta-top-item">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-icon">⚔️</div>
                        <div class="ta-top-lbl"><a class="ta-link" href="https://www.torn.com/profiles.php?XID=${t.id}" target="_blank" rel="noopener">${escHtml(t.name)}</a></div>
                        <div class="ta-top-amt" style="color:#4fc3f7">${t.count} win${t.count===1?"":"s"}</div>
                        <div class="ta-top-meta">${t.total > 0 ? escHtml(fmt.money(t.total)) : "—"}</div>
                    </div>`).join("")
                : `<div style="padding:6px;color:#666;font-size:12px">${this.access.attacks ? "No attack data — click ⟳ Sync to fetch." : "Attack history needs a Limited key or higher."}</div>`;

            return `${this._periodRow()}
                <div class="ta-section-hd">Top Individual Events</div>
                ${evtHTML}
                ${tgtHTML ? `<div class="ta-section-hd">Most Profitable Targets</div>${tgtHTML}` : ""}
                <div class="ta-section-hd">Most Attacked Targets</div>
                ${atkTgtHTML}`;
        }

        // ── Trends ────────────────────────────────────────────
        _trendsHTML() {
            const allEvts = loadEvents().filter(e =>
                (this.settings.includeMuggings && e.type===EVENT_TYPES.MUGGING ||
                 this.settings.includeBounties && e.type===EVENT_TYPES.BOUNTY  ||
                 this.settings.includeAttacks  && e.type===EVENT_TYPES.ATTACK));

            const weeks        = buildWeeklyComparison(allEvts);
            const hasWeekMoney = weeks.some(w => w.total > 0);
            const maxWeek      = Math.max(...weeks.map(w => hasWeekMoney ? w.total : w.count), 1);
            const weekRows = weeks.map(w => {
                const barVal = hasWeekMoney ? w.total : w.count;
                const dispAmt = hasWeekMoney ? fmt.money(w.total) : `${w.count} events`;
                return `<div class="ta-cmp-row">
                    <div class="ta-cmp-lbl">${escHtml(w.label)}</div>
                    <div class="ta-cmp-bar-wrap">
                        <div class="ta-cmp-bar-bg">
                            <div class="ta-cmp-bar-fill" style="width:${(barVal/maxWeek*100).toFixed(1)}%"></div>
                        </div>
                        <div style="font-size:10px;color:#555;margin-top:1px">${w.count} event${w.count===1?"":"s"}</div>
                    </div>
                    <div class="ta-cmp-amt">${escHtml(dispAmt)}</div>
                </div>`;
            }).join("");

            // Monthly bars (last 6 months)
            const now = Math.floor(Date.now()/1000);
            const months = Array.from({length:6}, (_,i) => {
                const to   = now - i*30*86400;
                const from = to - 30*86400;
                const evts = allEvts.filter(e => e.ts >= from && e.ts < to);
                const tot  = evts.reduce((s,e) => s + (e.amount||0), 0);
                const d    = new Date((from + 15*86400)*1000);
                return { label: d.toLocaleDateString([], {month:"short", year:"2-digit"}), total: tot, count: evts.length };
            }).reverse();
            const hasMoMoney = months.some(m => m.total > 0);
            const maxMo      = Math.max(...months.map(m => hasMoMoney ? m.total : m.count), 1);
            const moRows = months.map(m => {
                const barVal  = hasMoMoney ? m.total : m.count;
                const dispAmt = hasMoMoney ? fmt.money(m.total) : `${m.count} events`;
                return `<div class="ta-cmp-row">
                    <div class="ta-cmp-lbl">${escHtml(m.label)}</div>
                    <div class="ta-cmp-bar-wrap">
                        <div class="ta-cmp-bar-bg">
                            <div class="ta-cmp-bar-fill" style="width:${(barVal/maxMo*100).toFixed(1)}%"></div>
                        </div>
                        <div style="font-size:10px;color:#555;margin-top:1px">${m.count} event${m.count===1?"":"s"}</div>
                    </div>
                    <div class="ta-cmp-amt">${escHtml(dispAmt)}</div>
                </div>`;
            }).join("");

            const snaps   = loadSnapshots();
            const delta7  = computeSnapDelta(snaps, 7*86400);
            const delta30 = computeSnapDelta(snaps, 30*86400);

            const snapField = (label, key, d7, d30, money) => {
                const v7  = d7  && d7[key]  != null ? d7[key]  : null;
                const v30 = d30 && d30[key] != null ? d30[key] : null;
                if (v7 == null && v30 == null) return "";
                const fmtN = (n) => n == null ? "—" : (money ? fmt.money(n) : n.toLocaleString());
                return `<div class="ta-snap-row">
                    <div class="ta-snap-key">${escHtml(label)}</div>
                    <div style="display:flex;gap:16px">
                        <div class="ta-snap-val" title="7-day change">${escHtml(fmtN(v7))} <span style="color:#555;font-size:10px">7d</span></div>
                        <div class="ta-snap-val" title="30-day change">${escHtml(fmtN(v30))} <span style="color:#555;font-size:10px">30d</span></div>
                    </div>
                </div>`;
            };

            const s = this.cachedStats;
            let snapHTML;
            if (s && snaps.length >= 1) {
                const first    = snaps[0];
                const since    = fmt.date(first.ts);
                const dSince   = (key, money) => {
                    if (first[key] == null || s[key] == null) return "—";
                    const v = s[key] - first[key];
                    return (v >= 0 ? "+" : "") + (money ? fmt.money(v) : v.toLocaleString());
                };
                const sinceRows = [
                    ["Money Mugged",    "moneymugged",  true],
                    ["Bazaar Profit",   "bazaarprofit", true],
                    ["Networth Change", "networth",     true],
                    ["Attacks Won",     "attackswon",   false],
                    ["Items Sold",      "bazaarsales",  false],
                    ["Nerve Refills",   "nerverefills", false],
                ].map(([lbl, key, money]) => `<div class="ta-snap-row">
                    <div class="ta-snap-key">${escHtml(lbl)}</div>
                    <div class="ta-snap-val">${escHtml(dSince(key, money))}</div>
                </div>`).join("");

                const recentDeltaRows = snaps.length >= 2 ? [
                    ["Money Mugged",  "moneymugged",  true],
                    ["Bazaar Profit", "bazaarprofit", true],
                    ["Networth",      "networth",     true],
                    ["Attacks Won",   "attackswon",   false],
                ].map(([lbl, key, money]) => snapField(lbl, key, delta7, delta30, money)).join("") : "";

                snapHTML = `<div class="ta-section-hd">Changes Since ${escHtml(since)}</div>
                    <div style="font-size:10px;color:#555;margin-bottom:8px">${snaps.length} snapshot${snaps.length===1?"":"s"} · tracking started ${escHtml(since)}</div>
                    ${sinceRows}
                    ${snaps.length >= 2 ? `<div class="ta-section-hd" style="margin-top:8px">Recent Deltas <span style="font-weight:400;text-transform:none;font-size:10px">(7d · 30d)</span></div>${recentDeltaRows}` : ""}`;
            } else {
                snapHTML = `<div class="ta-section-hd">Personal Stats Deltas</div>
                    <div style="font-size:11px;color:#666;padding:8px 0">Click ⟳ Sync to start tracking stat changes over time.</div>`;
            }

            return `<div class="ta-section-hd">Weekly Comparison</div>
                ${weekRows}
                <div class="ta-section-hd">Monthly Comparison (6 months)</div>
                ${moRows}
                ${snapHTML}`;
        }

        // ── Settings ──────────────────────────────────────────
        _settingsHTML() {
            const s   = this.settings;
            const key = !KeyResolver.isPDAKey() ? (KeyResolver.resolveTornKey() || "") : "";
            const pdaNote = KeyResolver.isPDAKey() ? `<div class="ta-save-status ta-save-ok">✓ API key provided by Torn PDA</div>` : "";
            const accessNote = `<div style="font-size:11px;color:#888;margin-top:4px;line-height:1.5">
