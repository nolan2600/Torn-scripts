                }
                saveEvents(pruneEvents(merged, this.settings));

                // ── PersonalStats snapshot (works with any key) ─
                const now = Math.floor(Date.now()/1000);
                const stats = await api.fetchPersonalStats();
                if (stats) {
                    this.cachedStats = stats;
                    saveStatsCache(stats);
                    const lastSnapTs = getTs(LS.lastSnapTs);
                    if ((now - lastSnapTs) >= this.settings.snapEvery) {
                        const snap = { ts: now };
                        for (const f of SNAP_FIELDS) { if (stats[f] != null) snap[f] = stats[f]; }
                        const snaps = loadSnapshots();
                        snaps.push(snap);
                        saveSnapshots(snaps);
                        setTs(LS.lastSnapTs, now);
                    }
                }

                this.lastSync = Date.now();
                if (this._panel && this._panel.classList.contains("ta-open")) this._renderBody();

            } catch (e) {
                this.lastErr = this._friendlyErr(e);
            } finally {
                this.syncing = false;
                this._tickFooter();
                if (this._syncTmr) clearTimeout(this._syncTmr);
                this._syncTmr = setTimeout(() => {
                    if (this._panel && this._panel.classList.contains("ta-open")) this.syncData();
                }, this.settings.refreshSec * 1000);
            }
        }
    }

