// ==UserScript==
// @name         Torn Profit Analytics
// @namespace    https://github.com/nolan2600/torn-scripts
// @version      1.2.0
// @description  Track daily/weekly/monthly profits from muggings and bounties — with source breakdown, top events, and trend charts.
// @author       DieselBlade + nolan2600
// @match        https://www.torn.com/*
// @match        https://torn.com/*
// @grant        GM_xmlhttpRequest
// @grant        unsafeWindow
// @connect      api.torn.com
// @license      GPL-3.0-or-later
// ==/UserScript==

/* eslint-disable no-undef */

(function () {
    "use strict";

    const PDA_API_KEY     = "###PDA-APIKEY###";
    const PDA_PLACEHOLDER = "###" + "PDA-APIKEY" + "###";
    const VERSION         = "1.2.0";
    const API_BASE        = "https://api.torn.com/v2";
    const API_DELAY_MS    = 750;
    const SPA_LS_APIKEY   = "spa_apiKey";

    const LS = {
        apiKey:        "ta_apiKey",
        settings:      "ta_settings_v1",
        events:        "ta_events_v1",
        snapshots:     "ta_snapshots_v1",
        lastAttackTs:  "ta_last_attack_ts",
        lastLogTs:     "ta_last_log_ts",
        lastSnapTs:    "ta_last_snap_ts",
        myId:          "ta_my_id",
        statsCache:    "ta_stats_cache_v1",
        access:        "ta_access_v1",
        names:         "ta_names_v1",
    };

    const EVENT_TYPES = { MUGGING:"mugging", BOUNTY:"bounty", ATTACK:"attack" };

    const TYPE_CONFIG = {
        mugging: { label:"Mugging",    color:"#ef5350", icon:"💰" },
        bounty:  { label:"Bounty",     color:"#ffd700", icon:"🎯" },
        attack:  { label:"Attack Win", color:"#4fc3f7", icon:"⚔️"  },
    };

    const DEFAULT_SETTINGS = {
        includeMuggings:  true,
        includeBounties:  true,
        includeAttacks:   true,
        refreshSec:       600,
        retentionDays:    90,
        maxEvents:        5000,
        snapEvery:        3600, // personalstats snapshot interval (seconds)
    };

    const SNAP_FIELDS = [
        "attackswon","attackslost","moneymugged","defendslost",
        "criminaloffenses","nerverefills","bazaarsales","bazaarprofit",
        "networth","useractivity",
    ];

    // Attack results that count as a win for the attacker
    const WIN_RESULTS = new Set(["Attacked","Mugged","Hospitalized","Arrested","Looted","Special"]);

    const IS_PDA      = typeof PDA_httpGet === "function";
    const HAS_PDA_KEY = PDA_API_KEY !== PDA_PLACEHOLDER && /^[A-Za-z0-9]{16}$/.test(PDA_API_KEY);
    const GM_XHR      = (typeof GM_xmlhttpRequest !== "undefined") ? GM_xmlhttpRequest : null;

    // ── Utilities ──────────────────────────────────────────────
    function escHtml(s) {
        return String(s == null ? "" : s)
            .replace(/&/g,"&amp;").replace(/</g,"&lt;")
            .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    const fmt = {
        money(n) {
            if (n == null) return "$0";
            const a = Math.abs(n);
            const s = a >= 1e9 ? (a/1e9).toFixed(2)+"B"
                    : a >= 1e6 ? (a/1e6).toFixed(2)+"M"
                    : a >= 1e3 ? (a/1e3).toFixed(1)+"K"
                    : a.toLocaleString();
            return (n < 0 ? "-$" : "$") + s;
        },
        moneyFull(n) { return (n < 0 ? "-$" : "$") + Math.abs(n).toLocaleString(); },
        date(ts)     { return new Date(ts * 1000).toLocaleDateString(); },
        relTime(ts)  {
            const d = Math.floor(Date.now()/1000) - ts;
            if (d < 60)    return `${d}s ago`;
            if (d < 3600)  return `${Math.floor(d/60)}m ago`;
            if (d < 86400) return `${Math.floor(d/3600)}h ago`;
            return `${Math.floor(d/86400)}d ago`;
        },
        pct(n) { return (n == null ? 0 : n).toFixed(1) + "%"; },
    };

    const sleep = (ms) => new Promise(r => setTimeout(r, ms));

    // ── Storage ────────────────────────────────────────────────
    function loadSettings()   { try { const r = localStorage.getItem(LS.settings); return {...DEFAULT_SETTINGS,...(r?JSON.parse(r):{})}; } catch { return {...DEFAULT_SETTINGS}; } }
    function saveSettings(s)  { localStorage.setItem(LS.settings, JSON.stringify(s)); }
    function loadEvents()     { try { const r = localStorage.getItem(LS.events); return r ? JSON.parse(r) : []; } catch { return []; } }
    function loadSnapshots()  { try { const r = localStorage.getItem(LS.snapshots); return r ? JSON.parse(r) : []; } catch { return []; } }

    function saveEvents(events) {
        try { localStorage.setItem(LS.events, JSON.stringify(events)); }
        catch { try { localStorage.setItem(LS.events, JSON.stringify(events.slice(-1000))); } catch {} }
    }
    function saveSnapshots(snaps) {
        try { localStorage.setItem(LS.snapshots, JSON.stringify(snaps.slice(-1000))); } catch {}
    }
    function getTs(key)     { try { return parseInt(localStorage.getItem(key)||"0",10); } catch { return 0; } }
    function setTs(key, ts) { try { localStorage.setItem(key, String(ts)); } catch {} }

    function loadStatsCache() { try { const c = JSON.parse(localStorage.getItem(LS.statsCache)||"null"); return c && c.stats ? c.stats : null; } catch { return null; } }
    function saveStatsCache(stats) { try { localStorage.setItem(LS.statsCache, JSON.stringify({ ts: Math.floor(Date.now()/1000), stats })); } catch {} }
    function loadAccess() { try { const a = JSON.parse(localStorage.getItem(LS.access)||"null"); return a && typeof a === "object" ? { attacks:a.attacks!==false, log:a.log!==false } : { attacks:true, log:true }; } catch { return { attacks:true, log:true }; } }
    function saveAccess(a) { try { localStorage.setItem(LS.access, JSON.stringify(a)); } catch {} }

    // Persistent id → player-name cache (log entries carry target IDs only)
    function loadNames() { try { const n = JSON.parse(localStorage.getItem(LS.names)||"{}"); return n && typeof n === "object" ? n : {}; } catch { return {}; } }
    function saveNames(n) { try { localStorage.setItem(LS.names, JSON.stringify(n)); } catch {} }

    // ── Key Resolver ───────────────────────────────────────────
    const KeyResolver = {
        resolveTornKey() {
            if (HAS_PDA_KEY) return PDA_API_KEY;
            const k = localStorage.getItem(LS.apiKey);
            if (k) return k;
            return localStorage.getItem(SPA_LS_APIKEY) || null;
        },
        saveKey(k)   { localStorage.setItem(LS.apiKey, k); },
        clearKey()   { localStorage.removeItem(LS.apiKey); },
        isPDAKey()   { return HAS_PDA_KEY; },
    };

    // ── HTTP ───────────────────────────────────────────────────
    function _gmGet(url) {
        return new Promise((resolve, reject) => {
            GM_XHR({ method:"GET", url, timeout:25_000,
                onload:   r => resolve({status:r.status, text:r.responseText}),
                onerror:  () => reject(new Error("network_error")),
                ontimeout:() => reject(new Error("timeout")),
            });
        });
    }

    async function httpGetJson(url) {
        if (IS_PDA) {
            const res = await PDA_httpGet(url);
            if (res.status < 200 || res.status >= 300) { const e = new Error(`HTTP ${res.status}`); e.status = res.status; throw e; }
            return JSON.parse(res.responseText);
        }
        if (GM_XHR) {
            const res = await _gmGet(url);
            if (res.status < 200 || res.status >= 300) { const e = new Error(`HTTP ${res.status}`); e.status = res.status; throw e; }
            return JSON.parse(res.text);
        }
        // Timeout stays armed until the body is fully read
        return new Promise((resolve, reject) => {
            const tid = setTimeout(() => reject(new Error("timeout")), 25_000);
            fetch(url)
                .then(r => { if (!r.ok) { const e = new Error(`HTTP ${r.status}`); e.status = r.status; throw e; } return r.json(); })
                .then(d => { clearTimeout(tid); resolve(d); })
                .catch(e => { clearTimeout(tid); reject(e); });
        });
    }

    // ── Torn API ───────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key = key; this._lastReq = 0; }
        setKey(key) { this.key = key; }

        async _rateLimit() { const w = API_DELAY_MS - (Date.now() - this._lastReq); if (w > 0) await sleep(w); this._lastReq = Date.now(); }

        async _get(path, params = {}) {
            await this._rateLimit();
            const url = new URL(/^https?:\/\//.test(path) ? path : API_BASE + path);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            if (!url.searchParams.has("key")) url.searchParams.set("key", this.key);
            const data = await httpGetJson(url.toString());
            if (data && data.error) { const e = new Error(data.error.error || "Torn API error"); e.tornCode = data.error.code; throw e; }
            return data;
        }

        async _getV1(params, userId = "") {
            await this._rateLimit();
            const url = new URL("https://api.torn.com/user/" + userId);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, String(v));
            url.searchParams.set("key", this.key);
            const data = await httpGetJson(url.toString());
            if (data && data.error) { const e = new Error(data.error.error || "Torn API error"); e.tornCode = data.error.code; throw e; }
            return data;
        }

        // Resolve a player's name by ID — works with any key level
        async fetchBasic(id) {
            const data = await this._getV1({ selections:"basic" }, String(id));
            return data && data.name ? { id: data.player_id || id, name: data.name } : null;
        }

        async validateKey() {
            const data = await this._get("/user/profile");
            return (data && data.profile) || (data && data.id ? data : null);
        }

        // v1 attacks — the API returns at most 100 (newest first), so page
        // backwards with `to` until the window is covered. Requires Limited key.
        async fetchAttacks(fromTs = 0) {
            const from = fromTs > 0 ? fromTs : Math.floor(Date.now()/1000) - 90*86400;
            const out = [];
            let to = Math.floor(Date.now()/1000) + 60;
            for (let page = 0; page < 6; page++) {
                const data = await this._getV1({ selections:"attacks", from, to });
                const batch = Object.values(data.attacks || {});
                if (!batch.length) break;
                let oldest = Infinity;
                for (const a of batch) {
                    out.push(a);
                    const ts = a.timestamp_ended || a.timestamp_started || 0;
                    if (ts && ts < oldest) oldest = ts;
                }
                if (batch.length < 100 || !Number.isFinite(oldest) || oldest <= from) break;
                to = oldest - 1;
            }
            return out;
        }

        // v1 activity log — the only API source with exact per-event money
        // (money_mugged, bounty payouts). Requires a Full Access key; callers
        // must handle tornCode 16 gracefully. Paged like attacks.
        async fetchLog(fromTs = 0) {
            const from = fromTs > 0 ? fromTs : Math.floor(Date.now()/1000) - 90*86400;
            const out = [];
            let to = Math.floor(Date.now()/1000) + 60;
            for (let page = 0; page < 10; page++) {
                const data = await this._getV1({ selections:"log", from, to });
                const entries = Object.entries(data.log || {});
                if (!entries.length) break;
                let oldest = Infinity;
                for (const [id, e] of entries) {
                    out.push({ logId: id, ...e });
                    const ts = e.timestamp || 0;
                    if (ts && ts < oldest) oldest = ts;
                }
                if (entries.length < 100 || !Number.isFinite(oldest) || oldest <= from) break;
                to = oldest - 1;
            }
            return out;
        }

        // v1 personalstats — works with any key level
        async fetchPersonalStats() {
            try {
                const data = await this._getV1({ selections:"personalstats" });
                return data.personalstats || null;
            } catch { return null; }
        }
    }

    // ── Data Normalizers ───────────────────────────────────────
    function normalizeAttack(a) {
        return {
            id:           a.id || a.code || null,
            code:         a.code || null,
            ts:           a.timestamp_ended || a.ended || a.timestamp || 0,
            attackerId:   a.attacker?.id || a.attacker_id || null,
            defenderId:   a.defender?.id || a.defender_id || null,
            defenderName: a.defender?.name || a.defender_name || "",
            result:       a.result || "",
            respect:      Number(a.respect ?? a.respect_gain ?? 0) || 0,
        };
    }

    // ── Event Processors ───────────────────────────────────────
    // Attacks carry NO money in the Torn API — they only provide wins,
    // respect, and defender names (used to label mug events from the log).
    function processAttacks(rawAttacks, myUserId) {
        const events = [], nameMap = new Map();
        for (const raw of rawAttacks) {
            const a = normalizeAttack(raw);
            if (!a.ts) continue;
            if (a.defenderId && a.defenderName) nameMap.set(Number(a.defenderId), a.defenderName);
            if (myUserId && a.attackerId && Number(a.attackerId) !== Number(myUserId)) continue;
            if (!WIN_RESULTS.has(a.result)) continue;
            const uid = a.code || a.id || `${a.ts}_${a.defenderId}`;
            const respStr = a.respect > 0 ? ` (+${a.respect.toFixed(2)} resp)` : "";
            events.push({
                id:     `atk_${uid}`,
                type:   EVENT_TYPES.ATTACK,
                amount: 0,
                ts:     a.ts,
                label:  `${a.result} — ${a.defenderName || "Player"}${respStr}`,
                meta:   { targetId: a.defenderId, targetName: a.defenderName, respect: a.respect, result: a.result },
            });
        }
        return { events, nameMap };
    }

    // Money comes from the activity log: mug entries carry data.money_mugged,
    // bounty collections carry the payout. Parsed defensively by field/title
    // so exact log type IDs don't matter.
    function processLog(entries, nameMap) {
        const events = [];
        for (const e of entries) {
            const ts = e.timestamp || 0;
            if (!ts || !e.logId) continue;
            const d     = (e.data && typeof e.data === "object") ? e.data : {};
            const title = String(e.title || "");

            const mug = Number(d.money_mugged || 0);
            if (mug > 0) {
                const tid  = d.defender || d.defender_id || null;
                const name = (tid && nameMap.get(Number(tid))) || (tid ? `Player ${tid}` : "Player");
                events.push({
                    id:     `mug_${e.logId}`,
                    type:   EVENT_TYPES.MUGGING,
                    amount: Math.round(mug),
                    ts,
                    label:  `Mugged ${name}`,
                    meta:   { targetId: tid, targetName: name, title },
                });
                continue;
            }

            if (/bounty/i.test(title) && /collect|reward/i.test(title) && !/place/i.test(title)) {
                const amt = Number(d.money ?? d.money_gained ?? d.amount ?? 0);
                if (amt > 0) {
                    events.push({
                        id:     `bnty_${e.logId}`,
                        type:   EVENT_TYPES.BOUNTY,
                        amount: Math.round(amt),
                        ts,
                        label:  title,
                        meta:   { title },
                    });
                }
            }
        }
        return events;
    }

    function mergeEvents(existing, incoming) {
        const seen = new Set(existing.map(e => e.id));
        const added = incoming.filter(e => e.id && !seen.has(e.id));
        return [...existing, ...added].sort((a, b) => b.ts - a.ts);
    }

    function pruneEvents(events, settings) {
        const cutoff = Math.floor(Date.now()/1000) - settings.retentionDays * 86400;
        return events.filter(e => e.ts >= cutoff).slice(0, settings.maxEvents);
    }

    // ── Analytics ──────────────────────────────────────────────
    function getRange(period) {
        const now = Math.floor(Date.now()/1000);
        switch (period) {
            case "today": {
                const d = new Date(); d.setHours(0,0,0,0);
                return { from: Math.floor(d.getTime()/1000), to: now, label:"Today", days:1 };
            }
            case "week":   return { from: now - 7*86400,  to: now, label:"Last 7 Days",  days:7  };
            case "month":  return { from: now - 30*86400, to: now, label:"Last 30 Days", days:30 };
            case "3month": return { from: now - 90*86400, to: now, label:"Last 90 Days", days:90 };
            default:       return { from: 0,              to: now, label:"All Time",     days:0  };
        }
    }

    function filterByPeriod(events, period, settings) {
        const { from, to } = getRange(period);
        return events.filter(e => {
            if (e.ts < from || e.ts > to) return false;
            if (e.type === EVENT_TYPES.MUGGING && !settings.includeMuggings) return false;
            if (e.type === EVENT_TYPES.BOUNTY  && !settings.includeBounties) return false;
            if (e.type === EVENT_TYPES.ATTACK  && !settings.includeAttacks)  return false;
            return true;
        });
    }

    function groupByType(events) {
        const g = {};
        for (const e of events) {
            if ((e.amount||0) <= 0) continue;
            if (!g[e.type]) g[e.type] = { total:0, count:0 };
            g[e.type].total += e.amount;
            g[e.type].count++;
        }
        return g;
    }

    function groupByDay(events, days) {
        const now = Math.floor(Date.now()/1000);
        const buckets = Array.from({length: days}, (_, i) => {
            const dayEnd   = now - i*86400;
            const dayStart = dayEnd - 86400;
            const dayEvts  = events.filter(e => e.ts >= dayStart && e.ts < dayEnd);
            const total    = dayEvts.reduce((s,e) => s + (e.amount||0), 0);
            const mid      = new Date((dayStart + 43200)*1000);
            return {
                label: mid.toLocaleDateString([], {month:"short", day:"numeric"}),
                total, count: dayEvts.length,
            };
        }).reverse();
        const hasValue = buckets.some(b => b.total > 0);
        return buckets.map(b => ({ ...b, displayVal: hasValue ? b.total : b.count, isCounts: !hasValue }));
    }

    function groupByTarget(events) {
        const t = {};
        for (const e of events) {
            if (!e.meta?.targetId || (e.amount||0) <= 0) continue;
            const id = e.meta.targetId;
            if (!t[id]) t[id] = { id, name: e.meta.targetName || `Player ${id}`, total:0, count:0 };
            t[id].total += e.amount;
            t[id].count++;
        }
        return Object.values(t).sort((a,b) => b.total - a.total);
    }

    function rankByCount(events) {
        const t = {};
        for (const e of events) {
            if (!e.meta?.targetId) continue;
            const id = e.meta.targetId;
            if (!t[id]) t[id] = { id, name: e.meta.targetName || `Player ${id}`, total:0, count:0 };
            t[id].total += e.amount || 0;
            t[id].count++;
        }
        return Object.values(t).sort((a,b) => b.count - a.count);
    }

    function buildWeeklyComparison(events) {
        const now   = Math.floor(Date.now()/1000);
        const weeks = [];
        for (let w = 0; w < 4; w++) {
            const from  = now - (w+1)*7*86400;
            const to    = now - w*7*86400;
            const evts  = events.filter(e => e.ts >= from && e.ts < to);
            const total = evts.reduce((s,e) => s + (e.amount||0), 0);
            const lbl   = w === 0 ? "This Week" : w === 1 ? "Last Week" : `${w+1} Weeks Ago`;
            weeks.push({ label: lbl, total, count: evts.length });
        }
        return weeks;
    }

    function computeSnapDelta(snaps, periodSec) {
        if (snaps.length < 2) return null;
        const now     = Math.floor(Date.now()/1000);
        const recent  = snaps[snaps.length - 1];
        const cutoff  = now - periodSec;
        const earlier = [...snaps].reverse().find(s => s.ts <= cutoff);
        if (!earlier) return null;
        const delta = {};
        for (const f of SNAP_FIELDS) {
            if (recent[f] != null && earlier[f] != null) {
                delta[f] = recent[f] - earlier[f];
            }
        }
        return delta;
    }

