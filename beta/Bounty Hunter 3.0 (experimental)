// @license      GPL-3.0-or-later
// ==/UserScript==

/* eslint-disable no-undef */
(function () {
    'use strict';

    const PDA_API_KEY   = "###PDA-APIKEY###";
    const PDA_PLACEHOLDER = "###" + "PDA-APIKEY" + "###";
    const VERSION = "3.1.1";

    const LS = {
        apiKey:   "bh3_apiKey",
        ffKey:    "bh3_ffKey",
        settings: "bh3_settings",
        filters:  "bh3_filters",
        tracked:  "bh3_tracked",
    };

    // ── Filter option tables ───────────────────────────────────
    const PRICE_OPTS = [
        {v:"0",         l:"Any reward"},
        {v:"50000",     l:"$50k+"},
        {v:"250000",    l:"$250k+"},
        {v:"500000",    l:"$500k+"},
        {v:"1000000",   l:"$1M+"},
        {v:"2500000",   l:"$2.5M+"},
        {v:"5000000",   l:"$5M+"},
        {v:"10000000",  l:"$10M+"},
        {v:"25000000",  l:"$25M+"},
    ];

    const HOSP_OPTS = [
        {v:"99999", l:"Any time remaining"},
        {v:"120",   l:"Under 2 min"},
        {v:"300",   l:"Under 5 min"},
        {v:"600",   l:"Under 10 min"},
        {v:"1800",  l:"Under 30 min"},
        {v:"3600",  l:"Under 1 hr"},
        {v:"7200",  l:"Under 2 hr"},
    ];

    const FF_OPTS = [
        {v:"any", l:"Any FF",    min:0,   max:99},
        {v:"lt15",l:"FF < 1.5", min:0,   max:1.499},
        {v:"1520",l:"FF 1.5–2", min:1.5, max:2.0},
        {v:"2025",l:"FF 2–2.5", min:2.0, max:2.5},
        {v:"2530",l:"FF 2.5–3", min:2.5, max:3.0},
        {v:"gt30",l:"FF 3.0+",  min:3.0, max:99},
    ];

    const BS_OPTS = [
        {v:"any",l:"Any BS",      min:0,           max:Infinity},
        {v:"bs1", l:"2k – 25k",   min:2_000,       max:25_000},
        {v:"bs2", l:"20k – 250k", min:20_000,      max:250_000},
        {v:"bs3", l:"200k – 2.5m",min:200_000,     max:2_500_000},
        {v:"bs4", l:"2m – 25m",   min:2_000_000,   max:25_000_000},
        {v:"bs5", l:"20m – 250m", min:20_000_000,  max:250_000_000},
        {v:"bs6", l:"200m+",      min:200_000_000, max:Infinity},
    ];

    const WAR_OPTS = [
        {v:"all", l:"All targets"},
        {v:"hide",l:"Hide war targets"},
        {v:"only",l:"War targets only"},
    ];

    const STATUS_OPTS = [
        {v:"all",      l:"Any status"},
        {v:"okay",     l:"Okay only"},
        {v:"hospital", l:"Hospital only"},
        {v:"traveling",l:"Traveling only"},
    ];

    const DEFAULT_SETTINGS = {
        refreshSec: 60,
        toastsEnabled: true,
        includeUnknownFF: true,
    };

    const DEFAULT_FILTERS = {
        minPrice:     "500000",
        hospMax:      "99999",
        ffRange:      "any",
        bsBracket:    "any",
        warMode:      "all",
        statusFilter: "all",
    };

    // ── API + URL constants ────────────────────────────────────
    const API_BASE          = "https://api.torn.com/v2";
    const FF_BASE           = "https://ffscouter.com/api/v1";
    const API_DELAY_MS      = 750;
    const PROFILE_URL       = "https://www.torn.com/profiles.php?XID=";
    const ATTACK_URL        = "https://www.torn.com/page.php?sid=attack&user2ID=";
    const STATUS_CACHE_MS   = 20_000;
    const STATUS_CONCURRENCY= 3;
    const FACTION_CACHE_MS  = 5 * 60 * 1000;
    const SPA_LS_APIKEY     = "spa_apiKey";

    const IS_PDA      = typeof PDA_httpGet === "function";
    const HAS_PDA_KEY = PDA_API_KEY !== PDA_PLACEHOLDER && /^[A-Za-z0-9]{16}$/.test(PDA_API_KEY);
    const GM_XHR      = (typeof GM_xmlhttpRequest !== "undefined") ? GM_xmlhttpRequest : null;

    // ── Utilities ──────────────────────────────────────────────
    const sleep = (ms) => new Promise(r => setTimeout(r, ms));

    function escHtml(s) {
        return String(s == null ? "" : s)
            .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    function parseBS(human) {
        if (!human) return null;
        const m = String(human).match(/^\s*([\d.]+)\s*([kKmMbB]?)\s*$/);
        if (!m) return null;
        const n = parseFloat(m[1]);
        if (!Number.isFinite(n)) return null;
        const mult = {k:1e3,m:1e6,b:1e9}[(m[2]||"").toLowerCase()] || 1;
        return n * mult;
    }

    function openTornUrl(url) {
        const a = document.createElement("a"); a.href = url; a.target = "_blank";
        a.rel = "noopener noreferrer"; document.body.appendChild(a); a.click(); a.remove();
    }

    function revivableEmoji(rev, state) {
        if (state !== "Hospital") return "—";
        if (rev === true) return "💚"; if (rev === false) return "❌"; return "⚠️";
    }

    const fmt = {
        money(n) {
            if (n == null) return "$0";
            const a = Math.abs(n);
            const s = a >= 1e9 ? (a/1e9).toFixed(2)+"B" : a >= 1e6 ? (a/1e6).toFixed(2)+"M" : a >= 1e3 ? (a/1e3).toFixed(1)+"K" : a.toLocaleString();
            return (n < 0 ? "-$" : "$") + s;
        },
        moneyFull(n) { return (n < 0 ? "-" : "") + "$" + Math.abs(n).toLocaleString(); },
        hospLabel(untilSec) {
            const rem = Math.max(0, untilSec - Math.floor(Date.now()/1000));
            if (rem <= 0) return "🏥 out";
            const h = Math.floor(rem/3600), m = Math.floor((rem%3600)/60), s = rem%60;
            if (h > 0) return `🏥 ${h}h ${m}m`;
            return m === 0 ? `🏥 ${s}s` : `🏥 ${m}m ${s}s`;
        },
    };

    function loadSettings() { try { return {...DEFAULT_SETTINGS, ...JSON.parse(localStorage.getItem(LS.settings)||"{}")}; } catch { return {...DEFAULT_SETTINGS}; } }
    function saveSettings(s) { localStorage.setItem(LS.settings, JSON.stringify(s)); }
    function loadFilters()  { try { return {...DEFAULT_FILTERS,  ...JSON.parse(localStorage.getItem(LS.filters)||"{}")}; }  catch { return {...DEFAULT_FILTERS}; } }
    function saveFilters(f) { localStorage.setItem(LS.filters, JSON.stringify(f)); }

    // ── HTTP layer ─────────────────────────────────────────────
    function _gmGet(url) {
        return new Promise((resolve, reject) => {
            GM_XHR({
                method:"GET", url,
                onload:(r)   => resolve({status:r.status, text:r.responseText}),
                onerror:()   => reject(new Error("network_error")),
                ontimeout:() => reject(new Error("timeout")),
            });
        });
    }

    async function _httpGetOnceRaw(url) {
        if (IS_PDA) {
            let r;
            try { r = await PDA_httpGet(url); } catch(e) { throw new Error("PDA network error: " + (e?.message || e)); }
            if (!r || r.status < 200 || r.status >= 300) { const e = new Error(`HTTP ${r?.status ?? "no response"}`); e.status = r?.status; throw e; }
            return JSON.parse(r.responseText || "null");
        }
        if (GM_XHR) {
            const r = await _gmGet(url);
            if (!r || r.status < 200 || r.status >= 300) { const e = new Error(`HTTP ${r?.status ?? "no response"}`); e.status = r?.status; throw e; }
            return JSON.parse(r.text || "null");
        }
        const r = await fetch(url);
        if (!r.ok) { const e = new Error(`HTTP ${r.status}`); e.status = r.status; throw e; }
        return r.json();
    }

    async function httpGetJson(url) {
        try { return await _httpGetOnceRaw(url); }
        catch(err) { if (err.status >= 400 && err.status < 500) throw err; await sleep(400); return _httpGetOnceRaw(url); }
    }

    function isRateLimit(err) { return err && (err.status === 429 || err.tornCode === 5); }

    // ── Torn API ───────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key = key; this._last = 0; }
        setKey(key) { this.key = key; }

        async _rl() { const w = API_DELAY_MS - (Date.now() - this._last); this._last = Date.now() + Math.max(0, w); if (w > 0) await sleep(w); }

        async _get(pathOrUrl, params = null) {
            await this._rl();
            const url = new URL(/^https?:\/\//.test(pathOrUrl) ? pathOrUrl : API_BASE + pathOrUrl);
            if (params) for (const [k,v] of Object.entries(params)) url.searchParams.set(k, v);
            if (!url.searchParams.has("key")) url.searchParams.set("key", this.key);
            const data = await httpGetJson(url.toString());
            if (data && data.error) { const e = new Error(data.error.error || "API error"); e.tornCode = data.error.code; throw e; }
            return data;
        }

        async fetchAllBounties() {
            const all = []; let url = `${API_BASE}/torn/bounties?limit=100&offset=0`, delay = 0, safety = 10;
            while (url && safety-- > 0) {
                const data = await this._get(url);
                if (Array.isArray(data.bounties)) all.push(...data.bounties);
                if (typeof data.bounties_delay === "number") delay = data.bounties_delay;
                const next = data._metadata?.links?.next;
                if (!next || !data.bounties || data.bounties.length === 0) break;
                url = next;
            }
            return {bounties: all, delaySec: delay};
        }

        async fetchUserProfile(id) {
            const d = await this._get(`/user/${id}/profile`);
            return d?.profile || (d?.id ? d : null);
        }

        async validateKey() {
            const d = await this._get("/user/profile");
            return d?.profile || null;
        }

        async fetchWarFactions() {
            const ids = new Set();
            try {
                const d = await this._get("https://api.torn.com/torn/?selections=rankedwars,territorywars");
                for (const w of Object.values(d.rankedwars || {}))
                    for (const fid of Object.keys(w.factions || {})) { const n = Number(fid); if (n > 0) ids.add(n); }
                for (const w of Object.values(d.territorywars || {}))
                    for (const k of ["assaulting_faction","defending_faction"]) { const n = Number(w[k]); if (n > 0) ids.add(n); }
            } catch {}
            return ids;
        }
    }

    // ── FFScouter ──────────────────────────────────────────────
    async function fetchFFStats(key, ids) {
        const out = new Map();
        if (!key || ids.length === 0) return out;
        for (let i = 0; i < ids.length; i += 200) {
            const chunk = ids.slice(i, i + 200);
            try {
                const data = await httpGetJson(`${FF_BASE}/get-stats?key=${encodeURIComponent(key)}&targets=${chunk.join(",")}`);
                if (!Array.isArray(data)) continue;
                for (const p of data) {
                    if (p.fair_fight != null) out.set(Number(p.player_id), {ff: Number(p.fair_fight), bs: p.bs_estimate_human || null});
                }
            } catch {}
        }
        return out;
    }

    async function validateFFKey(key) {
        if (!/^[A-Za-z0-9]{16}$/.test(key)) return {ok:false, msg:"Must be 16 alphanumeric characters."};
        try {
            const d = await httpGetJson(`${FF_BASE}/check-key?key=${encodeURIComponent(key)}`);
            if (d?.code) return {ok:false, msg:d.error || "FFScouter error"};
            if (!d?.is_registered) return {ok:false, msg:"Key not registered — sign up at ffscouter.com."};
            return {ok:true, msg: d.is_premium ? "Valid (premium)." : "Valid."};
        } catch(e) { return {ok:false, msg:e?.message || "Could not reach FFScouter."}; }
    }

    // ── KeyResolver ────────────────────────────────────────────
    const KR = {
        tornKey() { if (HAS_PDA_KEY) return PDA_API_KEY; return localStorage.getItem(LS.apiKey) || null; },
        ffKey()   { return localStorage.getItem(LS.ffKey) || ""; },
        saveTorn(k) { localStorage.setItem(LS.apiKey, k); },
        saveFF(k)   { localStorage.setItem(LS.ffKey, k); },
        clearTorn() { localStorage.removeItem(LS.apiKey); },
        clearFF()   { localStorage.removeItem(LS.ffKey); },
        isPDA()     { return HAS_PDA_KEY; },
        hasSPA()    { const k = localStorage.getItem(SPA_LS_APIKEY); return !!k && /^[A-Za-z0-9]{16}$/.test(k); },
        getSPA()    { return localStorage.getItem(SPA_LS_APIKEY); },
    };

    // ── TrackedStore ───────────────────────────────────────────
    const TrackedStore = {
        load() { try { return JSON.parse(localStorage.getItem(LS.tracked) || "[]"); } catch { return []; } },
        save(list) { try { localStorage.setItem(LS.tracked, JSON.stringify(list)); } catch {} },
        has(id) { return this.load().some(t => t.id === Number(id)); },
        add(t) {
            const list = this.load();
            if (!list.some(x => x.id === Number(t.id))) {
                list.push({id: Number(t.id), name: String(t.name || `Player ${t.id}`), level: Number(t.level) || 0, addedAt: Date.now()});
                this.save(list);
            }
        },
        remove(id) { this.save(this.load().filter(t => t.id !== Number(id))); },
        updateMeta(id, patch) {
            const list = this.load(), t = list.find(x => x.id === Number(id));
            if (t) { Object.assign(t, patch); this.save(list); }
        },
    };

    // ── Hunter ─────────────────────────────────────────────────
    class Hunter {
        constructor(api) {
            this.api      = api;
            this.settings = loadSettings();
            this.filters  = loadFilters();
            this.myUserId = null;
            this._allBounties   = [];   // all deduped bounties (for getBounty lookup on tracking tab)
            this._bounties      = [];   // pre-filtered + profile-enriched candidates (for hunt table)
            this._ffMap         = new Map();  // bounty player id → {ff, bs}
            this._warSet        = new Set();
            this._warFetchedAt  = 0;
            this._profileCache  = new Map();  // id → {data, at}
            this._trackedStatuses = new Map(); // id → {state, until, revivable, inFactionWar, description}
            this._trackedFF       = new Map(); // id → {ff, bs}
            this._timer   = null; this._running = false; this._nextAt = 0;
            this.lastError = null; this.lastCounts = null; this._loadingMsg = null;
            this.onUpdate         = null;
            this.onToast          = null;
            this.onTrackedUpdate  = null;
        }

        updateSettings(next) { this.settings = {...this.settings, ...next}; saveSettings(this.settings); }
        updateFilters(next)  { this.filters  = {...this.filters,  ...next}; saveFilters(this.filters); }

        // Pre-filter by price/FF/BS using only data available before profile fetches.
        // Conservative: only exclude when we KNOW a bounty fails (never exclude on missing data).
        _preFilter(bounties) {
            const f = this.filters;
            const minPrice = Number(f.minPrice) || 0;
            const ffOpt = FF_OPTS.find(o => o.v === f.ffRange)   || FF_OPTS[0];
            const bsOpt = BS_OPTS.find(o => o.v === f.bsBracket) || BS_OPTS[0];
            return bounties.filter(b => {
                if (b.reward < minPrice) return false;
                if (ffOpt.v !== "any" && b.ff !== null) {
                    if (b.ff < ffOpt.min || b.ff > ffOpt.max) return false;
                }
                if (bsOpt.v !== "any" && b.bs !== null) {
                    const bsNum = parseBS(b.bs);
                    if (bsNum !== null && (bsNum < bsOpt.min || bsNum > bsOpt.max)) return false;
                }
                return true;
            });
        }

        start() { if (this._running) return; this._running = true; this._tick(); }
        stop()  { if (this._timer) { clearTimeout(this._timer); this._timer = null; } this._running = false; }

        async _tick() {
            if (!this._running) return;
            let waitSec = this.settings.refreshSec;
            try {
                const delay = await this.refresh();
                waitSec = Math.max(this.settings.refreshSec, delay || 0);
            } catch(err) {
                this.lastError   = err;
                this._loadingMsg = null;
                if (this.onUpdate) this.onUpdate();
                waitSec = Math.max(this.settings.refreshSec, 30);
            }
            await this.refreshTracked().catch(() => {});
            if (this.settings.refreshSec <= 0) return;
            this._nextAt = Date.now() + waitSec * 1000;
            this._timer  = setTimeout(() => this._tick(), waitSec * 1000);
        }

        async refresh() {
            this.lastError  = null;
            this._loadingMsg = "Fetching bounties…";
            if (this.onUpdate) this.onUpdate({loading: true});

            try { const p = await this.api.validateKey(); if (p) this.myUserId = p.id || this.myUserId; } catch {}

            const {bounties, delaySec} = await this.api.fetchAllBounties();

            // Deduplicate by target_id, keep highest reward, sum bounty counts
            const grouped = new Map();
            for (const b of bounties) {
                const id = String(b.target_id), qty = (b.quantity > 0 ? b.quantity : 1);
                if (!grouped.has(id)) { grouped.set(id, {...b, bountyCount: qty}); }
                else {
                    const ex = grouped.get(id); ex.bountyCount += qty;
                    if (b.reward > ex.reward) grouped.set(id, {...b, bountyCount: ex.bountyCount});
                }
            }
            const deduped = [...grouped.values()].filter(b => !this.myUserId || b.target_id !== this.myUserId);

            // ── Phase 1: Bulk FF/BS fetch (1 API call regardless of bounty count) ──
            this._loadingMsg = `Fetching FF data for ${deduped.length} targets…`;
            if (this.onUpdate) this.onUpdate({loading: true});

            const allIds = deduped.map(b => Number(b.target_id));
            this._ffMap  = await fetchFFStats(KR.ffKey(), allIds);

            // Stamp FF/BS onto every bounty entry so pre-filter can use it
            for (const b of deduped) {
                const ff = this._ffMap.get(Number(b.target_id));
                b.ff = ff?.ff ?? null;
                b.bs = ff?.bs ?? null;
                b.statusState = null; b.hospUntil = 0;
                b.revivable = null; b.inFactionWar = false;
            }

            // Pre-filter by price/FF/BS — no profile data needed for these
            const candidates = this._preFilter(deduped);

            // Fetch war factions (cached, 1 call per 5 min)
            this._warSet = await this._getWarFactions();

            // ── Phase 2: Profile fetch for candidates only ──
            this._loadingMsg = `Fetching ${candidates.length} profile${candidates.length===1?"":"s"} (filtered from ${deduped.length})…`;
            if (this.onUpdate) this.onUpdate({loading: true});

            const candidateIds = candidates.map(b => Number(b.target_id));
            const profiles = await this._fetchProfiles(candidateIds);

            // Enrich candidates with profile data (status, war, revivable, name, level)
            for (const b of candidates) {
                const p = profiles.get(Number(b.target_id));
                b.statusState  = p?.status?.state  ?? null;
                b.hospUntil    = p?.status?.until   ?? 0;
                b.revivable    = p?.revivable        ?? null;
                b.inFactionWar = !!(p?.faction_id && this._warSet.has(Number(p.faction_id)));
                if (p?.name)                     b.target_name  = p.name;
                if (typeof p?.level === "number") b.target_level = p.level;
            }

            this._allBounties = deduped;     // full set — used by getBounty() for tracking tab
            this._bounties    = candidates;  // profile-enriched candidates — used by hunt table
            this.lastCounts   = {total: bounties.length, deduped: deduped.length, candidates: candidates.length};
            this._loadingMsg  = null;

            if (this.onUpdate) this.onUpdate({loading: false});
            if (this.settings.toastsEnabled && this.onToast) this.onToast(this.applyFilters(this._bounties));
            return delaySec;
        }

        async _getWarFactions() {
            const now = Date.now();
            if (this._warSet.size > 0 && (now - this._warFetchedAt) < FACTION_CACHE_MS) return this._warSet;
            const ids = await this.api.fetchWarFactions();
            this._warFetchedAt = now;
            return ids;
        }

        async _fetchProfiles(ids) {
            const out = new Map(), now = Date.now(), stale = [], unique = [...new Set(ids)];
            for (const id of unique) {
                const c = this._profileCache.get(id);
                if (c && (now - c.at) < STATUS_CACHE_MS) { out.set(id, c.data); continue; }
                stale.push(id);
            }
            let i = 0, rateErr = null;
            await Promise.all(Array.from({length: STATUS_CONCURRENCY}, async () => {
                while (i < stale.length && !rateErr) {
                    const id = stale[i++];
                    try {
                        const p = await this.api.fetchUserProfile(id);
                        if (p) {
                            const data = {
                                status:     p.status  ?? null,
                                age:        p.age     ?? null,
                                faction_id: p.faction?.id ?? p.faction?.faction_id ?? p.faction_id ?? null,
                                revivable:  typeof p.revivable === "boolean" ? p.revivable : null,
                                name:       p.name || p.player_name || null,
                                level:      typeof p.level === "number" ? p.level : null,
                            };
                            out.set(id, data); this._profileCache.set(id, {data, at: Date.now()});
                        }
                    } catch(err) { if (isRateLimit(err)) { rateErr = err; return; } }
                }
            }));
            if (rateErr) throw rateErr;
            return out;
        }

        // Apply all current filter dropdowns to a list of enriched bounties
        applyFilters(list) {
            const f = this.filters, nowSec = Math.floor(Date.now() / 1000);
            const minPrice = Number(f.minPrice) || 0;
            const hospMax  = Number(f.hospMax) >= 99999 ? Infinity : Number(f.hospMax);
            const ffOpt    = FF_OPTS.find(o => o.v === f.ffRange)    || FF_OPTS[0];
            const bsOpt    = BS_OPTS.find(o => o.v === f.bsBracket)  || BS_OPTS[0];
            const inclUnk  = !!this.settings.includeUnknownFF;

            return list.filter(b => {
                if (b.reward < minPrice) return false;

                // Status filter
                const state = b.statusState;
                if (f.statusFilter === "okay"      && state !== "Okay")                                  return false;
                if (f.statusFilter === "hospital"   && state !== "Hospital")                              return false;
                if (f.statusFilter === "traveling"  && state !== "Traveling" && state !== "Abroad")       return false;

                // Hospital time remaining (only applies to hospital targets)
                if (state === "Hospital") {
                    const rem = Math.max(0, (b.hospUntil || 0) - nowSec);
                    if (rem > hospMax) return false;
                }

                // FF filter
                if (b.ff === null) { if (!inclUnk) return false; }
                else { if (b.ff < ffOpt.min || b.ff > ffOpt.max) return false; }

                // BS bracket
                if (bsOpt.v !== "any" && b.bs != null) {
                    const bsNum = parseBS(b.bs);
                    if (bsNum != null && (bsNum < bsOpt.min || bsNum > bsOpt.max)) return false;
                }

                // Clan war filter
                if (f.warMode === "hide" && b.inFactionWar)  return false;
                if (f.warMode === "only" && !b.inFactionWar) return false;

                return true;
            });
        }

        // Full refresh of all tracked players (runs after each main cycle)
        async refreshTracked() {
            const targets = TrackedStore.load();
            if (targets.length === 0) {
                this._trackedStatuses = new Map(); this._trackedFF = new Map();
                if (this.onTrackedUpdate) this.onTrackedUpdate(); return;
            }
            const ids = targets.map(t => Number(t.id));
            const profiles = await this._fetchProfiles(ids);
            const warSet   = await this._getWarFactions();
            const ffKey    = KR.ffKey();

            // Fetch FF for tracked players not already covered by the bounty ffMap
            const needFF = ids.filter(id => !this._ffMap.has(id));
            if (needFF.length > 0 && ffKey) {
                const extra = await fetchFFStats(ffKey, needFF);
                for (const [k,v] of extra) this._trackedFF.set(k, v);
            }
            for (const [k,v] of this._ffMap) this._trackedFF.set(k, v);

            const statuses = new Map();
            for (const t of targets) {
                const p = profiles.get(Number(t.id));
                if (p?.name && p.name !== t.name) TrackedStore.updateMeta(t.id, {name: p.name});
                if (p?.level && p.level !== t.level) TrackedStore.updateMeta(t.id, {level: p.level});
                statuses.set(t.id, {
                    state:        p?.status?.state       ?? null,
                    until:        p?.status?.until        ?? 0,
                    revivable:    p?.revivable            ?? null,
                    inFactionWar: !!(p?.faction_id && warSet.has(Number(p.faction_id))),
                    description:  p?.status?.description  ?? "",
                });
            }
            this._trackedStatuses = statuses;
            if (this.onTrackedUpdate) this.onTrackedUpdate();
        }

        // Immediately fetch a single player after the Track button is clicked
        async refreshOneTracked(id) {
            const profiles = await this._fetchProfiles([Number(id)]);
            const warSet   = await this._getWarFactions();
            const ffKey    = KR.ffKey();
            if (ffKey) { const extra = await fetchFFStats(ffKey, [Number(id)]); for (const [k,v] of extra) this._trackedFF.set(k, v); }
            const p = profiles.get(Number(id));
            this._trackedStatuses.set(id, {
                state:        p?.status?.state      ?? null,
                until:        p?.status?.until       ?? 0,
                revivable:    p?.revivable           ?? null,
                inFactionWar: !!(p?.faction_id && warSet.has(Number(p?.faction_id))),
                description:  p?.status?.description ?? "",
            });
            if (this.onTrackedUpdate) this.onTrackedUpdate();
        }

        // Look up whether a player currently has a bounty on the board.
        // Uses _allBounties so tracked players below the current price filter still show their bounty.
        getBounty(id) { return this._allBounties.find(b => b.target_id === Number(id)) || null; }

        secondsUntilRefresh() { return Math.max(0, Math.round((this._nextAt - Date.now()) / 1000)); }
    }

