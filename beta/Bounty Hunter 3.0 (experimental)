    // ── Toaster ────────────────────────────────────────────────
    class Toaster {
        constructor() { this._con = null; this._cards = []; }
        _ensure() {
            if (this._con && document.body.contains(this._con)) return;
            const c = document.createElement("div"); c.id = "bh3-toasts"; document.body.appendChild(c); this._con = c;
        }
        showNew(matches, prevIds) {
            const newOnes = prevIds ? matches.filter(b => !prevIds.has(`${b.target_id}|${b.reward}`)) : matches;
            if (!newOnes.length) return;
            this._ensure();
            for (const b of newOnes.slice(0, 3)) this._show(b);
        }
        _show(b) {
            const stale = this._cards.find(c => c.id === Number(b.target_id)); if (stale) this._rm(stale);
            const el = document.createElement("div"); el.className = "bh3-toast";
            const isH = b.statusState === "Hospital";
            const wb  = b.inFactionWar ? `<span class="bh3-chip">⚔️ War</span>` : "";
            el.innerHTML = `<button class="bh3-tc">&times;</button><div class="bh3-th"><span class="bh3-tn">${escHtml(b.target_name)} <span style="color:#555;font-size:11px">L${b.target_level}</span></span><span class="bh3-tr">${escHtml(fmt.money(b.reward))}</span></div><div class="bh3-tm">${b.ff!=null?`<span class="bh3-chip">FF ${b.ff.toFixed(2)}</span>`:""}<span class="bh3-chip ${isH?"bh3-hosp":"bh3-ok"}">${isH?fmt.hospLabel(b.hospUntil):"Okay"}</span>${wb}</div><button class="bh3-ta">Attack</button>`;
            const card = {id: Number(b.target_id), el, timer: null, rem: 12000, at: 0};
            el.querySelector(".bh3-tc").addEventListener("click", e => { e.stopPropagation(); this._rm(card); });
            el.querySelector(".bh3-ta").addEventListener("click", () => { openTornUrl(ATTACK_URL + b.target_id); this._rm(card); });
            el.addEventListener("pointerenter", () => this._pause(card));
            el.addEventListener("pointerleave", () => this._resume(card));
            this._resume(card); this._con.appendChild(el); this._cards.push(card);
        }
        _pause(c)  { if (!c.timer) return; clearTimeout(c.timer); c.timer = null; c.rem = Math.max(0, c.rem - (Date.now() - c.at)); }
        _resume(c) { c.at = Date.now(); if (c.timer) clearTimeout(c.timer); c.timer = setTimeout(() => this._rm(c), c.rem); }
        _rm(c)     { if (c.timer) clearTimeout(c.timer); c.el?.parentNode?.removeChild(c.el); this._cards = this._cards.filter(x => x !== c); }
        clearAll() { for (const c of [...this._cards]) this._rm(c); }
    }

    // ── UI ─────────────────────────────────────────────────────
    class UI {
        constructor(hunter, toaster) {
            this.hunter   = hunter; this.toaster = toaster;
            this.activeTab = "hunt";
            this._panel = null; this._overlay = null; this._authed = false;
            this._sortCol = "reward"; this._sortDir = "desc";
            this._refreshing = false;
            this._prevMatchIds = new Set();
            this._cdTimer = null;
        }

        inject() {
            injectCSS();
            const overlay = document.createElement("div"); overlay.id = "bh3-overlay"; document.body.appendChild(overlay);
            const panel   = document.createElement("div"); panel.id   = "bh3-panel";
            panel.innerHTML = `<div id="bh3-header"><h2>Bounty Hunter <span style="color:#555;font-size:11px;margin-left:6px">v${VERSION}</span></h2><button id="bh3-close">&times;</button></div><div id="bh3-tabs"><div class="bh3-tab active" data-tab="hunt">Hunt</div><div class="bh3-tab" data-tab="tracking">Tracking 🎯</div><div class="bh3-tab" data-tab="settings">Settings</div></div><div id="bh3-content" style="display:flex;flex-direction:column;flex:1;min-height:0;overflow:hidden"></div>`;
            document.body.appendChild(panel); this._panel = panel; this._overlay = overlay;

            overlay.addEventListener("click", () => this.toggle(false));
            panel.querySelector("#bh3-close").addEventListener("click", () => this.toggle(false));
            panel.querySelector("#bh3-tabs").addEventListener("click", e => {
                const t = e.target.closest(".bh3-tab"); if (!t) return;
                this.activeTab = t.dataset.tab; this._syncTabs(); this._renderActive();
            });

            this.hunter.onUpdate = () => { if (this._isOpen()) this._renderActive(); };
            this.hunter.onToast  = (matches) => {
                this.toaster.showNew(matches, this._prevMatchIds);
                this._prevMatchIds = new Set(matches.map(b => `${b.target_id}|${b.reward}`));
            };
            this.hunter.onTrackedUpdate = () => { if (this._isOpen() && this.activeTab === "tracking") this._renderTracking(); };

            this._cdTimer = setInterval(() => {
                if (!this._isOpen()) return;
                const cdEl = document.getElementById("bh3-cd"); if (cdEl) cdEl.textContent = this.hunter.secondsUntilRefresh();
                document.querySelectorAll("[data-hu]").forEach(el => { const u = parseInt(el.dataset.hu, 10); if (Number.isFinite(u)) el.textContent = fmt.hospLabel(u); });
            }, 1000);
        }

        _isOpen() { return !!this._panel?.classList.contains("bh3-open"); }
        toggle(open) {
            const isOpen = open != null ? open : !this._isOpen();
            this._panel.classList.toggle("bh3-open", isOpen);
            this._overlay.classList.toggle("bh3-open", isOpen);
            if (isOpen) this._renderActive();
        }
        _syncTabs() { for (const t of this._panel.querySelectorAll(".bh3-tab")) t.classList.toggle("active", t.dataset.tab === this.activeTab); }
        _renderActive() { if (!this._authed) { this._renderAuth(); return; } if (this.activeTab === "hunt") this._renderHunt(); else if (this.activeTab === "tracking") this._renderTracking(); else this._renderSettings(); }
        setAuthed(v) { this._authed = v; if (this._isOpen()) this._renderActive(); }

        // ── Auth ───────────────────────────────────────────────
        _renderAuth() {
            const con = this._panel.querySelector("#bh3-content");
            const spaOk = !IS_PDA && KR.hasSPA();
            con.innerHTML = `<div id="bh3-auth"><h3>Set your Torn API key</h3><p style="color:#888;font-size:13px">Bounty Hunter 3.0 requires a <b>Public</b> access Torn API key. Stored locally and only sent to <code>api.torn.com</code>.</p><div class="bh3-fld" style="margin-top:14px"><label>Torn API key (16 chars)</label><input id="bh3-ak" class="bh3-inp bh3-inp-m" type="text" maxlength="16" spellcheck="false" autocomplete="off" data-lpignore="true"></div><div class="bh3-rowa"><button id="bh3-asave" class="bh3-btn bh3-btn-p">Save &amp; start</button>${spaOk?`<button id="bh3-aspa" class="bh3-btn bh3-btn-m">Use SPA key</button>`:""}</div><p id="bh3-aerr" class="bh3-ss bh3-err2" style="min-height:1em"></p><hr style="border:none;border-top:1px solid #242424;margin:16px 0"><h3 style="margin:0 0 8px">FFScouter key <span style="color:#555;font-size:12px;font-weight:400">(optional)</span></h3><p style="color:#666;font-size:12px">Required for the FF and BS bracket filters.</p><div class="bh3-fld"><label>FFScouter key (16 chars)</label><input id="bh3-affk" class="bh3-inp bh3-inp-m" type="text" maxlength="16" spellcheck="false" autocomplete="off" data-lpignore="true" value="${escHtml(KR.ffKey())}"></div></div>`;
            const ki = con.querySelector("#bh3-ak"), err = con.querySelector("#bh3-aerr");
            const doSave = async () => {
                err.textContent = ""; const k = ki.value.trim();
                if (!/^[A-Za-z0-9]{16}$/.test(k)) { err.textContent = "Needs to be 16 alphanumeric characters."; return; }
                await this._adoptKey(k, con.querySelector("#bh3-affk").value.trim());
            };
            con.querySelector("#bh3-asave").addEventListener("click", doSave);
            ki.addEventListener("keydown", e => { if (e.key === "Enter") doSave(); });
            const spaBtn = con.querySelector("#bh3-aspa");
            if (spaBtn) spaBtn.addEventListener("click", async () => { const k = KR.getSPA(); if (!k) return; await this._adoptKey(k, con.querySelector("#bh3-affk").value.trim()); });
        }
        async _adoptKey(tornKey, ffKey) {
            const err = this._panel.querySelector("#bh3-aerr");
            if (err) err.textContent = "Validating…";
            this.hunter.api.setKey(tornKey);
            try { await this.hunter.api.validateKey(); } catch(e) { if (err) err.textContent = "Key rejected: " + (e.message || "invalid"); return; }
            KR.saveTorn(tornKey);
            if (ffKey && /^[A-Za-z0-9]{16}$/.test(ffKey)) KR.saveFF(ffKey);
            this.setAuthed(true); this.hunter.start();
        }

        // ── Hunt tab ───────────────────────────────────────────
        _renderHunt() {
            const con = this._panel.querySelector("#bh3-content");
            const f   = this.hunter.filters;
            const matches = this.hunter.applyFilters(this.hunter._bounties);
            const sorted  = this._sortList(matches);
            const cnt     = this.hunter.lastCounts;
            const lmsg    = this.hunter._loadingMsg;
            const errLine = this.hunter.lastError ? `<span class="bh3-err">${escHtml(this.hunter.lastError.message||"error")}</span>` : "";
            const noFF    = !KR.ffKey() && !this.hunter.settings.includeUnknownFF ? `<span class="bh3-err">No FFScouter key — unknown-FF targets excluded. Enable in Settings or add FFScouter key.</span>` : "";
            const countLine = lmsg
                ? `<span style="color:#777">${escHtml(lmsg)}</span>`
                : cnt
                    ? `<span>${sorted.length} shown · ${cnt.candidates} candidates · ${cnt.deduped} unique · ${cnt.total} raw</span>`
