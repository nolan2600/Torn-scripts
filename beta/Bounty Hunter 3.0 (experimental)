    // ── Profile Track Button ───────────────────────────────────
    function setupProfileInjector(hunter, ui) {
        let lastUrl = "", lastXid = "";
        const tryInject = () => {
            const url = location.href;
            if (!url.includes("profiles.php")) { const b = document.getElementById("bh3-tb"); if (b) b.remove(); lastXid = ""; return; }
            const xid = new URLSearchParams(location.search).get("XID") || "";
            if (!xid) { const b = document.getElementById("bh3-tb"); if (b) b.remove(); lastXid = ""; return; }
            if (document.getElementById("bh3-tb") && lastXid === xid) return;
            const prev = document.getElementById("bh3-tb"); if (prev) prev.remove();
            lastXid = xid;
            const id = Number(xid); if (!id) return;
            let name = `Player ${id}`, level = 0;
            for (const sel of ["[class*='playerName']","[class*='player-name']","[class*='name___']",".profile-header h4","h4.bold"]) {
                const el = document.querySelector(sel);
                if (el && el.textContent.trim() && el.textContent.trim().length < 40) { name = el.textContent.trim(); break; }
            }
            const isTracked = TrackedStore.has(id);
            const btn = document.createElement("button");
            btn.id = "bh3-tb"; btn.className = "bh3-tb" + (isTracked ? " bh3-tb-on" : "");
            btn.textContent = isTracked ? "✓ Tracked" : "🎯 Track";
            btn.addEventListener("click", async () => {
                if (TrackedStore.has(id)) {
                    TrackedStore.remove(id);
                    btn.textContent = "🎯 Track";
                    btn.classList.remove("bh3-tb-on");
                } else {
                    TrackedStore.add({id, name, level});
                    btn.textContent = "⏳ Fetching…";
                    btn.disabled = true;
                    try { await hunter.refreshOneTracked(id); } catch {}
                    btn.textContent = "✓ Tracked";
                    btn.classList.add("bh3-tb-on");
                    btn.disabled = false;
                    // Open tracking tab
                    ui.activeTab = "tracking";
                    if (!ui._isOpen()) ui.toggle(true);
                    else { ui._syncTabs(); ui._renderActive(); }
                }
            });
            document.body.appendChild(btn);
        };
        setInterval(() => { if (location.href !== lastUrl) { lastUrl = location.href; setTimeout(tryInject, 500); setTimeout(tryInject, 1500); } }, 400);
        tryInject(); setTimeout(tryInject, 800); setTimeout(tryInject, 2000);
    }

