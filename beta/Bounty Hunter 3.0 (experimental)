            const bsCell  = b.bs ? escHtml(b.bs) : "—";
            const revCell = revivableEmoji(b.revivable, b.statusState);
            return `<tr class="${warRow}"><td><a class="bh3-link" href="${PROFILE_URL}${b.target_id}" target="_blank" rel="noopener">${escHtml(b.target_name)}</a><span style="color:#444;font-size:11px"> L${b.target_level}</span>${countBadge}${warBadge}</td><td class="num">${escHtml(fmt.moneyFull(b.reward))}</td><td class="num">${ffCell}</td><td class="num">${bsCell}</td><td>${statusCell}</td><td class="bh3-rev" title="${revCell==="💚"?"Revivable":revCell==="❌"?"Not revivable":"—"}">${revCell}</td><td><button class="bh3-atk" data-id="${b.target_id}">Attack</button></td></tr>`;
