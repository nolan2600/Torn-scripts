        _rowHTML(b) {
            const isH    = b.statusState === "Hospital";
            const warRow = b.inFactionWar ? " bh3-row-war" : "";
            const warBadge = b.inFactionWar ? `<span class="bh3-war-badge" title="Faction is in an active war — outside attackers blocked">⚔️ War</span>` : "";
            const countBadge = b.bountyCount > 1 ? `<span class="bh3-count">×${b.bountyCount}</span>` : "";
