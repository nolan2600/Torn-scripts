`;
        document.head.appendChild(s);
    }

    // ── UI ─────────────────────────────────────────────────────
    class AnalyticsUI {
        constructor() {
            this._panel   = null;
            this._overlay = null;
            this.tab      = "overview";
            this.period   = "week";
            this.settings = loadSettings();
            this.syncing  = false;
            this.lastSync = 0;
            this.lastErr  = null;
            this.myId     = null;
            this._ticker  = null;
            this._syncTmr = null;
        }

        init() {
            injectCSS();
            this._registerEugene();
        }

        _registerEugene() {
            const W = (typeof unsafeWindow !== "undefined") ? unsafeWindow : window;
            const tryReg = () => {
                if (W.registerEugeneScript) {
                    W.registerEugeneScript({
                        id: "torn-analytics", name: "Analytics",
                        color: "#1565c0", colorDark: "#0d3a6e", hoverColor: "#1976d2",
                        iconSVG: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><defs><linearGradient id="ta_g" x1=".5" x2=".5" y2="1" gradientUnits="objectBoundingBox"><stop offset="0" stop-color="#ddd"/><stop offset="1" stop-color="#999"/></linearGradient></defs><g fill="url(#ta_g)"><path d="M5 20h2v-8H5v8zm4 0h2V4H9v16zm4 0h2v-5h-2v5zm4 0h2V9h-2v11z"/></g></svg>`,
                        onClick: () => this.toggle(true),
                    });
                } else {
                    setTimeout(tryReg, 500);
                }
            };
            tryReg();
        }

        toggle(open) {
            const isOpen = open != null ? open : !(this._panel && this._panel.classList.contains("ta-open"));
            if (isOpen) this._open(); else this._close();
        }

        _open() {
            injectCSS();
            if (!this._panel) this._build();
            this._panel.classList.add("ta-open");
            this._overlay.classList.add("ta-open");
            this._renderBody();
            this._startTicker();
            // Auto-sync on open if stale
            const key = KeyResolver.resolveTornKey();
            if (key && (Date.now() - this.lastSync) > this.settings.refreshSec * 1000) {
                this.syncData();
            }
        }

        _close() {
            if (this._panel)   this._panel.classList.remove("ta-open");
            if (this._overlay) this._overlay.classList.remove("ta-open");
            this._stopTicker();
        }

        _build() {
            const overlay = document.createElement("div");
            overlay.id = "ta-overlay";
            overlay.addEventListener("click", () => this._close());
            document.body.appendChild(overlay);
            this._overlay = overlay;

            const panel = document.createElement("div");
            panel.id = "ta-panel";
            panel.innerHTML = `
                <div id="ta-header">
                    <h2>📊 Profit Analytics <span class="ta-ver">v${VERSION}</span></h2>
                    <button id="ta-close" title="Close">✕</button>
                </div>
                <div id="ta-tabs">
                    <button class="ta-tab active" data-tab="overview">Overview</button>
                    <button class="ta-tab" data-tab="sources">By Source</button>
                    <button class="ta-tab" data-tab="top">Top Events</button>
                    <button class="ta-tab" data-tab="trends">Trends</button>
                    <button class="ta-tab" data-tab="settings">Settings</button>
                </div>
                <div id="ta-body"></div>
                <div id="ta-footer">
                    <span id="ta-status-txt">—</span>
                    <button class="ta-btn ta-btn-primary ta-btn-sm" id="ta-sync-btn">⟳ Sync</button>
                </div>`;
            document.body.appendChild(panel);
            this._panel = panel;

            panel.querySelector("#ta-close").addEventListener("click", () => this._close());
            panel.querySelectorAll(".ta-tab").forEach(t =>
                t.addEventListener("click", () => { this.tab = t.dataset.tab; this._syncTabs(); this._renderBody(); })
            );
            panel.querySelector("#ta-sync-btn").addEventListener("click", () => this.syncData());
        }

        _syncTabs() {
            this._panel.querySelectorAll(".ta-tab").forEach(t =>
                t.classList.toggle("active", t.dataset.tab === this.tab)
            );
        }

        _startTicker() {
            if (this._ticker) return;
            this._ticker = setInterval(() => this._tickFooter(), 5000);
        }
        _stopTicker() { if (this._ticker) { clearInterval(this._ticker); this._ticker = null; } }

        _tickFooter() {
            const el = this._panel && this._panel.querySelector("#ta-status-txt");
            if (!el) return;
            if (this.syncing) { el.textContent = "⟳ Syncing…"; return; }
            if (this.lastErr) { el.textContent = `❌ ${this.lastErr}`; return; }
            if (this.lastSync > 0) {
                const events = loadEvents();
                el.textContent = `${events.length} events · synced ${fmt.relTime(Math.floor(this.lastSync/1000))}`;
            } else {
                el.textContent = "No data yet — click ⟳ Sync";
            }
        }

        _renderBody() {
            const body = this._panel && this._panel.querySelector("#ta-body");
            if (!body) return;
            const key = KeyResolver.resolveTornKey();
            if (!key) { body.innerHTML = this._authHTML(); this._wireAuth(body); this._tickFooter(); return; }
            switch (this.tab) {
                case "overview": body.innerHTML = this._overviewHTML(); this._wirePeriod(body); break;
                case "sources":  body.innerHTML = this._sourcesHTML(); this._wirePeriod(body); break;
                case "top":      body.innerHTML = this._topHTML();     this._wirePeriod(body); break;
                case "trends":   body.innerHTML = this._trendsHTML();  break;
                case "settings": body.innerHTML = this._settingsHTML(); this._wireSettings(body); break;
            }
            this._tickFooter();
        }

        // ── Auth ──────────────────────────────────────────────
        _authHTML() {
            return `<div style="padding:8px 0">
                <div style="font-size:14px;font-weight:700;margin-bottom:10px">API Key Required</div>
                <div class="ta-field">
                    <label>Torn API Key (16 characters)</label>
                    <div class="ta-key-row">
                        <input type="text" class="ta-input" id="ta-auth-inp" maxlength="16" placeholder="Paste your key here" autocomplete="off" data-lpignore="true" />
                        <button class="ta-btn ta-btn-primary" id="ta-auth-save">Save</button>
                    </div>
                    <div id="ta-auth-msg" class="ta-save-status"></div>
                </div>
                <p style="font-size:11px;color:#666;margin-top:6px">
                    Get your key at <a class="ta-link" href="https://www.torn.com/preferences.php#tab=api" target="_blank">Torn → Preferences → API Key</a>. "Public" access is sufficient.
                </p>
            </div>`;
        }

        _wireAuth(body) {
            const inp = body.querySelector("#ta-auth-inp");
            const btn = body.querySelector("#ta-auth-save");
            const msg = body.querySelector("#ta-auth-msg");
            const save = async () => {
                const k = inp.value.trim();
                if (!/^[A-Za-z0-9]{16}$/.test(k)) { msg.className = "ta-save-status ta-save-err"; msg.textContent = "Must be exactly 16 alphanumeric characters."; return; }
                btn.disabled = true;
                msg.className = "ta-save-status ta-save-info"; msg.textContent = "Validating…";
                try {
                    const api  = new TornAPI(k);
                    const prof = await api.validateKey();
                    if (!prof) throw new Error("Key rejected or insufficient access.");
                    KeyResolver.saveKey(k);
                    this.myId = prof.id || prof.player_id;
                    msg.className = "ta-save-status ta-save-ok";
                    msg.textContent = `✓ Valid — ${prof.name || "Player"} [${this.myId}]`;
                    setTimeout(() => { this._renderBody(); this.syncData(); }, 1200);
                } catch (e) {
                    msg.className = "ta-save-status ta-save-err"; msg.textContent = e.message || "Validation failed.";
                } finally { btn.disabled = false; }
            };
            btn.addEventListener("click", save);
            inp.addEventListener("keydown", e => { if (e.key === "Enter") save(); });
        }

        // ── Period selector ───────────────────────────────────
        _periodRow() {
            const periods = [
                {id:"today",label:"Today"},{id:"week",label:"7 Days"},
                {id:"month",label:"30 Days"},{id:"3month",label:"90 Days"},{id:"all",label:"All Time"},
            ];
            return `<div class="ta-period-row">${periods.map(p =>
                `<button class="ta-period-btn${p.id===this.period?" active":""}" data-period="${p.id}">${p.label}</button>`
            ).join("")}</div>`;
        }

        _wirePeriod(container) {
            container.querySelectorAll(".ta-period-btn").forEach(btn =>
                btn.addEventListener("click", () => { this.period = btn.dataset.period; this._renderBody(); })
            );
        }

        _events() { return filterByPeriod(loadEvents(), this.period, this.settings); }

        // ── Overview ──────────────────────────────────────────
        _overviewHTML() {
            const events  = this._events();
            const stats   = calcStats(events);
            const { label, days } = getRange(this.period);
            const allEvts = loadEvents().filter(e => (e.amount||0) > 0);
            const allTot  = allEvts.reduce((s,e) => s + e.amount, 0);
            const dAvg    = days > 0 ? stats.total / days : stats.total;

            const cards = `<div class="ta-cards">
                <div class="ta-card">
                    <div class="ta-card-lbl">${escHtml(label)} Profit</div>
                    <div class="ta-card-val">${escHtml(fmt.money(stats.total))}</div>
                    <div class="ta-card-sub">${stats.count} events</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">Avg per Event</div>
                    <div class="ta-card-val">${escHtml(fmt.money(stats.avg))}</div>
                    <div class="ta-card-sub">Best single: ${escHtml(fmt.money(stats.best))}</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">Daily Average</div>
                    <div class="ta-card-val">${escHtml(fmt.money(dAvg))}</div>
                    <div class="ta-card-sub">over ${escHtml(label.toLowerCase())}</div>
                </div>
                <div class="ta-card">
                    <div class="ta-card-lbl">All-Time Total</div>
                    <div class="ta-card-val">${escHtml(fmt.money(allTot))}</div>
                    <div class="ta-card-sub">${allEvts.length} events tracked</div>
                </div>
            </div>`;

            // Always show at least 7 days in the bar chart for readability
            const chartDays = days <= 1 ? 7 : Math.min(days, 30);
            const chartPeriod = chartDays <= 7 ? "week" : chartDays <= 30 ? "month" : "3month";
            const chart = this._barChart(filterByPeriod(loadEvents(), chartPeriod, this.settings), chartDays);

            const recent = events.filter(e => (e.amount||0) > 0 || e.type === EVENT_TYPES.ATTACK).slice(0, 12);

            return `${this._periodRow()}${cards}
                <div class="ta-section-hd">Daily Trend</div>
                ${chart}
                <div class="ta-section-hd">Recent Activity</div>
                ${this._eventListHTML(recent)}`;
        }

        _barChart(events, days) {
            const buckets = groupByDay(events, days);
            const maxVal  = Math.max(...buckets.map(b => b.total), 1);
            const bars    = buckets.map(b => {
                const h = Math.max(2, Math.round((b.total / maxVal) * 100));
                return `<div class="ta-bar-col" title="${escHtml(b.label)}: ${escHtml(fmt.money(b.total))} (${b.count} events)">
                    <div class="ta-bar-fill${b.total===0?" ta-bar-zero":""}" style="height:${h}%"></div>
                </div>`;
            }).join("");
            return `<div class="ta-chart">
                <div class="ta-bars">${bars}</div>
                <div class="ta-chart-axis">
                    <span>${escHtml(buckets[0]?.label||"")}</span>
                    <span>Today</span>
                </div>
            </div>`;
        }

        _eventListHTML(events) {
            if (events.length === 0) return `<div class="ta-empty"><div class="ta-empty-icon">📭</div>No events for this period.<br>Click ⟳ Sync to fetch data.</div>`;
            return `<div class="ta-event-list">${events.map(e => {
                const tc   = TYPE_CONFIG[e.type] || {icon:"•"};
                const pos  = (e.amount||0) > 0;
                const amtS = pos ? "+" + fmt.money(e.amount)
                           : e.type === EVENT_TYPES.ATTACK ? fmt.money(e.meta?.respect||0) + " resp"
                           : fmt.money(0);
                return `<div class="ta-event-row">
                    <div class="ta-event-icon">${tc.icon}</div>
                    <div class="ta-event-lbl" title="${escHtml(e.label)}">${escHtml(e.label)}</div>
                    <div class="ta-event-amt ${pos?"pos":"zero"}">${escHtml(amtS)}</div>
                    <div class="ta-event-time">${fmt.relTime(e.ts)}</div>
                </div>`;
            }).join("")}</div>`;
        }

        // ── Sources ───────────────────────────────────────────
        _sourcesHTML() {
            const events   = this._events().filter(e => (e.amount||0) > 0);
            const groups   = groupByType(events);
            const grandTot = events.reduce((s,e) => s + e.amount, 0);

            if (Object.keys(groups).length === 0) {
                return `${this._periodRow()}<div class="ta-empty"><div class="ta-empty-icon">📊</div>No profitable events for this period.</div>`;
            }

            const rows = Object.entries(groups)
                .sort((a,b) => b[1].total - a[1].total)
                .map(([type, g]) => {
                    const tc  = TYPE_CONFIG[type] || {icon:"•", label:type, color:"#888"};
                    const pct = grandTot > 0 ? g.total/grandTot*100 : 0;
                    const avg = g.count > 0 ? g.total/g.count : 0;
                    return `<tr>
                        <td><span class="ta-badge" style="background:${tc.color}1a;color:${tc.color}">${tc.icon} ${tc.label}</span></td>
                        <td class="num" style="color:#aaa">${g.count}</td>
                        <td class="num" style="color:#66bb6a;font-weight:700">${escHtml(fmt.money(g.total))}</td>
                        <td>
                            <span class="ta-pbar-bg"><span class="ta-pbar-fill" style="width:${pct.toFixed(1)}%;background:${tc.color};display:block;height:100%;border-radius:3px"></span></span>
                            <span style="font-size:10px;color:#777;margin-left:5px">${fmt.pct(pct)}</span>
                        </td>
                        <td class="num" style="color:#888">${escHtml(fmt.money(avg))}</td>
                    </tr>`;
                }).join("");

            return `${this._periodRow()}
                <table class="ta-tbl">
                    <thead><tr>
                        <th>Source</th><th class="num">Events</th>
                        <th class="num">Total Profit</th><th>Share</th>
                        <th class="num">Avg / Event</th>
                    </tr></thead>
                    <tbody>${rows}</tbody>
                    <tfoot>
                        <tr style="border-top:1px solid #333">
                            <td style="color:#777;font-weight:700;font-size:11px">TOTAL</td>
                            <td class="num" style="color:#777">${events.length}</td>
                            <td class="num" style="color:#4fc3f7;font-weight:700">${escHtml(fmt.money(grandTot))}</td>
                            <td></td>
                            <td class="num" style="color:#777">${escHtml(fmt.money(grandTot/(events.length||1)))}</td>
                        </tr>
                    </tfoot>
                </table>`;
        }

        // ── Top Events ────────────────────────────────────────
        _topHTML() {
            const events      = this._events().filter(e => (e.amount||0) > 0);
            const topEvents   = [...events].sort((a,b) => b.amount - a.amount).slice(0, 15);
            const topTargets  = groupByTarget(filterByPeriod(loadEvents(), this.period, this.settings)).slice(0, 10);

            const evtHTML = topEvents.length === 0
                ? `<div class="ta-empty"><div class="ta-empty-icon">🏆</div>No events yet for this period.</div>`
                : topEvents.map((e, i) => {
                    const tc = TYPE_CONFIG[e.type] || {icon:"•"};
                    return `<div class="ta-top-item">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-icon">${tc.icon}</div>
                        <div class="ta-top-lbl" title="${escHtml(e.label)}">${escHtml(e.label)}</div>
                        <div class="ta-top-amt">${escHtml(fmt.money(e.amount))}</div>
                        <div class="ta-top-meta">${fmt.relTime(e.ts)}</div>
                    </div>`;
                }).join("");

            const tgtHTML = topTargets.length === 0
                ? `<div style="padding:6px;color:#666;font-size:12px">No target data available.</div>`
                : topTargets.map((t, i) =>
                    `<div class="ta-top-item">
                        <div class="ta-top-rank">#${i+1}</div>
                        <div class="ta-event-icon">🎯</div>
                        <div class="ta-top-lbl"><a class="ta-link" href="https://www.torn.com/profiles.php?XID=${t.id}" target="_blank" rel="noopener">${escHtml(t.name)}</a></div>
                        <div class="ta-top-amt">${escHtml(fmt.money(t.total))}</div>
                        <div class="ta-top-meta">${t.count} hit${t.count===1?"":"s"}</div>
                    </div>`
                ).join("");

            return `${this._periodRow()}
                <div class="ta-section-hd">Top Individual Events</div>
                ${evtHTML}
                <div class="ta-section-hd">Most Profitable Targets</div>
                ${tgtHTML}`;
        }

        // ── Trends ────────────────────────────────────────────
        _trendsHTML() {
            const allEvts = loadEvents().filter(e => (e.amount||0) > 0 &&
                (this.settings.includeMuggings && e.type===EVENT_TYPES.MUGGING ||
                 this.settings.includeBounties && e.type===EVENT_TYPES.BOUNTY  ||
                 this.settings.includeCrimes   && e.type===EVENT_TYPES.CRIME   ||
                 this.settings.includeAttacks  && e.type===EVENT_TYPES.ATTACK));

            const weeks   = buildWeeklyComparison(allEvts);
            const maxWeek = Math.max(...weeks.map(w => w.total), 1);
            const weekRows = weeks.map(w => `
                <div class="ta-cmp-row">
                    <div class="ta-cmp-lbl">${escHtml(w.label)}</div>
                    <div class="ta-cmp-bar-wrap">
                        <div class="ta-cmp-bar-bg">
                            <div class="ta-cmp-bar-fill" style="width:${(w.total/maxWeek*100).toFixed(1)}%"></div>
                        </div>
                        <div style="font-size:10px;color:#555;margin-top:1px">${w.count} events</div>
                    </div>
                    <div class="ta-cmp-amt">${escHtml(fmt.money(w.total))}</div>
                </div>`).join("");

            // Monthly bars (last 6 months)
            const now = Math.floor(Date.now()/1000);
            const months = Array.from({length:6}, (_,i) => {
                const to   = now - i*30*86400;
                const from = to - 30*86400;
                const evts = allEvts.filter(e => e.ts >= from && e.ts < to);
                const tot  = evts.reduce((s,e) => s + e.amount, 0);
                const d    = new Date((from + 15*86400)*1000);
                return { label: d.toLocaleDateString([], {month:"short", year:"2-digit"}), total: tot, count: evts.length };
            }).reverse();
            const maxMo = Math.max(...months.map(m => m.total), 1);
            const moRows = months.map(m => `
                <div class="ta-cmp-row">
                    <div class="ta-cmp-lbl">${escHtml(m.label)}</div>
                    <div class="ta-cmp-bar-wrap">
                        <div class="ta-cmp-bar-bg">
                            <div class="ta-cmp-bar-fill" style="width:${(m.total/maxMo*100).toFixed(1)}%"></div>
                        </div>
                        <div style="font-size:10px;color:#555;margin-top:1px">${m.count} events</div>
                    </div>
                    <div class="ta-cmp-amt">${escHtml(fmt.money(m.total))}</div>
                </div>`).join("");

            const snaps   = loadSnapshots();
            const delta7  = computeSnapDelta(snaps, 7*86400);
            const delta30 = computeSnapDelta(snaps, 30*86400);

            const snapField = (label, key, d7, d30) => {
                const v7  = d7  && d7[key]  != null ? d7[key]  : null;
                const v30 = d30 && d30[key] != null ? d30[key] : null;
                if (v7 == null && v30 == null) return "";
                const fmtN = (n) => n == null ? "—" : n.toLocaleString();
                return `<div class="ta-snap-row">
                    <div class="ta-snap-key">${escHtml(label)}</div>
                    <div style="display:flex;gap:16px">
                        <div class="ta-snap-val" title="7-day change">${fmtN(v7)} <span style="color:#555;font-size:10px">7d</span></div>
                        <div class="ta-snap-val" title="30-day change">${fmtN(v30)} <span style="color:#555;font-size:10px">30d</span></div>
                    </div>
                </div>`;
            };

            const snapHTML = snaps.length >= 2 ? `
                <div class="ta-section-hd">Personal Stats Deltas</div>
                <div style="font-size:10px;color:#555;margin-bottom:8px">${snaps.length} snapshots · last: ${fmt.relTime(snaps[snaps.length-1]?.ts||0)}</div>
                ${snapField("Attacks Won",   "attackswon",   delta7, delta30)}
                ${snapField("Money Mugged",  "moneymugged",  delta7, delta30)}
                ${snapField("Crimes",        "criminaloffenses", delta7, delta30)}
                ${snapField("Bazaar Sales",  "bazaarsales",  delta7, delta30)}
                ${snapField("Bazaar Profit", "bazaarprofit", delta7, delta30)}
                ${snapField("Nerve Refills", "nerverefills", delta7, delta30)}
            ` : `<div class="ta-section-hd">Personal Stats Deltas</div>
