// ==UserScript==
// @name         Torn Profit Analytics
// @namespace    https://github.com/nolan2600/torn-scripts
// @version      1.0.0
// @description  Track daily/weekly/monthly profits from muggings, bounties, crimes and more — with source breakdown, top events, and trend charts.
// @author       DieselBlade
// @match        https://www.torn.com/*
// @grant        GM_xmlhttpRequest
// @grant        unsafeWindow
// @connect      api.torn.com
// @license      GPL-3.0-or-later
// ==/UserScript==

/* eslint-disable no-undef */

(function () {
    "use strict";

    const PDA_API_KEY     = "###PDA-APIKEY###";
    const PDA_PLACEHOLDER = "###" + "PDA-APIKEY" + "###";
    const VERSION         = "1.0.0";
    const API_BASE        = "https://api.torn.com/v2";
    const API_DELAY_MS    = 750;
    const SPA_LS_APIKEY   = "spa_apiKey";

    const LS = {
        apiKey:        "ta_apiKey",
        settings:      "ta_settings_v1",
        events:        "ta_events_v1",
        snapshots:     "ta_snapshots_v1",
        lastAttackTs:  "ta_last_attack_ts",
        lastCrimeTs:   "ta_last_crime_ts",
        lastSnapTs:    "ta_last_snap_ts",
    };

    const EVENT_TYPES = { MUGGING:"mugging", BOUNTY:"bounty", CRIME:"crime", ATTACK:"attack" };

    const TYPE_CONFIG = {
        mugging: { label:"Mugging",    color:"#ef5350", icon:"💰" },
        bounty:  { label:"Bounty",     color:"#ffd700", icon:"🎯" },
        crime:   { label:"Crime",      color:"#ab47bc", icon:"🔪" },
        attack:  { label:"Attack Win", color:"#4fc3f7", icon:"⚔️"  },
    };

    const DEFAULT_SETTINGS = {
        includeMuggings:  true,
        includeBounties:  true,
        includeCrimes:    true,
        includeAttacks:   false,
        refreshSec:       300,
        retentionDays:    90,
        maxEvents:        5000,
        snapEvery:        3600, // personalstats snapshot interval (seconds)
    };

    const SNAP_FIELDS = [
        "attackswon","attackslost","moneymugged","defendslost",
        "criminaloffenses","nerverefills","bazaarsales","bazaarprofit",
        "networth","respectforfaction","useractivity",
    ];

    const IS_PDA      = typeof PDA_httpGet === "function";
    const HAS_PDA_KEY = PDA_API_KEY !== PDA_PLACEHOLDER && /^[A-Za-z0-9]{16}$/.test(PDA_API_KEY);
    const GM_XHR      = (typeof GM_xmlhttpRequest !== "undefined") ? GM_xmlhttpRequest : null;

    // ── Utilities ──────────────────────────────────────────────
    function escHtml(s) {
        return String(s == null ? "" : s)
            .replace(/&/g,"&amp;").replace(/</g,"&lt;")
            .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    const fmt = {
        money(n) {
            if (n == null) return "$0";
            const a = Math.abs(n);
            const s = a >= 1e9 ? (a/1e9).toFixed(2)+"B"
                    : a >= 1e6 ? (a/1e6).toFixed(2)+"M"
                    : a >= 1e3 ? (a/1e3).toFixed(1)+"K"
                    : a.toLocaleString();
            return (n < 0 ? "-$" : "$") + s;
        },
        moneyFull(n) { return (n < 0 ? "-$" : "$") + Math.abs(n).toLocaleString(); },
        date(ts)     { return new Date(ts * 1000).toLocaleDateString(); },
        relTime(ts)  {
            const d = Math.floor(Date.now()/1000) - ts;
            if (d < 60)    return `${d}s ago`;
            if (d < 3600)  return `${Math.floor(d/60)}m ago`;
            if (d < 86400) return `${Math.floor(d/3600)}h ago`;
            return `${Math.floor(d/86400)}d ago`;
        },
        pct(n) { return (n == null ? 0 : n).toFixed(1) + "%"; },
    };

    const sleep = (ms) => new Promise(r => setTimeout(r, ms));

    // ── Storage ────────────────────────────────────────────────
    function loadSettings()   { try { const r = localStorage.getItem(LS.settings); return {...DEFAULT_SETTINGS,...(r?JSON.parse(r):{})}; } catch { return {...DEFAULT_SETTINGS}; } }
    function saveSettings(s)  { localStorage.setItem(LS.settings, JSON.stringify(s)); }
    function loadEvents()     { try { const r = localStorage.getItem(LS.events); return r ? JSON.parse(r) : []; } catch { return []; } }
    function loadSnapshots()  { try { const r = localStorage.getItem(LS.snapshots); return r ? JSON.parse(r) : []; } catch { return []; } }

    function saveEvents(events) {
        try { localStorage.setItem(LS.events, JSON.stringify(events)); }
        catch { try { localStorage.setItem(LS.events, JSON.stringify(events.slice(-1000))); } catch {} }
    }
    function saveSnapshots(snaps) {
        try { localStorage.setItem(LS.snapshots, JSON.stringify(snaps.slice(-365))); } catch {}
    }
    function getTs(key)     { try { return parseInt(localStorage.getItem(key)||"0",10); } catch { return 0; } }
    function setTs(key, ts) { try { localStorage.setItem(key, String(ts)); } catch {} }

    // ── Key Resolver ───────────────────────────────────────────
    const KeyResolver = {
        resolveTornKey() {
            if (HAS_PDA_KEY) return PDA_API_KEY;
            const k = localStorage.getItem(LS.apiKey);
            if (k) return k;
            return localStorage.getItem(SPA_LS_APIKEY) || null;
        },
        saveKey(k)   { localStorage.setItem(LS.apiKey, k); },
        clearKey()   { localStorage.removeItem(LS.apiKey); },
        isPDAKey()   { return HAS_PDA_KEY; },
    };

    // ── HTTP ───────────────────────────────────────────────────
    function _gmGet(url) {
        return new Promise((resolve, reject) => {
            GM_XHR({ method:"GET", url,
                onload:   r => resolve({status:r.status, text:r.responseText}),
                onerror:  () => reject(new Error("network_error")),
                ontimeout:() => reject(new Error("timeout")),
            });
        });
    }

    async function httpGetJson(url) {
        if (IS_PDA) {
            const res = await PDA_httpGet(url);
            if (res.status < 200 || res.status >= 300) { const e = new Error(`HTTP ${res.status}`); e.status = res.status; throw e; }
            return JSON.parse(res.responseText);
        }
        if (GM_XHR) {
            const res = await _gmGet(url);
            if (res.status < 200 || res.status >= 300) { const e = new Error(`HTTP ${res.status}`); e.status = res.status; throw e; }
            return JSON.parse(res.text);
        }
        const res = await fetch(url);
        if (!res.ok) { const e = new Error(`HTTP ${res.status}`); e.status = res.status; throw e; }
        return res.json();
    }

    // ── Torn API ───────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key = key; this._lastReq = 0; }
        setKey(key) { this.key = key; }

        async _rateLimit() { const w = API_DELAY_MS - (Date.now() - this._lastReq); if (w > 0) await sleep(w); this._lastReq = Date.now(); }

        async _get(path, params = {}) {
            await this._rateLimit();
            const url = new URL(/^https?:\/\//.test(path) ? path : API_BASE + path);
            for (const [k, v] of Object.entries(params)) url.searchParams.set(k, v);
            if (!url.searchParams.has("key")) url.searchParams.set("key", this.key);
            const data = await httpGetJson(url.toString());
            if (data && data.error) { const e = new Error(data.error.error || "Torn API error"); e.tornCode = data.error.code; throw e; }
            return data;
        }

        async validateKey() {
            const data = await this._get("/user/profile");
            return (data && data.profile) || (data && data.id ? data : null);
        }

        async fetchAttacks(fromTs = 0) {
            const all = []; let offset = 0; let pages = 0;
            while (pages < 20) {
                const params = { limit: 100, offset };
                if (fromTs > 0) params.from = fromTs + 1; // +1 avoids re-fetching the last seen
                const data = await this._get("/user/attacks", params);
                const raw = data.attacks;
                if (!raw) break;
                const arr = Array.isArray(raw) ? raw : Object.values(raw);
                if (arr.length === 0) break;
                all.push(...arr);
                if (arr.length < 100) break;
                offset += 100; pages++;
            }
            return all;
        }

        async fetchCrimes(fromTs = 0) {
            const all = []; let offset = 0; let pages = 0;
            while (pages < 10) {
                const params = { limit: 100, offset };
                if (fromTs > 0) params.from = fromTs + 1;
                try {
                    const data = await this._get("/user/crimes", params);
                    const raw = data.crimes;
                    if (!raw) break;
                    const arr = Array.isArray(raw) ? raw : Object.values(raw);
                    if (arr.length === 0) break;
                    all.push(...arr);
                    if (arr.length < 100) break;
                    offset += 100; pages++;
                } catch { break; } // crimes endpoint may not exist — skip silently
            }
            return all;
        }

        async fetchPersonalStats() {
            try {
                const data = await this._get("/user/personalstats");
                return data.personalstats || data || null;
            } catch { return null; }
        }
    }

    // ── Data Normalizers ───────────────────────────────────────
    function normalizeAttack(a) {
        return {
            id:           a.id || a.code || null,
            code:         a.code || null,
            ts:           a.ended || a.timestamp_ended || a.timestamp || 0,
            attackerId:   a.attacker?.id || a.attacker_id || null,
            attackerName: a.attacker?.name || a.attacker_name || "",
            defenderId:   a.defender?.id || a.defender_id || null,
            defenderName: a.defender?.name || a.defender_name || "",
            result:       a.result || "",
            moneyMugged:  a.stolen?.money || a.money_mugged || a.mug || 0,
            respect:      a.respect || a.respect_gain || 0,
        };
    }

    function normalizeCrime(c) {
        const reward = c.reward?.money || c.reward || c.cash || c.cash_gain || c.money_gain || 0;
        return {
            id:      c.id || c.crime_id || null,
            name:    c.title || c.crime_name || c.name || "Crime",
            ts:      c.time_completed || c.ended || c.timestamp || 0,
            reward:  typeof reward === "number" ? reward : 0,
            success: c.success !== false,
        };
    }

    // ── Event Processors ───────────────────────────────────────
    function processAttacks(rawAttacks, myUserId, settings) {
        const events = [];
        for (const raw of rawAttacks) {
            const a = normalizeAttack(raw);
            if (!a.ts) continue;
            if (myUserId && a.attackerId && a.attackerId !== myUserId) continue; // skip if I'm not the attacker

            const uid = a.code || a.id || `${a.ts}_${a.defenderId}`;

            if (settings.includeMuggings && a.moneyMugged > 0) {
                events.push({
                    id:     `mug_${uid}`,
                    type:   EVENT_TYPES.MUGGING,
                    amount: a.moneyMugged,
                    ts:     a.ts,
                    label:  `Mugged ${a.defenderName || "Player"}`,
                    meta:   { targetId: a.defenderId, targetName: a.defenderName, result: a.result },
                });
            }

            if (settings.includeBounties && a.result === "Bounty") {
                events.push({
                    id:     `bnty_${uid}`,
                    type:   EVENT_TYPES.BOUNTY,
                    amount: a.moneyMugged || 0,
                    ts:     a.ts,
                    label:  `Bounty — ${a.defenderName || "Player"}`,
                    meta:   { targetId: a.defenderId, targetName: a.defenderName },
                });
            }

            if (settings.includeAttacks && a.moneyMugged === 0 && a.respect > 0) {
                events.push({
                    id:     `atk_${uid}`,
                    type:   EVENT_TYPES.ATTACK,
                    amount: 0,
                    ts:     a.ts,
                    label:  `${a.result || "Win"} vs ${a.defenderName || "Player"} (+${a.respect.toFixed(2)} resp)`,
                    meta:   { targetId: a.defenderId, targetName: a.defenderName, respect: a.respect },
                });
            }
        }
        return events;
    }

    function processCrimes(rawCrimes, settings) {
        if (!settings.includeCrimes) return [];
        const events = [];
        for (const raw of rawCrimes) {
            const c = normalizeCrime(raw);
            if (!c.ts || !c.success || c.reward <= 0) continue;
            events.push({
                id:     `cr_${c.id || c.ts}`,
                type:   EVENT_TYPES.CRIME,
                amount: c.reward,
                ts:     c.ts,
                label:  c.name,
                meta:   { crimeName: c.name },
            });
        }
        return events;
    }

    function mergeEvents(existing, incoming) {
        const seen = new Set(existing.map(e => e.id));
        const added = incoming.filter(e => e.id && !seen.has(e.id));
        return [...existing, ...added].sort((a, b) => b.ts - a.ts);
    }

    function pruneEvents(events, settings) {
        const cutoff = Math.floor(Date.now()/1000) - settings.retentionDays * 86400;
        return events.filter(e => e.ts >= cutoff).slice(0, settings.maxEvents);
    }

    // ── Analytics ──────────────────────────────────────────────
    function getRange(period) {
        const now = Math.floor(Date.now()/1000);
        switch (period) {
            case "today": {
                const d = new Date(); d.setHours(0,0,0,0);
                return { from: Math.floor(d.getTime()/1000), to: now, label:"Today", days:1 };
            }
            case "week":   return { from: now - 7*86400,  to: now, label:"Last 7 Days",  days:7  };
            case "month":  return { from: now - 30*86400, to: now, label:"Last 30 Days", days:30 };
            case "3month": return { from: now - 90*86400, to: now, label:"Last 90 Days", days:90 };
            default:       return { from: 0,              to: now, label:"All Time",     days:0  };
        }
    }

    function filterByPeriod(events, period, settings) {
        const { from, to } = getRange(period);
        return events.filter(e => {
            if (e.ts < from || e.ts > to) return false;
            if (e.type === EVENT_TYPES.MUGGING && !settings.includeMuggings) return false;
            if (e.type === EVENT_TYPES.BOUNTY  && !settings.includeBounties) return false;
            if (e.type === EVENT_TYPES.CRIME   && !settings.includeCrimes)   return false;
            if (e.type === EVENT_TYPES.ATTACK  && !settings.includeAttacks)  return false;
            return true;
        });
    }

    function calcStats(events) {
        const money = events.filter(e => (e.amount||0) > 0);
        const total = money.reduce((s,e) => s + e.amount, 0);
        const count = money.length;
        return {
            total, count,
            avg:  count > 0 ? total/count : 0,
            best: count > 0 ? Math.max(...money.map(e => e.amount)) : 0,
        };
    }

    function groupByType(events) {
        const g = {};
        for (const e of events) {
            if ((e.amount||0) <= 0) continue;
            if (!g[e.type]) g[e.type] = { total:0, count:0 };
            g[e.type].total += e.amount;
            g[e.type].count++;
        }
        return g;
    }

    function groupByDay(events, days) {
        const now = Math.floor(Date.now()/1000);
        return Array.from({length: days}, (_, i) => {
            const dayEnd   = now - i*86400;
            const dayStart = dayEnd - 86400;
            const dayEvts  = events.filter(e => e.ts >= dayStart && e.ts < dayEnd && (e.amount||0) > 0);
            const total    = dayEvts.reduce((s,e) => s + e.amount, 0);
            const mid      = new Date((dayStart + 43200)*1000);
            return {
                label: mid.toLocaleDateString([], {month:"short", day:"numeric"}),
                total, count: dayEvts.length,
            };
        }).reverse();
    }

    function groupByTarget(events) {
        const t = {};
        for (const e of events) {
            if (!e.meta?.targetId || (e.amount||0) <= 0) continue;
            const id = e.meta.targetId;
            if (!t[id]) t[id] = { id, name: e.meta.targetName || `Player ${id}`, total:0, count:0 };
            t[id].total += e.amount;
            t[id].count++;
        }
        return Object.values(t).sort((a,b) => b.total - a.total);
    }

    function buildWeeklyComparison(events) {
        const now   = Math.floor(Date.now()/1000);
        const weeks = [];
        for (let w = 0; w < 4; w++) {
            const from = now - (w+1)*7*86400;
            const to   = now - w*7*86400;
            const evts = events.filter(e => e.ts >= from && e.ts < to && (e.amount||0) > 0);
            const total = evts.reduce((s,e) => s + e.amount, 0);
            const lbl   = w === 0 ? "This Week" : w === 1 ? "Last Week" : `${w+1} Weeks Ago`;
            weeks.push({ label: lbl, total, count: evts.length });
        }
        return weeks;
    }

    function computeSnapDelta(snaps, periodSec) {
        if (snaps.length < 2) return null;
        const now     = Math.floor(Date.now()/1000);
        const recent  = snaps[snaps.length - 1];
        const cutoff  = now - periodSec;
        const earlier = [...snaps].reverse().find(s => s.ts <= cutoff);
        if (!earlier) return null;
        const delta = {};
        for (const f of SNAP_FIELDS) {
            if (recent[f] != null && earlier[f] != null) {
                delta[f] = recent[f] - earlier[f];
            }
        }
        return delta;
    }

