        _wireSettings(body) {
            const msg = body.querySelector("#ta-s-msg");

            // API key save
            const keySave = body.querySelector("#ta-s-key-save");
            if (keySave) {
                keySave.addEventListener("click", async () => {
                    const k    = body.querySelector("#ta-s-key").value.trim();
                    const kMsg = body.querySelector("#ta-s-key-msg");
                    if (!/^[A-Za-z0-9]{16}$/.test(k)) { kMsg.className = "ta-save-status ta-save-err"; kMsg.textContent = "Must be 16 alphanumeric characters."; return; }
                    keySave.disabled = true;
                    kMsg.className = "ta-save-status ta-save-info"; kMsg.textContent = "Validating…";
                    try {
                        const api  = new TornAPI(k);
                        const prof = await api.validateKey();
                        if (!prof) throw new Error("Key rejected.");
                        KeyResolver.saveKey(k);
                        this.myId = prof.id;
                        kMsg.className = "ta-save-status ta-save-ok";
                        kMsg.textContent = `✓ Valid — ${prof.name || "Player"} [${prof.id}]`;
                    } catch (e) {
                        kMsg.className = "ta-save-status ta-save-err"; kMsg.textContent = e.message || "Validation failed.";
                    } finally { keySave.disabled = false; }
                });
            }

            // Settings save
            body.querySelector("#ta-s-save").addEventListener("click", () => {
                this.settings = {
                    ...this.settings,
                    includeMuggings: body.querySelector("#ta-s-mug").checked,
                    includeBounties: body.querySelector("#ta-s-bty").checked,
                    includeCrimes:   body.querySelector("#ta-s-cr").checked,
                    includeAttacks:  body.querySelector("#ta-s-atk").checked,
                    refreshSec:      Math.max(60, parseInt(body.querySelector("#ta-s-refresh").value, 10) || 300),
                    retentionDays:   Math.min(365, Math.max(7, parseInt(body.querySelector("#ta-s-retain").value, 10) || 90)),
                };
                saveSettings(this.settings);
                msg.className = "ta-save-status ta-save-ok";
                msg.textContent = "✓ Settings saved.";
                setTimeout(() => { msg.textContent = ""; }, 2000);
            });

            // Export CSV
            body.querySelector("#ta-s-export").addEventListener("click", () => {
                const events = loadEvents();
                const csv    = ["type,amount,label,date"].concat(
                    events.map(e => `${e.type},${e.amount||0},"${(e.label||"").replace(/"/g,'""')}",${fmt.date(e.ts)}`)
                ).join("\n");
                const blob = new Blob([csv], {type:"text/csv"});
                const url  = URL.createObjectURL(blob);
                const a    = document.createElement("a");
                a.href = url; a.download = `torn-analytics-${Date.now()}.csv`; a.click();
                URL.revokeObjectURL(url);
            });

            // Clear data
            body.querySelector("#ta-s-clear").addEventListener("click", () => {
                if (!confirm("Clear ALL tracked profit data? This cannot be undone.")) return;
                [LS.events, LS.snapshots, LS.lastAttackTs, LS.lastCrimeTs, LS.lastSnapTs].forEach(k => {
                    try { localStorage.removeItem(k); } catch {}
                });
                msg.className = "ta-save-status ta-save-err";
                msg.textContent = "All data cleared.";
                this.lastSync = 0;
                this._tickFooter();
                setTimeout(() => this._renderBody(), 1500);
            });
        }

        // ── Sync ──────────────────────────────────────────────
        async syncData() {
            if (this.syncing) return;
            const key = KeyResolver.resolveTornKey();
            if (!key) return;
            const api = new TornAPI(key);

            this.syncing = true; this.lastErr = null;
            this._tickFooter();

            try {
                // Validate key + get own ID
                const prof = await api.validateKey();
                if (!prof) throw new Error("API key invalid or expired.");
                this.myId = prof.id || prof.player_id;

                const lastAtkTs  = getTs(LS.lastAttackTs);
                const lastCrTs   = getTs(LS.lastCrimeTs);
                const lastSnapTs = getTs(LS.lastSnapTs);
                let newEvents    = [];
                let newAtkTs     = lastAtkTs;
                let newCrTs      = lastCrTs;

                // ── Fetch attacks ──────────────────────────────
                try {
                    const attacks = await api.fetchAttacks(lastAtkTs);
                    if (attacks.length > 0) {
                        newEvents.push(...processAttacks(attacks, this.myId, this.settings));
                        newAtkTs = Math.max(...attacks.map(a => a.ended || a.timestamp_ended || a.timestamp || 0), newAtkTs);
                    }
                } catch (e) {
                    if (e.tornCode === 18) { /* no attacks — normal */ } else throw e;
                }

                // ── Fetch crimes ───────────────────────────────
                if (this.settings.includeCrimes) {
                    try {
                        const crimes = await api.fetchCrimes(lastCrTs);
                        if (crimes.length > 0) {
                            newEvents.push(...processCrimes(crimes, this.settings));
                            newCrTs = Math.max(...crimes.map(c => c.time_completed || c.ended || c.timestamp || 0), newCrTs);
                        }
                    } catch { /* crimes endpoint not available — skip */ }
                }

                // ── Merge & save events ────────────────────────
                const merged = mergeEvents(loadEvents(), newEvents);
                saveEvents(pruneEvents(merged, this.settings));
                if (newAtkTs > lastAtkTs) setTs(LS.lastAttackTs, newAtkTs);
                if (newCrTs  > lastCrTs)  setTs(LS.lastCrimeTs,  newCrTs);

                // ── PersonalStats snapshot (once per hour) ─────
                const now = Math.floor(Date.now()/1000);
                if ((now - lastSnapTs) >= this.settings.snapEvery) {
                    const stats = await api.fetchPersonalStats();
                    if (stats) {
                        const snap = { ts: now };
                        for (const f of SNAP_FIELDS) { if (stats[f] != null) snap[f] = stats[f]; }
                        const snaps = loadSnapshots();
                        snaps.push(snap);
                        saveSnapshots(snaps);
                        setTs(LS.lastSnapTs, now);
                    }
                }

                this.lastSync = Date.now();
                if (this._panel && this._panel.classList.contains("ta-open")) this._renderBody();

            } catch (e) {
                this.lastErr = e.message || "Sync failed";
            } finally {
                this.syncing = false;
                this._tickFooter();
                // Schedule next auto-sync
                if (this._syncTmr) clearTimeout(this._syncTmr);
                this._syncTmr = setTimeout(() => {
                    if (this._panel && this._panel.classList.contains("ta-open")) this.syncData();
                }, this.settings.refreshSec * 1000);
            }
        }
    }

