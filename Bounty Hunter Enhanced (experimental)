    function isDebugOn() { try { return localStorage.getItem(LS.debug) === "1"; } catch { return false; } }
    function redactUrl(url) {
        try { const u=new URL(url),p=new URLSearchParams(u.search); for(const k of["key","apikey"]) if(p.has(k)) p.set(k,"***"); const q=p.toString(); return `${u.host}${u.pathname}${q?"?"+q:""}`; } catch { return url; }
    }
    function logDebug(label,level="info",ms=null) {
        if(!isDebugOn()) return;
