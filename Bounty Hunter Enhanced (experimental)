    // Resolve description text to a canonical country name
    function resolveCountryFromDesc(desc){
        const d=(desc||"").toLowerCase();
        for(const name of Object.keys(FLIGHT_MINS)){if(d.includes(name.toLowerCase()))return name;}
        if(/mex/.test(d))return"Mexico";
        if(/cayman/.test(d))return"Cayman Islands";
        if(/can/.test(d))return"Canada";
        if(/hawaii/.test(d))return"Hawaii";
        if(/united kingdom|london|uk/.test(d))return"United Kingdom";
        if(/argentin/.test(d))return"Argentina";
        if(/swiss/.test(d))return"Switzerland";
        if(/japan/.test(d))return"Japan";
        if(/china/.test(d))return"China";
        if(/emirates|dubai|uae/.test(d))return"United Arab Emirates";
        if(/south africa/.test(d))return"South Africa";
        return null;
    }
    // Compute landing timestamp from first observation of travel
    function computeLandingTs(desc,plane){
        const country=resolveCountryFromDesc(desc);
        if(!country)return 0;
        const durations=FLIGHT_MINS[country];
        if(!durations)return 0;
        const mins=durations[plane]||durations.airliner||0;
        if(!mins)return 0;
        return Math.floor(Date.now()/1000)+mins*60;
    }

