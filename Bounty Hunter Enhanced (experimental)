    }

    // ── Utilities ──────────────────────────────────────────────
    const fmt = {
        money(n) { if(n==null)return"$0"; const a=Math.abs(n),s=a>=1e9?(a/1e9).toFixed(2)+"B":a>=1e6?(a/1e6).toFixed(2)+"M":a>=1e3?(a/1e3).toFixed(1)+"K":a.toLocaleString(); return(n<0?"-$":"$")+s; },
        moneyFull(n) { return(n<0?"-":"")+"\$"+Math.abs(n).toLocaleString(); },
        hospLabel(untilSec) { const rem=Math.max(0,untilSec-Math.floor(Date.now()/1000)); if(rem<=0)return"🏥 out"; const m=Math.floor(rem/60),s=rem%60; return m===0?`🏥 ${s}s`:`🏥 ${m}m ${s}s`; },
        travelLabel(description,landingTs) { const dir=travelDirLabel(description||""); if(!landingTs)return dir; const rem=Math.max(0,landingTs-Math.floor(Date.now()/1000)); if(!rem)return dir; const m=Math.floor(rem/60),s=rem%60; return `${dir} ${m}m ${String(s).padStart(2,"0")}s`; },
    };
    const sleep = (ms) => new Promise((r) => setTimeout(r,ms));
    function parseBS(human) {
        if(!human) return null;
        const m=String(human).match(/^\s*([\d.]+)\s*([kKmMbB]?)\s*$/); if(!m) return null;
        const n=parseFloat(m[1]); if(!Number.isFinite(n)) return null;
        const s=(m[2]||"").toLowerCase(), mult=s==="k"?1e3:s==="m"?1e6:s==="b"?1e9:1; return n*mult;
    }
    function escHtml(s) { return String(s==null?"":s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
    const _TRAVEL_MAP={"Mexico":"MEX","Cayman Islands":"CAY","Canada":"CAN","Hawaii":"HAW","United Kingdom":"UK","Argentina":"ARG","Switzerland":"SWI","Japan":"JPN","China":"CHI","United Arab Emirates":"UAE","South Africa":"SA"};
    function travelDestShort(desc){
        if(!desc)return"Abroad";
        for(const[full,short]of Object.entries(_TRAVEL_MAP)){if(desc.includes(full))return short;}
        const m=/(?:to |from |In )([A-Z][a-zA-Z]+)/.exec(desc);
        return(m&&!/torn/i.test(m[1]))?m[1].substring(0,3).toUpperCase():"Abroad";
    }
    function travelDirLabel(desc){
        if(!desc)return"✈️ Abroad";
        const country=travelDestShort(desc);
        // Returning to Torn = inbound arrow
        if(/returning to torn/i.test(desc))return`✈️ ← ${country}`;
        // Actively flying out
        if(/traveling to/i.test(desc)&&!/torn/i.test(desc))return`✈️ → ${country}`;
        // "In X" = already abroad, no flight arrow, just country
        if(/^in /i.test(desc.trim()))return`✈️ ${country}`;
        return`✈️ ${country}`;
    }
    function revivableEmoji(revivable,statusState) { if(statusState!=="Hospital")return"—"; if(revivable===true)return"💚"; if(revivable===false)return"❌"; return"⚠️"; }
    function loadSettings() { try { const raw=localStorage.getItem(LS.settings); return{...DEFAULT_SETTINGS,...(raw?JSON.parse(raw):{})}; } catch { return{...DEFAULT_SETTINGS}; } }
    function saveSettings(s) { localStorage.setItem(LS.settings,JSON.stringify(s)); }
    function openTornUrl(url) { const a=document.createElement("a"); a.href=url; a.target="_blank"; a.rel="noopener noreferrer"; document.body.appendChild(a); a.click(); a.remove(); }

    // ── HTTP ───────────────────────────────────────────────────
    function _gmGet(url) {
        return new Promise((resolve,reject) => { GM_XHR({method:"GET",url,onload:(r)=>resolve({status:r.status,text:r.responseText}),onerror:()=>reject(new Error("network_error")),ontimeout:()=>reject(new Error("timeout"))}); });
    }
    async function _httpGetOnceRaw(url) {
        if(IS_PDA) { const res=await PDA_httpGet(url); if(res.status<200||res.status>=300){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;} return JSON.parse(res.responseText); }
        if(GM_XHR) { const res=await _gmGet(url); if(res.status<200||res.status>=300){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;} return JSON.parse(res.text); }
        const res=await fetch(url); if(!res.ok){const e=new Error(`HTTP ${res.status}`);e.status=res.status;throw e;} return res.json();
    }
    async function _httpGetOnce(url) {
        const t0=performance.now(),rd=redactUrl(url);
        try { const data=await _httpGetOnceRaw(url),ms=performance.now()-t0,tc=data&&data.error&&data.error.code; if(tc===5)logDebug(`GET ${rd} → rate limit`,"err",ms); else if(tc)logDebug(`GET ${rd} → code ${tc}`,"warn",ms); else logDebug(`GET ${rd} → 200`,"ok",ms); return data; }
        catch(err) { logDebug(`GET ${rd} → ${err.status||"ERR"}`,(err.status===429)?"err":"warn",performance.now()-t0); throw err; }
    }
    async function httpGetJson(url) {
        try { return await _httpGetOnce(url); }
        catch(err) { if(err.status>=400&&err.status<500) throw err; logDebug("retry","warn"); await sleep(400); return _httpGetOnce(url); }
    }
    function isRateLimitError(err) { if(!err)return false; if(err.status===429)return true; if(err.tornCode===5)return true; return false; }

    // ── Torn API ───────────────────────────────────────────────
    class TornAPI {
        constructor(key) { this.key=key; this._lastReq=0; }
        setKey(key) { this.key=key; }
        async _rateLimit() { const w=API_DELAY_MS-(Date.now()-this._lastReq); if(w>0)await sleep(w); this._lastReq=Date.now(); }
        async _get(pathOrUrl,params=null) {
            await this._rateLimit();
            const url=new URL(/^https?:\/\//.test(pathOrUrl)?pathOrUrl:API_BASE+pathOrUrl);
            if(params)for(const[k,v]of Object.entries(params))url.searchParams.set(k,v);
            if(!url.searchParams.has("key"))url.searchParams.set("key",this.key);
            const data=await httpGetJson(url.toString());
            if(data&&data.error){const e=new Error(data.error.error||"Torn API error");e.tornCode=data.error.code;throw e;}
            return data;
        }
        async fetchAllBounties() {
            const all=[]; let url=`${API_BASE}/torn/bounties?limit=100&offset=0`,delay=0,safety=10;
            while(url&&safety-->0) {
                const data=await this._get(url);
                if(Array.isArray(data.bounties))all.push(...data.bounties);
                if(typeof data.bounties_delay==="number")delay=data.bounties_delay;
                const next=data._metadata&&data._metadata.links&&data._metadata.links.next;
                if(!next||!data.bounties||data.bounties.length===0)break; url=next;
            }
            return{bounties:all,delaySec:delay};
        }
        async fetchUserProfile(id) { const data=await this._get(`/user/${id}/profile`); if(!data)return null; return data.profile||(data.id?data:null); }
        async validateKey() { const data=await this._get("/user/profile"); return(data&&data.profile)||null; }
    }

    // ── FFScouter ──────────────────────────────────────────────
    async function validateFFScouterKey(key) {
        if(!/^[A-Za-z0-9]{16}$/.test(key))return{ok:false,message:"Must be 16 alphanumeric characters."};
        try { const data=await httpGetJson(`${FF_BASE}/check-key?key=${encodeURIComponent(key)}`); if(data&&data.code)return{ok:false,message:data.error||`FFScouter code ${data.code}`}; if(!data||!data.is_registered)return{ok:false,message:"Key is not registered — sign up at ffscouter.com first."}; return{ok:true,message:data.is_premium?"Valid — premium.":"Valid."}; }
        catch(e){return{ok:false,message:e&&e.message?e.message:"Could not reach FFScouter."};}
    }
    async function fetchFFScouterStats(key,userIds) {
        const result={map:new Map(),error:null,nullCount:0,totalReturned:0,networkFail:false};
        if(!key){result.error="no_key";return result;}
        if(userIds.length===0)return result;
        for(let i=0;i<userIds.length;i+=200) {
            const chunk=userIds.slice(i,i+200),url=`${FF_BASE}/get-stats?key=${encodeURIComponent(key)}&targets=${chunk.join(",")}`;
            try {
                const data=await httpGetJson(url);
                if(!Array.isArray(data)){result.error=(data&&data.error)?data.error:"unexpected_response";continue;}
                result.totalReturned+=data.length;
                for(const p of data){if(p.fair_fight==null){result.nullCount++;continue;}result.map.set(Number(p.player_id),{ff:Number(p.fair_fight),bs:p.bs_estimate_human||null});}
            } catch(e) {
                if(isRateLimitError(e))throw e;
                if(!result.error){result.error=e.message||"network_error";if(String(e.message).match(/fetch|network|Failed/i))result.networkFail=true;}
            }
        }
        return result;
    }

    // ── Key Resolver ───────────────────────────────────────────
    const KeyResolver = {
        resolveTornKey(){if(HAS_PDA_KEY)return PDA_API_KEY;return localStorage.getItem(LS.apiKey)||null;},
        hasSPAKey(){const k=localStorage.getItem(SPA_LS_APIKEY);return!!k&&/^[A-Za-z0-9]{16}$/.test(k);},
        getSPAKey(){return localStorage.getItem(SPA_LS_APIKEY);},
        saveTornKey(k){localStorage.setItem(LS.apiKey,k);}, clearTornKey(){localStorage.removeItem(LS.apiKey);},
        getFFKey(){return localStorage.getItem(LS.ffKey)||"";},
        saveFFKey(k){localStorage.setItem(LS.ffKey,k);}, clearFFKey(){localStorage.removeItem(LS.ffKey);},
        isPDAKey(){return HAS_PDA_KEY;},
    };

    // ── Marked Target Store ────────────────────────────────────
    const MarkedTargetStore={
        load(){try{const r=localStorage.getItem(LS.marked);return r?JSON.parse(r):[];}catch{return[];}},
        save(list){try{localStorage.setItem(LS.marked,JSON.stringify(list));}catch{}},
        has(id){return this.load().some((t)=>t.id===Number(id));},
        add(t){const list=this.load();if(!list.some((x)=>x.id===Number(t.id))){list.push({id:Number(t.id),name:String(t.name||`Player ${t.id}`),level:Number(t.level)||0});this.save(list);}},
        remove(id){this.save(this.load().filter((t)=>t.id!==Number(id)));},
        updateInfo(id,name,level){const list=this.load();const t=list.find((x)=>x.id===Number(id));if(t&&name){t.name=name;if(level)t.level=level;this.save(list);}},
    };

    // ── Hunter ─────────────────────────────────────────────────
    class Hunter {
        constructor(api) {
            this.api=api; this.settings=loadSettings();
            this.myUserId=null; this.myUserLevel=null; this.myUserAge=null; this.myCountry=null;
            this.lastMatches=[]; this.lastMatchIds=new Set(); this.lastCounts=null;
            this._statusCache=new Map(); this._travelCache=new Map(); this._warCache=null; this._timer=null; this._running=false; this._nextAt=0;
            this.lastError=null; this.onUpdate=null; this.onToast=null; this.onHospAlert=null; this.onBountyClaimed=null; this.onMarkedUpdate=null; this.onMarkedAlert=null; this.lastMarkedStatuses=new Map();
        }
        updateSettings(next) { this.settings={...this.settings,...next}; saveSettings(this.settings); this.lastMatchIds=new Set(); this._warCache=null; try{localStorage.removeItem(LS.shared);}catch{} }
        _readShared() { try{const raw=localStorage.getItem(LS.shared);if(!raw)return null;const s=JSON.parse(raw);if(!s||typeof s.writtenAt!=="number")return null;return s;}catch{return null;} }
        _writeShared() { try{localStorage.setItem(LS.shared,JSON.stringify({writtenAt:Date.now(),refreshSec:this.settings.refreshSec,matches:this.lastMatches,lastCounts:this.lastCounts,myUserId:this.myUserId,myUserLevel:this.myUserLevel,myUserAge:this.myUserAge,myCountry:this.myCountry,lastError:this.lastError?(this.lastError.message||"error"):null}));}catch{} }
        _adoptSharedIdentity(s) { if(s.myUserId!=null&&this.myUserId==null)this.myUserId=s.myUserId; if(s.myUserLevel!=null&&this.myUserLevel==null)this.myUserLevel=s.myUserLevel; if(s.myUserAge!=null&&this.myUserAge==null)this.myUserAge=s.myUserAge; if(s.myCountry!=null)this.myCountry=s.myCountry; }
        _applyMatches(matches) {
            const key=(m)=>`${m.target_id}|${m.reward}`,currentIds=new Set(matches.map(key)),newOnes=matches.filter((m)=>!this.lastMatchIds.has(key(m)));
            if(this.settings.toastsEnabled&&this.onToast&&newOnes.length>0)this.onToast(newOnes);
            this.lastMatches=matches; this.lastMatchIds=currentIds;
            if(this.onHospAlert)this.onHospAlert(matches);
        }
        adoptSharedPayload(s) { if(!s)return; this._adoptSharedIdentity(s); if(Array.isArray(s.matches)){this.lastCounts=s.lastCounts||null;this._applyMatches(s.matches);} if(this.onUpdate)this.onUpdate(); }
        stop() { if(this._timer){clearTimeout(this._timer);this._timer=null;} this._running=false; }
        start() { if(this._running)return; this._running=true; this._tick(); }
        async _tick() {
            if(!this._running)return;
            let waitSec=this.settings.refreshSec;
            try {
                const shared=this._readShared(),fresh=shared&&(Date.now()-shared.writtenAt)<(this.settings.refreshSec*1000*SHARED_FRESH_RATIO);
                if(fresh){logDebug(`free-ride: ${shared.matches?shared.matches.length:0} matches`,"info");this._adoptSharedIdentity(shared);this.lastCounts=shared.lastCounts||null;this.lastError=null;this._applyMatches(shared.matches||[]);if(this.onUpdate)this.onUpdate();}
                else{const delaySec=await this.refresh();waitSec=Math.max(this.settings.refreshSec,delaySec||0);}
            } catch(err) { this.lastError=err; logDebug(`refresh ${isRateLimitError(err)?"aborted — rate limit":"failed: "+(err.message||"error")}`,"err"); if(this.onUpdate)this.onUpdate(); waitSec=Math.max(this.settings.refreshSec,30); }
            await this.refreshMarked().catch(()=>{});
            if(this.settings.refreshSec<=0)return;
            this._nextAt=Date.now()+waitSec*1000; this._timer=setTimeout(()=>this._tick(),waitSec*1000);
        }
        async refresh() {
            this.lastError=null; const t0=performance.now(); logDebug("refresh: start","info"); if(this.onUpdate)this.onUpdate({loading:true});
            try { const profile=await this.api.validateKey(); if(profile){this.myUserId=profile.id||this.myUserId;this.myUserLevel=(typeof profile.level==="number")?profile.level:this.myUserLevel;this.myUserAge=(typeof profile.age==="number")?profile.age:this.myUserAge;this.myCountry=getPlayerCountry(profile.status)||this.myCountry;} } catch{}
            const{bounties,delaySec}=await this.api.fetchAllBounties(); logDebug(`fetched ${bounties.length} bounties`,"ok");
            // Deduplicate by target — keep highest-reward bounty per person, sum counts.
            const grouped=new Map();
            for(const b of bounties){
                const id=String(b.target_id),qty=(typeof b.quantity==="number"&&b.quantity>0)?b.quantity:1;
                if(!grouped.has(id)){grouped.set(id,{...b,bountyCount:qty});}
                else{const ex=grouped.get(id);const newCount=ex.bountyCount+qty;if(b.reward>ex.reward){grouped.set(id,{...b,bountyCount:newCount});}else{ex.bountyCount=newCount;}}
            }
            const deduped=[...grouped.values()];
            // Detect bounties claimed since last refresh: hospital matches that vanished from the board.
            if(this.lastMatches.length>0){
                const boardIds=new Set(deduped.map((b)=>String(b.target_id)));
                const claimed=this.lastMatches.filter((m)=>m.statusState==="Hospital"&&!boardIds.has(String(m.target_id)));
                if(claimed.length>0&&this.onBountyClaimed)this.onBountyClaimed(claimed);
            }
            const counts={total:bounties.length,afterBasic:0,withFF:0,ffNull:0,ffError:null,ffNetworkFail:false,afterFF:0,afterBS:0,statusBreakdown:{},notRevivable:0,tooNew:0,differentCountry:0,matches:0};
