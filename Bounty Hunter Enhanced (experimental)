    // ── Profile Button Injector ───────────────────────────────
    function setupProfileButtonInjector(){
        let lastUrl="",lastXid="";
        const tryInject=()=>{
            const url=location.href;
            if(!url.includes("profiles.php")){
                const b=document.getElementById("bh-mark-btn");if(b)b.remove();lastXid="";return;
            }
            const xid=new URLSearchParams(location.search).get("XID")||"";
            if(!xid){const b=document.getElementById("bh-mark-btn");if(b)b.remove();lastXid="";return;}
            if(document.getElementById("bh-mark-btn")&&lastXid===xid)return;
            const prev=document.getElementById("bh-mark-btn");if(prev)prev.remove();
            lastXid=xid;
            const id=Number(xid);if(!id)return;
            // Try to grab name from page DOM
            let name=`Player ${id}`,level=0;
            for(const sel of ["[class*='playerName']","[class*='player-name']","[class*='name___']",".profile-header h4","h4.bold"]) {
                const el=document.querySelector(sel);
                if(el&&el.textContent.trim()&&el.textContent.trim().length<40){name=el.textContent.trim();break;}
            }
            const isMarked=MarkedTargetStore.has(id);
            const btn=document.createElement("button");
            btn.id="bh-mark-btn";
            btn.className="bh-mark-profile-btn"+(isMarked?" bh-mark-profile-btn-active":"");
            btn.textContent=isMarked?"✓ Marked":"🎯 Mark";
            btn.addEventListener("click",()=>{
                if(MarkedTargetStore.has(id)){MarkedTargetStore.remove(id);btn.textContent="🎯 Mark";btn.classList.remove("bh-mark-profile-btn-active");}
                else{MarkedTargetStore.add({id,name,level});btn.textContent="✓ Marked";btn.classList.add("bh-mark-profile-btn-active");}
            });
            document.body.appendChild(btn);
        };
        // Poll for SPA URL changes
        setInterval(()=>{if(location.href!==lastUrl){lastUrl=location.href;setTimeout(tryInject,500);setTimeout(tryInject,1500);}},400);
        tryInject();setTimeout(tryInject,800);setTimeout(tryInject,2000);
    }

